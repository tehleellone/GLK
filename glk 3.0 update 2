function fmt(v){
  const n=num(v);
  if(n>=1e9) return (n/1e9).toFixed(2)+'B';
  if(n>=1e6) return (n/1e6).toFixed(2)+'M';
  if(n>=1e3) return (n/1e3).toFixed(1)+'K';
  return n.toFixed(0);
}
function fmtGA(v){ const n=num(v); return n%1===0?n.toFixed(0):n.toFixed(2); }
const fmtDate = iso => { if(!iso) return '—'; const d=new Date(iso); return isNaN(d)?'—':d.toLocaleDateString('en-GB'); };
  function fmtYearImpact(v) {
  if (v === null || v === undefined) return '—';
  if (v === 0) return 'AED 0';
  if (v >= 1e6) return 'AED ' + (v / 1e6).toFixed(2) + 'M';
  if (v >= 1e3) return 'AED ' + v.toLocaleString('en-US');
  return 'AED ' + v.toFixed(0);
}

function calcYearImpact(bid) {
  const STATUS_SKIP = ['Lost', 'Cancelled', 'No Bid'];
  if (STATUS_SKIP.includes(bid.status)) return { val: null, note: null };
  if (!bid.expectedActivation) return { val: null, note: null };
  const actDate = new Date(bid.expectedActivation);
  if (isNaN(actDate)) return { val: null, note: null };
  const currentYear = new Date().getFullYear();
  const actYear = actDate.getFullYear();
  if (actYear < currentYear) return { val: null, note: null };
  if (actYear > currentYear) return { val: null, note: 'Expected activation in ' + actYear + ' — cannot calculate this year' };
  const monthsRemaining = 12 - actDate.getMonth();
  const impact = bid.mrc * monthsRemaining;
  return { val: impact, note: null };
}
