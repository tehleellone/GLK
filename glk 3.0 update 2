  var wrap=el('forecastPieControlsWrap');
  if(wrap) wrap.innerHTML=glkChartControlsHtml('chartPeriodSelectPie','chartPeriodSelectPie');
}
function glkBridgeTargetLinePlugin(targetDispY,labelText,c){
  return {id:'glkBridgeTargetLine',afterDatasetsDraw:function(chart){
    var y=chart.scales.y,area=chart.chartArea,ctx=chart.ctx;
    if(!y) return;
    var py=y.getPixelForValue(targetDispY);
    if(py<area.top-2||py>area.bottom+2) return;
    ctx.save();
    ctx.strokeStyle='#ef4444';
    ctx.lineWidth=1.5;
    ctx.setLineDash([6,4]);
    ctx.beginPath();ctx.moveTo(area.left,py);ctx.lineTo(area.right,py);ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='#ef4444';
    ctx.font='bold 10px Inter';
    ctx.textAlign='right';
    ctx.textBaseline='bottom';
    ctx.fillText(labelText,area.right-6,py-3);
    ctx.restore();
  }};
}
function renderBridge(bids,c){
  destroyChart('bridge');
  var scoped=glkFilterByChartPeriod(bids,chartPeriod);
  var metric=chartMetric;
  var targetVal=bridgeTarget;
  var targetM=targetVal/1e6;
  var wonBids=scoped.filter(function(b){return b.forecastCategory==='Closed Won'||STATUS_WON.includes(b.status);});
  var wonVal=wonBids.reduce(function(s,b){return s+glkBidMetric(b,metric);},0);
  var wonM=wonVal/1e6;
  var pipeItems=[];
  BRIDGE_SECTIONS.forEach(function(sec){
    if(sec.key==='won') return;
    glkBridgeFourBars(scoped.filter(sec.filter),metric).forEach(function(cb,ci){
      if(cb.value<=0) return;
      pipeItems.push({
        name:cb.name,value:cb.value,
        custName:glkBridgeBarLabel(cb.name,cb.value),
        color:sec.colors[ci]||sec.colors[sec.colors.length-1],
        secLabel:sec.label,secKey:sec.key,secColor:sec.colors[1]||sec.colors[0]
      });
    });
  });
  var pipeTotal=pipeItems.reduce(function(s,p){return s+p.value;},0);
  var pipeTotalM=pipeTotal/1e6;
  var nz=pipeItems.length;
  var forecastVal=wonVal+pipeTotal;
  var forecastM=forecastVal/1e6;
  var gap=forecastVal-targetVal,over=gap>=0;
  var targetOffScale=targetM>forecastM*2;
  // Display-only scale (NOT real AED) — y-axis locked to these units; AED on bars/tooltips.
  var WON_DISP=5.5;
  var STEP_H=2.2;
  var hasPipe=nz>0;
  var wonDispEnd=hasPipe?WON_DISP:wonM;
  var dispTop=wonDispEnd;
  var bars=[],barMeta=[],sectionGroups=[];
  var truePipeRunning=0;
  // Won
  bars.push({value:wonVal,trueEnd:wonVal,displayStart:0,displayEnd:wonDispEnd,color:'#16a34a',type:'won'});
  barMeta.push({label:'Won · '+fmt(wonVal)});
  sectionGroups.push({key:'won',label:'Won',color:'#16a34a',startIdx:0,endIdx:0});
  var labelList=[''];
  pipeItems.forEach(function(p){
    var idx=bars.length;
    var trueStart=wonVal+truePipeRunning,trueEnd=trueStart+p.value;
    var dStart=dispTop,dEnd=dispTop+STEP_H;
    dispTop=dEnd;
    bars.push({
      value:p.value,trueStart:trueStart,trueEnd:trueEnd,
      displayStart:dStart,displayEnd:dEnd,
      custName:p.custName,color:p.color,type:'step'
    });
    barMeta.push({label:p.secLabel+': '+p.name+' · '+fmt(p.value)});
    truePipeRunning+=p.value;
    labelList.push('');
    if(sectionGroups.length&&sectionGroups[sectionGroups.length-1].key===p.secKey){
      sectionGroups[sectionGroups.length-1].endIdx=idx;
    }else{
      sectionGroups.push({key:p.secKey,label:p.secLabel,color:p.secColor,startIdx:idx,endIdx:idx});
    }
  });
  var forecastDispTop=hasPipe?dispTop:forecastM;
  var fIdx=bars.length;
  bars.push({value:forecastVal,trueEnd:forecastVal,displayStart:0,displayEnd:forecastDispTop,color:over?'#0ea5e9':'#f59e0b',type:'forecast',gap:gap,over:over});
  barMeta.push({label:'Forecast '+fmt(forecastVal)+(over?' · +'+fmt(gap)+' over target':' · '+fmt(Math.abs(gap))+' short')});
  sectionGroups.push({key:'forecast',label:'Forecast',color:over?'#0ea5e9':'#f59e0b',startIdx:fIdx,endIdx:fIdx});
  labelList.push('');
  var targetDisp=null,targetLabel='Target '+fmt(targetVal);
  if(!targetOffScale&&hasPipe){
    var pipeDispSpan=forecastDispTop-wonDispEnd;
    var aboveScale=pipeTotalM>0?pipeDispSpan/pipeTotalM:STEP_H;
    if(targetM<=wonM&&wonM>0) targetDisp=(targetM/wonM)*WON_DISP;
    else targetDisp=wonDispEnd+(targetM-wonM)*aboveScale;
  }else if(!targetOffScale&&!hasPipe){
    targetDisp=targetM;
  }
  var floatData=bars.map(glkBridgeFloatBar);
  var bg=bars.map(function(b){return b.color;});
  var yMax=Math.max(forecastDispTop,targetDisp||0,0.001)*1.06;
  var bridgePlugins=[
    glkBridgeMinPxPlugin(bars,42),
    glkBridgeBarLabelPlugin(bars),
    glkBridgeGroupPlugin(sectionGroups,c),
    glkBridgeConnectorPlugin(bars)
  ];
  if(targetDisp!=null) bridgePlugins.push(glkBridgeTargetLinePlugin(targetDisp,targetLabel,c));
  CHARTS.bridge=new Chart(el('chartBridge'),{
    type:'bar',
    plugins:bridgePlugins,
    data:{labels:labelList,glkBars:bars,datasets:[{
      label:(metric==='mrc'?'MRC':'TCV'),
      data:floatData,
      backgroundColor:bg,
      borderRadius:5,
      borderSkipped:false,
      barPercentage:.92,
      categoryPercentage:.88,
      maxBarThickness:68
    }]},
    options:{responsive:true,maintainAspectRatio:false,
      layout:{padding:{bottom:72,top:targetOffScale?22:14,left:6,right:10}},
      plugins:{
        legend:{display:false},
        tooltip:{backgroundColor:'rgba(15,10,30,.88)',padding:14,cornerRadius:12,titleFont:{size:12,weight:'700'},bodyFont:{size:12},
          callbacks:{
            title:function(items){return barMeta[items[0].dataIndex]?barMeta[items[0].dataIndex].label:'';},
            label:function(ctx){
              var b=bars[ctx.dataIndex];
              if(b.type==='won') return '  Won '+fmt(b.value);
              if(b.type==='forecast') return b.over?('  '+fmt(b.value)+'  (+'+fmt(b.gap)+' over target)'):('  '+fmt(b.value)+'  ('+fmt(Math.abs(b.gap))+' short)');
              return '  +'+fmt(b.value);
            },
            afterBody:function(items){
              var b=bars[items[0].dataIndex];
              if(b.type==='step') return ['  Running total: '+fmt(b.trueEnd)];
              return [];
            }
          }
        }
      },
      scales:{
        x:{ticks:{display:false},grid:{display:false},border:{display:true,color:c.grid||'rgba(148,163,184,.3)'}},
        y:{min:0,max:yMax,grace:'0%',ticks:{display:false},grid:{color:c.grid},border:{display:false},
          title:{display:true,text:'AED values shown on bars',color:c.text,font:{size:9,weight:'600'}}}
      }
    }
  });
  var wrap=el('bridgeControlsWrap');
  if(wrap){
    var gapTxt=over?('<span style="color:#0ea5e9;">+'+fmt(gap)+' over target</span>'):('<span style="color:#f59e0b;">'+fmt(Math.abs(gap))+' short of target</span>');
    var targetNote=targetOffScale?(' · <span style="color:#ef4444;">Target '+fmt(targetVal)+' (above chart scale)</span>'):'';
    wrap.innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;margin-top:.65rem;flex-wrap:wrap;gap:.5rem;">'+
      '<div style="font-size:.68rem;color:var(--t3);font-weight:600;">Won '+fmt(wonVal)+' · Pipeline +'+fmt(pipeTotal)+' · Forecast '+fmt(forecastVal)+' · Target '+fmt(targetVal)+' · '+gapTxt+targetNote+'</div>'+
      '<div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;">'+glkChartMetricBtns()+glkChartPeriodSelect('chartPeriodSelectBridge')+'</div></div>';
  }
}
