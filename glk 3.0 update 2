    if(!isLocked) trig.onclick=function(e){e.stopPropagation();toggleMs(fd.key);};
    const drop=document.createElement('div'); drop.className='ms-dropdown'; drop.id='msd_'+fd.key;
    getFilterVals(fd.key).forEach(function(v){
      if(!v||v==='—'||v==='All') return;
      const label=v;
      const opt=document.createElement('div'); opt.className='ms-option';
      const cid='cb_'+fd.key+'_'+v.toString().replace(/[^a-zA-Z0-9]/g,'_');
      opt.innerHTML='<input type="checkbox" id="'+cid+'" value="'+v+'" onchange="onFilterChange(\''+fd.key+'\')"><label for="'+cid+'">'+label+'</label>';
      drop.appendChild(opt);
    });
    wrap.appendChild(trig); wrap.appendChild(drop); div.appendChild(wrap); grid.appendChild(div);
  });
  applyRoleLocks();
  glkBuildDateFilters();
}
function applyRoleLocks(){
  if(USER.role==='Viewer'||USER.role==='Admin'||USER.role==='CEO') return;
  
  if(USER.role==='Head Director'){
    const v=findMyHD();
    if(!v){preSelectAndLock('headDirector',['__NOACCESS__']);return;}
    preSelectAndLock('headDirector',[v]);
  }
  
  if(USER.role==='Account Director'){
    const v=findMyAD();
    if(!v){preSelectAndLock('accountDirector',['__NOACCESS__']);return;}
    const hd=[...new Set(ALL_BIDS.filter(b=>b.accountDirector===v).map(b=>b.headDirector))];
    preSelectAndLock('headDirector',hd);
    preSelectAndLock('accountDirector',[v]);
  }
  
if(USER.role==='Account Manager'){
    let amBids=ALL_BIDS.filter(b=>b.amEmail&&b.amEmail.toLowerCase()===USER.email.toLowerCase());
    if(!amBids.length&&USER.name) amBids=ALL_BIDS.filter(b=>b.amName&&b.amName.toLowerCase()===USER.name.toLowerCase());
    if(!amBids.length){preSelectAndLock('amName',['__NOACCESS__']);return;}
    const amName=amBids[0].amName;
    preSelectAndLock('headDirector',[...new Set(amBids.map(b=>b.headDirector))]);
    preSelectAndLock('accountDirector',[...new Set(amBids.map(b=>b.accountDirector))]);
    preSelectAndLock('amName',[amName]);
  }
}
function findMyHD(){ 
  const name=USER.name.toLowerCase().trim();
  const d=ALL_BIDS.find(b=>b.headDirector&&(
    b.headDirector.toLowerCase().trim()===name||
    b.headDirector.toLowerCase().includes(name)||
    name.includes(b.headDirector.toLowerCase().trim())
  ));
  return d?d.headDirector:null; 
}
function findMyAD(){ 
  const name=USER.name.toLowerCase().trim();
  const d=ALL_BIDS.find(b=>b.accountDirector&&(
    b.accountDirector.toLowerCase().trim()===name||
    b.accountDirector.toLowerCase().includes(name)||
    name.includes(b.accountDirector.toLowerCase().trim())
  ));
