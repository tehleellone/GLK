function toggleCharts(){
  chartsVisible=!chartsVisible;
  el('chartsSection').style.display=chartsVisible?'block':'none';
  el('chartsToggleText').textContent=chartsVisible?'Hide Analytics Charts':'Show Analytics Charts';
  if(chartsVisible) setTimeout(()=>renderCharts(),80);
}
function getChartColors(){
  const t=document.body.getAttribute('data-theme')||'';
  const isDark=t==='dark'||t==='duralux-dark';
  const isDural=t==='duralux'||t==='duralux-dark';
  return {
    text:isDark?'rgba(255,255,255,0.6)':'rgba(0,0,0,0.5)',
    grid:isDark?'rgba(255,255,255,0.07)':'rgba(0,0,0,0.06)',
p1:isDural?'#4c6fff':'#a855f7',
    p2:isDural?'#818cf8':'#c724b1',
    p1a:isDural?'rgba(76,111,255,':'rgba(168,85,247,',
    p2a:isDural?'rgba(129,140,248,':'rgba(199,36,177,',

  };
}
function destroyChart(k){ if(CHARTS[k]){ CHARTS[k].destroy(); CHARTS[k]=null; } }
const dataLabelPlugin={id:'dlp',afterDatasetsDraw(chart){
  const ctx=chart.ctx;
  chart.data.datasets.forEach((ds,di)=>{
    const meta=chart.getDatasetMeta(di);
    if(meta.hidden)return;
    meta.data.forEach((el,i)=>{
      const v=ds.data[i]; if(!v&&v!==0)return;
      const isH=chart.options.indexAxis==='y';
      ctx.save();
      ctx.font='bold 11px Inter,sans-serif';
      ctx.fillStyle=chart.options.scales[isH?'x':'y'].ticks.color||'#666';
      const lbl=v>=1e6?(v/1e6).toFixed(1)+'M':v>=1e3?(v/1e3).toFixed(0)+'K':Number.isInteger(v)?String(v):v.toFixed(1);
      if(isH){ctx.textAlign='left';ctx.textBaseline='middle';const p=el.tooltipPosition();ctx.fillText(lbl,p.x+6,p.y);}
      else{ctx.textAlign='center';ctx.textBaseline='bottom';const p=el.tooltipPosition();ctx.fillText(lbl,p.x,p.y-4);}
      ctx.restore();
    });
  });
}};
