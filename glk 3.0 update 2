function renderForecastPie(bids,c){
  destroyChart('fcPie');
  var scoped=glkFilterByChartPeriod(bids,chartPeriod);
  var metric=chartMetric;
  var groups=FORECAST_PIE_GROUPS.map(function(g){
    var matched=scoped.filter(g.match);
    return {label:g.label,color:g.color,count:matched.length,value:matched.reduce(function(s,b){return s+glkBidMetric(b,metric);},0)};
  }).filter(function(g){return g.value>0||g.count>0;});
  if(!groups.length) groups=FORECAST_PIE_GROUPS.map(function(g){return {label:g.label,color:g.color,count:0,value:0};});
  var total=groups.reduce(function(a,g){return a+g.value;},0);
  var totalCnt=groups.reduce(function(a,g){return a+g.count;},0);
  var labels=groups.map(function(g){
