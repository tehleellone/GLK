  if(USER.role==='Head Director') lockedKeys.add('headDirector');
  if(USER.role==='Account Director'){lockedKeys.add('headDirector');lockedKeys.add('accountDirector');}
  if(USER.role==='Account Manager'){lockedKeys.add('headDirector');lockedKeys.add('accountDirector');lockedKeys.add('amName');}

  FILTER_DEFS.forEach(function(fd){
    const isLocked=lockedKeys.has(fd.key);
    const div=document.createElement('div'); div.className='filter-group';
    div.innerHTML='<div class="filter-label">'+fd.label+'</div>';
    const wrap=document.createElement('div'); wrap.className='ms-wrap'; wrap.id='ms_'+fd.key;
