      plugins:{
        legend:{display:false},
        tooltip:{
          backgroundColor:'rgba(0,0,0,.82)',
          padding:14,
          cornerRadius:10,
          titleFont:{size:13,weight:'700'},
          bodyFont:{size:12},
          bodySpacing:5,
          callbacks:{
            label:ctx=>'  '+metricLabel+': '+ctx.parsed.x.toFixed(2)+'M',
            afterLabel:ctx=>{
              const d=sorted[ctx.dataIndex][1];
              const wr=d.total?(d.won/d.total*100).toFixed(1):0;
              return [
                '  Total Bids: '+d.total,
                '  Won: '+d.won,
                '  Win Rate: '+wr+'%',
                '  MRC: '+fmt(d.mrc),
                '  OTC: '+fmt(d.otc),
              ];
            }
          }
        }
      },
      scales:{
        x:{
          ticks:{color:c.text,font:{size:11},callback:v=>v+'M'},
