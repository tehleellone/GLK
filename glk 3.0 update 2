const SP_LIST   = 'GLK Pipeline Portal';
const SP_ACCESS = 'GKLA_ACCESS';
const STATUS_WON  = ['Won','Billed'];
const STATUS_IP   = ['Lead','Opportunity','On Hold','Proposed'];
const STATUS_LOST = ['Lost','Cancelled','No Bid'];
const PROB_ORDER  = ['0%','25%','50%','75%','100%'];
const FORECAST_OPTIONS=[
  'Not Forecasted','Upside - Bring Home Yes','Upside - Bring Home No',
  'Most Likely - No Risk','Most Likely - Risk to Forecast','Commit','Closed Won','Closed Lost'
];
const FORECAST_TO_PROB={
  'Closed Won':'100%','Closed Lost':'0%','Most Likely - No Risk':'75%',
  'Commit':'75%','Upside - Bring Home Yes':'50%',
  'Upside - Bring Home No':'50%','Not Forecasted':'25%'
};
const PROB_TO_FORECAST={
  '100%':'Closed Won','0%':'Closed Lost','75%':'Most Likely - No Risk',
  '50%':'Upside - Bring Home No','25%':'Not Forecasted'
};
const FORECAST_TO_STATUS={'Closed Won':'Won','Closed Lost':'Lost'};
const FORECAST_PIE_GROUPS=[
  {key:'won',label:'Won',color:'#059669',match:b=>b.forecastCategory==='Closed Won'||STATUS_WON.includes(b.status)},
  {key:'inForecast',label:'In Forecast',color:'#2563eb',match:b=>['Commit','Most Likely - No Risk','Upside - Bring Home Yes'].includes(b.forecastCategory)},
  {key:'mlRisk',label:'ML Risk to Forecast',color:'#ca8a04',match:b=>b.forecastCategory==='Most Likely - Risk to Forecast'},
  {key:'upsideNo',label:'Upside (No Bring Home)',color:'#ea580c',match:b=>b.forecastCategory==='Upside - Bring Home No'},
  {key:'notForecast',label:'Not Forecasted',color:'#64748b',match:b=>b.forecastCategory==='Not Forecasted'},
];
const BRIDGE_SECTIONS=[
  {key:'won',label:'Won',filter:b=>b.forecastCategory==='Closed Won'||STATUS_WON.includes(b.status),colors:['#16a34a','#22c55e']},
