function glkApplyDateRule(bid,rule){
  if(!rule||rule.dateMode==='any') return true;
  const meta=glkDateMeta(glkBidDateValue(bid,rule.dateField));
  if(!meta) return false;
  if(rule.dateMode==='range'){
    if(rule.from){ const fromD=new Date(rule.from); if(!isNaN(fromD)){ fromD.setHours(0,0,0,0); if(meta.dayStart<fromD.getTime()) return false; } }
    if(rule.to){ const toD=new Date(rule.to); if(!isNaN(toD)){ toD.setHours(23,59,59,999); if(meta.dayStart>toD.getTime()) return false; } }
    return true;
  }
  if(rule.dateMode==='single'){
    if(!rule.specific) return true;
    const spec=new Date(rule.specific); if(isNaN(spec)) return true;
    spec.setHours(0,0,0,0); return meta.dayStart===spec.getTime();
  }
  if(rule.dateMode==='ytd'){
    const yr=parseInt(rule.ytdYear||String(new Date().getFullYear()),10);
    if(meta.year!==yr) return false;
    const today=new Date(); today.setHours(23,59,59,999);
    const ytdEnd=(yr===today.getFullYear())?today.getTime():new Date(yr,11,31,23,59,59,999).getTime();
    return meta.dayStart>=new Date(yr,0,1).getTime()&&meta.dayStart<=ytdEnd;
  }
  if(rule.dateMode==='period'){
    if(rule.years&&rule.years.length&&rule.years.indexOf(String(meta.year))<0) return false;
    if(rule.quarters&&rule.quarters.length&&rule.quarters.indexOf(String(meta.quarter))<0) return false;
    if(rule.months&&rule.months.length&&rule.months.indexOf(String(meta.monthIndex))<0) return false;
    if(rule.weeks&&rule.weeks.length&&rule.weeks.indexOf(String(meta.week))<0) return false;
    return true;
  }
  return true;
}
function glkApplyDateRules(bids,rules){
  const active=(rules||[]).filter(r=>r.dateMode&&r.dateMode!=='any');
  if(!active.length) return bids;
  return bids.filter(b=>active.every(r=>glkApplyDateRule(b,r)));
}
function glkRuleIsActive(rule){ return rule&&rule.dateMode&&rule.dateMode!=='any'; }
function glkSummarizeRules(rules,compareYear){
  const active=(rules||[]).filter(glkRuleIsActive);
  if(!active.length) return 'All dates';
  return active.map(function(r){
    const fld=glkDateFieldLabel(r.dateField);
    const yr=compareYear||(r.ytdYear||(r.years&&r.years[0])||'');
    if(r.dateMode==='ytd') return fld+' YTD '+yr;
    if(r.dateMode==='range') return fld+' '+(r.from||'…')+' → '+(r.to||'…');
    if(r.dateMode==='single') return fld+' on '+r.specific;
    if(r.dateMode==='period'){
      const bits=[];
      const ys=compareYear?[compareYear]:(r.years||[]);
      if(ys.length) bits.push(ys.join(','));
      if(r.quarters&&r.quarters.length) bits.push('Q'+r.quarters.join(','));
      if(r.months&&r.months.length) bits.push(r.months.map(m=>MONTH_NAMES[+m]||m).join(','));
      return fld+' '+bits.join(' · ');
    }
    return fld;
  }).join(' + ');
}
function glkRulesForCompareYear(rules){
  const cy=glkCompareYear||String(new Date().getFullYear()-1);
  return rules.map(function(r){
    const c=Object.assign({},r);
    if(r.dateMode==='period') c.years=[cy];
    else if(r.dateMode==='ytd') c.ytdYear=cy;
    else if(r.dateMode==='range'){
      const py=(r.years&&r.years[0])?parseInt(r.years[0],10):(r.from?new Date(r.from).getFullYear():new Date().getFullYear());
      const diff=parseInt(cy,10)-py;
      if(r.from){ const d=new Date(r.from); if(!isNaN(d)){ d.setFullYear(d.getFullYear()+diff); c.from=d.toISOString().slice(0,10); } }
      if(r.to){ const d=new Date(r.to); if(!isNaN(d)){ d.setFullYear(d.getFullYear()+diff); c.to=d.toISOString().slice(0,10); } }
    }
    return c;
  });
}
