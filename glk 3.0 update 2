function renderAMRows(ad){
  el('amSection').style.display='block';
  set('amContext','← '+ad);
  const pfTest=PF_FAMILIES[selPF];
  const isMobile=selPF===MOBILE_PF;
const adBids=FILTERED.filter(b=>pfTest(b.productFamily)&&b.headDirector===selHD&&b.accountDirector===ad&&(!selStatusTile||b.status===selStatusTile));  const amMap={};
  adBids.forEach(function(b){
    const key=b.amEmail||b.amName||'Unknown';
    if(!amMap[key]) amMap[key]={name:b.amName,email:b.amEmail,bids:[]};
    amMap[key].bids.push(b);
  });
  const ams=Object.values(amMap).filter(a=>a.name&&a.name!=='—').sort((a,b)=>b.bids.reduce((s,x)=>s+x.tcv,0)-a.bids.reduce((s,x)=>s+x.tcv,0));
  set('amBadge',ams.length);
  const list=el('amList'); list.innerHTML='';
  if(!ams.length){list.innerHTML='<div style="color:var(--t3);font-size:.84rem;padding:20px;">No account managers found.</div>';return;}
  ams.forEach(function(am,i){
    const s=buildTileStats(am.bids,adBids);
    const key=am.email||am.name;
    const rankClass=i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-other';
    const verticals=[...new Set(am.bids.map(b=>b.vertical).filter(v=>v&&v!=='—'))].join(', ');
    const billed=am.bids.filter(b=>b.status==='Billed');
    const won=am.bids.filter(b=>b.status==='Won');
    const lost=am.bids.filter(b=>STATUS_LOST.includes(b.status));
    const ip=am.bids.filter(b=>STATUS_IP.includes(b.status));
    const mainLabel=isMobile?'GA':'MRC';
    const mainVal=isMobile?fmtGA(s.ga):fmt(am.bids.reduce((sum,b)=>sum+b.mrc,0));
    const row=document.createElement('div');
    row.className='manager-row'+(selAM===key?' selected':'');
    row.innerHTML=`
      <div class="rank-badge ${rankClass}">${i+1}</div>
      <div class="manager-name-col">
        <div class="manager-name">${am.name}</div>
        <div class="manager-tag" style="font-size:.62rem">${verticals||'—'}</div>
      </div>
      <div class="stat-col"><div class="stat-label">Opps</div><div class="stat-value">${s.total}</div></div>
      <div class="stat-col"><div class="stat-label">Billed</div><div class="stat-value" style="color:#16a34a">${billed.length}</div></div>
      <div class="stat-col"><div class="stat-label">Won</div><div class="stat-value" style="color:#16a34a">${won.length}</div></div>
      <div class="stat-col"><div class="stat-label">Lost</div><div class="stat-value" style="color:#dc2626">${lost.length}</div></div>
      <div class="stat-col"><div class="stat-label">TCV</div><div class="stat-value">${fmt(s.allTCV)}</div></div>
      <div class="stat-col"><div class="stat-label">${mainLabel}</div><div class="stat-value">${mainVal}</div></div>
      <div class="stat-col"><div class="stat-label">OTC</div><div class="stat-value">${fmt(am.bids.reduce((sum,b)=>sum+b.otc,0))}</div></div>
      <div class="stat-col"><div class="stat-label">Catelog MRC</div><div class="stat-value">${fmt(am.bids.reduce((sum,b)=>sum+b.pcv,0))}</div></div>
      <div class="progress-bar-col">
        <div class="progress-label">Billed Ratio: ${s.total?(billed.length/s.total*100).toFixed(1):0}%</div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.total?(billed.length/s.total*100).toFixed(1):0}%"></div></div>
      </div>
      <div class="progress-bar-col">
        <div class="progress-label">TCV Contribution: ${s.tcvPct}%</div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.tcvPct}%"></div></div>
      </div>`;
    row.onclick=function(){ selectAM(key); };
    list.appendChild(row);
  });
}function selectAM(key){
  if(selAM===key) selAM=null; else selAM=key;
  renderAMRows(selAD); updateTopStats(); renderCharts(); renderGrid();
  updateSelectionBadge();
}

