    var d=new Date(iso);
    if(isNaN(d)) return false;
    if(period==='YTD') return d.getFullYear()===now.getFullYear()&&d<=now;
    if(period==='Y') return d.getFullYear()===now.getFullYear();
    if(period==='Q') return d.getFullYear()===now.getFullYear()&&Math.ceil((d.getMonth()+1)/3)===Math.ceil((now.getMonth()+1)/3);
    if(period==='M') return d.getFullYear()===now.getFullYear()&&d.getMonth()===now.getMonth();
