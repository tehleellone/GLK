    const d=new Date(rd);
    if(gaPeriod==='W') return d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
    if(gaPeriod==='M') return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
    if(gaPeriod==='Q') return d.getFullYear()+'-Q'+Math.ceil((d.getMonth()+1)/3);
    return String(d.getFullYear());
  };
  const periods=gaPeriod==='W'?12:gaPeriod==='M'?12:gaPeriod==='Q'?8:5;
  const buckets=[];
  for(let i=periods-1;i>=0;i--){
    let label,bucket;
    if(gaPeriod==='W'){
      const d=new Date(now);d.setDate(d.getDate()-i*7);
      bucket=d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
      label='W'+getWeekOfYear(d);
    } else if(gaPeriod==='M'){
      const d=new Date(now.getFullYear(),now.getMonth()-i,1);
      bucket=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
      label=d.toLocaleDateString('en-US',{month:'short',year:'2-digit'});
    } else if(gaPeriod==='Q'){
      const totalQ=now.getFullYear()*4+Math.ceil((now.getMonth()+1)/3)-1-i;
      const yr=Math.floor(totalQ/4);const q=(totalQ%4)+1;
      bucket=yr+'-Q'+q;label='Q'+q+' '+String(yr).slice(2);
    } else {
      const yr=now.getFullYear()-i;bucket=String(yr);label=String(yr);
    }
    labels.push(label);buckets.push(bucket);
    vals.push(bids.filter(b=>{const rd=getRelevantDate(b);if(!rd)return false;return getBucket(rd)===bucket;}).reduce((s,b)=>s+b[metricKey],0));
  }
  const ctx=el('chartGA').getContext('2d');
  const gaGrad=ctx.createLinearGradient(0,0,0,260);
  gaGrad.addColorStop(0,c.p2a+'0.4)');gaGrad.addColorStop(1,c.p2a+'0.02)');
  CHARTS.ga=new Chart(el('chartGA'),{type:'line',
    data:{labels,datasets:[{label:metricLabel,data:vals,borderColor:c.p2,backgroundColor:gaGrad,fill:true,tension:.42,pointRadius:5,pointHoverRadius:8,pointBackgroundColor:c.p2,pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:2.5}]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{backgroundColor:'rgba(0,0,0,.75)',padding:12,cornerRadius:10,titleFont:{size:13,weight:'700'},bodyFont:{size:12}}
      },
      scales:{x:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{color:c.grid},border:{dash:[4,4]}},y:{ticks:{color:c.text},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true}}}});

  const wrap=el('gaControlsWrap');
  if(wrap){
    wrap.innerHTML=`
      <div style="display:flex;justify-content:flex-end;margin-top:.65rem;gap:.35rem;">
        ${['W','M','Q','Y'].map(p=>`<button type="button" onclick="gaPeriod='${p}';renderGA(getViewBids(),getChartColors())" style="padding:.25rem .7rem;border-radius:6px;font-size:.72rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:${gaPeriod===p?'var(--grad)':'var(--bg-secondary)'};color:${gaPeriod===p?'#fff':'var(--t3)'}">${p==='W'?'Week':p==='M'?'Month':p==='Q'?'Quarter':'Year'}</button>`).join('')}
      </div>`;
  }
}

