  const selSet={}; (selected||[]).forEach(v=>{selSet[String(v)]=true;});
  drop.innerHTML=values.map(function(val){
    const disp=labelFn?labelFn(val):val;
    const cid=glkRulePrefix(ruleId)+'_'+part+'_'+String(val).replace(/\W/g,'_');
    return '<div class="ms-option" onclick="event.stopPropagation()"><input type="checkbox" id="'+cid+'" value="'+val+'"'+(selSet[String(val)]?' checked':'')+' onchange="glkUpdateRuleMsText(\''+ruleId+'\',\''+part+'\',\''+label+'\');onDateFilterChange()"><label for="'+cid+'">'+disp+'</label></div>';
  }).join('');
  glkUpdateRuleMsText(ruleId,part,label);
}
function glkCollectDateMetas(items,field){
  const metas=[];
  (items||[]).forEach(function(b){ const meta=glkDateMeta(glkBidDateValue(b,field)); if(meta) metas.push(meta); });
  return metas;
}
function glkPopulateRulePeriodDropdowns(rule,items){
  const field=rule.dateField||'created';
  const metas=glkCollectDateMetas(items,field);
  const ySel=rule.years||[], qSel=rule.quarters||[], mSel=rule.months||[];
  const years=[],quarters=[],months=[],weeks=[];
  metas.forEach(function(m){ const ys=String(m.year); if(years.indexOf(ys)<0) years.push(ys); });
  years.sort((a,b)=>parseInt(b,10)-parseInt(a,10));
  metas.forEach(function(m){
    if(ySel.length&&ySel.indexOf(String(m.year))<0) return;
    const qs=String(m.quarter); if(quarters.indexOf(qs)<0) quarters.push(qs);
  });
  quarters.sort((a,b)=>parseInt(a,10)-parseInt(b,10));
  metas.forEach(function(m){
    if(ySel.length&&ySel.indexOf(String(m.year))<0) return;
    if(qSel.length&&qSel.indexOf(String(m.quarter))<0) return;
    const ms=String(m.monthIndex); if(months.indexOf(ms)<0) months.push(ms);
  });
  months.sort((a,b)=>parseInt(a,10)-parseInt(b,10));
  metas.forEach(function(m){
    if(ySel.length&&ySel.indexOf(String(m.year))<0) return;
    if(qSel.length&&qSel.indexOf(String(m.quarter))<0) return;
    if(mSel.length&&mSel.indexOf(String(m.monthIndex))<0) return;
    if(m.week!=null){ const ws=String(m.week); if(weeks.indexOf(ws)<0) weeks.push(ws); }
  });
  weeks.sort((a,b)=>parseInt(a,10)-parseInt(b,10));
  glkBuildRuleMs(rule.id,'year','Years',years,rule.years);
  glkBuildRuleMs(rule.id,'quarter','Quarters',quarters,rule.quarters,v=>'Q'+v);
  glkBuildRuleMs(rule.id,'month','Months',months,rule.months,v=>MONTH_NAMES[+v]||v);
  glkBuildRuleMs(rule.id,'week','Weeks',weeks,rule.weeks,v=>'W'+v);
}
