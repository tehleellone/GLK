function getRelevantDate(bid){
  const s=bid.status;
  const fc=bid.forecastCategory;
  if(s==='Won'||fc==='Closed Won') return bid.contractSigned||bid.billedDate||bid.expectedActivation;
  if(s==='Billed') return bid.billedDate||bid.contractSigned;
  if(STATUS_IP.includes(s)) return bid.expectedActivation||bid.proposedDate;
  if(STATUS_LOST.includes(s)||fc==='Closed Lost') return bid.lostDate||bid.proposedDate;
  return bid.proposedDate||bid.contractSigned||bid.expectedActivation||bid.created;
}
