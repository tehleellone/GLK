function glkGetRuleChecked(ruleId,part){
  const drop=el(glkRulePrefix(ruleId)+'_'+part);
  if(!drop) return [];
  return Array.from(drop.querySelectorAll('input:checked')).map(c=>c.value);
}
function glkUpdateRuleMsText(ruleId,part,label){
  const checked=glkGetRuleChecked(ruleId,part);
  const te=el(glkRulePrefix(ruleId)+'_'+part+'Text'); if(!te) return;
  if(!checked.length){ te.textContent='All '+label; return; }
  if(checked.length===1){
    if(part==='quarter') te.textContent='Q'+checked[0];
    else if(part==='month') te.textContent=MONTH_NAMES[+checked[0]]||checked[0];
    else if(part==='week') te.textContent='W'+checked[0];
    else te.textContent=checked[0];
    return;
  }
  te.textContent=checked.length+' selected';
}
function glkToggleRuleMs(ruleId,part){
  const drop=el(glkRulePrefix(ruleId)+'_'+part),trig=el(glkRulePrefix(ruleId)+'_'+part+'Trig');
  if(!drop||!trig) return;
  const isOpen=drop.classList.contains('open');
  document.querySelectorAll('.glk-date-rule .ms-dropdown.open').forEach(d=>{d.classList.remove('open');if(d.previousElementSibling)d.previousElementSibling.classList.remove('open');});
  if(!isOpen){
    const rect=trig.getBoundingClientRect();
    drop.style.top=(rect.bottom+4)+'px';drop.style.left=rect.left+'px';
    drop.style.width=Math.max(rect.width,180)+'px';
    drop.classList.add('open');trig.classList.add('open');
  }
}
