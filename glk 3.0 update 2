function glkBridgeConnectorPlugin(bars){
  return {id:'glkBridgeConnectors',afterDatasetsDraw:function(chart){
    var meta=chart.getDatasetMeta(0),ctx=chart.ctx;
    if(!meta||!meta.data) return;
    for(var i=1;i<meta.data.length;i++){
      var prev=bars[i-1],cur=bars[i];
      if(cur.type!=='step') continue;
      if(prev.type!=='won'&&prev.type!=='step') continue;
      var pBar=meta.data[i-1],cBar=meta.data[i];
      if(!pBar||!cBar) continue;
      var topPrev=Math.min(pBar.y,pBar.base);
      ctx.save();
      ctx.strokeStyle='rgba(100,116,139,.35)';
      ctx.lineWidth=1;
      ctx.setLineDash([4,3]);
      ctx.beginPath();
      ctx.moveTo(pBar.x,topPrev);
      ctx.lineTo(cBar.x,topPrev);
      ctx.stroke();
      ctx.restore();
    }
  }};
}
function glkBridgeBarLabelPlugin(bars){
