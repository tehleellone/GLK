      if(STATUS_WON.includes(b.status)){map[k].won++;map[k].wonTCV+=b.tcv;}
      map[k].mrc+=b.mrc;map[k].otc+=b.otc;map[k].pcv+=b.pcv;map[k].ga+=b.gaPoints;map[k].total++;
