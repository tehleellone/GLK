    this.gui.appendChild(this.list);
    this.gui.appendChild(this.actions);
    this.search.addEventListener('input',()=>this.renderList());
    this.renderList();
  }
  cellVal(row){
    const cd=this.colDef,p={data:row,colDef:cd,api:this.params.api,column:this.params.column};
    if(cd.filterValueGetter) return cd.filterValueGetter(p);
    if(cd.valueGetter) return cd.valueGetter(p);
    if(cd.field) return row[cd.field];
    return null;
  }
  cellStr(row){
    const v=this.cellVal(row);
    if(v==null||v==='') return '—';
    return String(v);
  }
  getValues(){
    const vals=[];
    this.params.api.forEachNode(function(n){
      if(!n.data) return;
      const s=this.cellStr(n.data);
      if(s&&s!=='—') vals.push(s);
    }.bind(this));
    return [...new Set(vals)].sort();
  }
  renderList(){
    const q=this.search.value.toLowerCase();
    const vals=this.getValues().filter(function(v){return v.toLowerCase().includes(q);});
    const self=this;
    this.list.innerHTML=vals.map(function(v){
      const esc=v.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');
      return '<label style="display:flex;align-items:center;gap:6px;padding:4px 0;cursor:pointer;font-size:12px;"><input type="checkbox" data-v="'+esc+'"'+(self.selected.has(v)?' checked':'')+'><span>'+esc+'</span></label>';
    }).join('')||(vals.length?'':'<div style="font-size:11px;color:var(--t3);padding:4px 0;">No values</div>');
    this.list.querySelectorAll('input[type=checkbox]').forEach(function(inp){
      inp.addEventListener('change',function(){
        const v=inp.getAttribute('data-v');
        if(inp.checked) self.selected.add(v); else self.selected.delete(v);
        self.params.filterChangedCallback();
      });
    });
  }
  getGui(){return this.gui;}
  isFilterActive(){return this.selected.size>0;}
  doesFilterPass(params){
    if(!this.isFilterActive()) return true;
    return this.selected.has(this.cellStr(params.data));
  }
  getModel(){return this.isFilterActive()?{values:[...this.selected]}:null;}
  setModel(model){
    this.selected=new Set(model&&model.values?model.values:[]);
    this.renderList();
  }
}
