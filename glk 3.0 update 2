<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GLK Enterprise Pipeline Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/ag-grid/32.0.2/ag-grid-community.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/ag-grid-community@32.0.2/styles/ag-grid.css">
<link rel="stylesheet" href="https://unpkg.com/ag-grid-community@32.0.2/styles/ag-theme-alpine.css">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

/* ═══════ TOKENS ═══════════════════════════════════════════════════════ */
/* MAGENTA LIGHT — default */
:root {
  --bg-body: linear-gradient(145deg, #f9f0ff, #fce7ff, #f5eeff);
  --bg-card: #ffffff;
  --bg-header: rgba(255,255,255,0.97);
  --bg-sidebar: linear-gradient(180deg,#fdf4ff,#f8ecff);
  --bg-content: #f9f3ff;
  --bg-input: rgba(168,85,247,0.06);
  --bg-secondary: rgba(168,85,247,0.05);
  --bg-hover: rgba(168,85,247,0.07);
  --border: rgba(168,85,247,0.2);
  --border-s: rgba(168,85,247,0.45);
  --t1: #1e1133;
  --t2: #4b3f6b;
  --t3: #8b7aad;
  --acc: #a855f7;
  --acc2: #c724b1;
  --glow: rgba(168,85,247,0.28);
  --grad: linear-gradient(135deg,#9248b9,#c724b1);
  --nab: rgba(168,85,247,0.1);
  --nab2: rgba(168,85,247,0.35);
  --sc: #a855f7;
  --cs: 0 1px 8px rgba(168,85,247,0.12);
  --ch: 0 6px 20px rgba(168,85,247,0.2);
  --chip: rgba(168,85,247,0.08);
}
/* MAGENTA DARK */
body[data-theme="dark"] {
  --bg-body: linear-gradient(145deg,#120820,#1e0d33,#160a28);
  --bg-card: #1f0d38;
  --bg-header: rgba(18,8,32,0.98);
  --bg-sidebar: linear-gradient(180deg,#230f3d,#1a0a2e);
  --bg-content: #160a28;
  --bg-input: rgba(168,85,247,0.12);
  --bg-secondary: rgba(168,85,247,0.08);
  --bg-hover: rgba(168,85,247,0.12);
  --border: rgba(168,85,247,0.2);
  --border-s: rgba(168,85,247,0.5);
  --t1: #f3e8ff;
  --t2: #c4b5fd;
  --t3: #8b5cf6;
  --acc: #c084fc;
  --acc2: #e879f9;
  --glow: rgba(192,132,252,0.35);
  --grad: linear-gradient(135deg,#9248b9,#c724b1);
  --nab: rgba(168,85,247,0.16);
  --nab2: rgba(168,85,247,0.45);
  --sc: #e879f9;
  --cs: 0 2px 16px rgba(0,0,0,0.5);
  --ch: 0 6px 24px rgba(168,85,247,0.25);
  --chip: rgba(168,85,247,0.15);
}
/* DURALUX LIGHT */
body[data-theme="duralux"] {
  --bg-body: linear-gradient(145deg,#f0f4ff,#e8edff,#f4f6ff);
  --bg-card: #ffffff;
  --bg-header: rgba(255,255,255,0.97);
  --bg-sidebar: linear-gradient(180deg,#f0f4ff,#e8edff);
  --bg-content: #f0f4ff;
  --bg-input: rgba(76,111,255,0.06);
  --bg-secondary: rgba(76,111,255,0.05);
  --bg-hover: rgba(76,111,255,0.07);
  --border: rgba(76,111,255,0.2);
  --border-s: rgba(76,111,255,0.45);
  --t1: #0f1a3e;
  --t2: #3d4f8a;
  --t3: #7a8fc4;
  --acc: #4c6fff;
  --acc2: #818cf8;
  --glow: rgba(76,111,255,0.28);
  --grad: linear-gradient(135deg,#4c6fff,#818cf8);
  --nab: rgba(76,111,255,0.1);
  --nab2: rgba(76,111,255,0.35);
  --sc: #4c6fff;
  --cs: 0 1px 8px rgba(76,111,255,0.1);
  --ch: 0 6px 20px rgba(76,111,255,0.18);
  --chip: rgba(76,111,255,0.08);
}
/* DURALUX DARK */
body[data-theme="duralux-dark"] {
  --bg-body: linear-gradient(145deg,#060c1f,#0c1535,#080e25);
  --bg-card: #0e1630;
  --bg-header: rgba(6,12,31,0.98);
  --bg-sidebar: linear-gradient(180deg,#101a38,#0c1430);
  --bg-content: #090f28;
  --bg-input: rgba(76,111,255,0.12);
  --bg-secondary: rgba(76,111,255,0.08);
  --bg-hover: rgba(76,111,255,0.12);
  --border: rgba(76,111,255,0.2);
  --border-s: rgba(76,111,255,0.5);
  --t1: #e2e8f0;
  --t2: #a5b4c8;
  --t3: #637899;
  --acc: #818cf8;
  --acc2: #a5b4fc;
  --glow: rgba(129,140,248,0.35);
  --grad: linear-gradient(135deg,#4c6fff,#818cf8);
  --nab: rgba(76,111,255,0.14);
  --nab2: rgba(76,111,255,0.45);
  --sc: #818cf8;
  --cs: 0 2px 16px rgba(0,0,0,0.55);
  --ch: 0 6px 24px rgba(76,111,255,0.2);
  --chip: rgba(76,111,255,0.15);
}

/* ═══════ RESET ════════════════════════════════════════════════════════ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
h1,h2,h3,h4,h5,h6{margin:0!important;padding:0!important;font-weight:inherit}
html{scroll-behavior:smooth}
body{
  font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  background:var(--bg-body);
  color:var(--t1);
  min-height:100vh;
  -webkit-font-smoothing:antialiased;
  transition:background .3s,color .3s;
  line-height:1.5;
}
select,input,textarea,button{font-family:inherit}

/* ═══════ PORTAL SHELL ══════════════════════════════════════════════════ */
.portal-shell{
  max-width:1800px;margin:0 auto;min-height:100vh;
  display:flex;flex-direction:column;background:var(--bg-body);
}

/* ═══════ HEADER ════════════════════════════════════════════════════════ */
.header{
  background:var(--bg-header);border-bottom:1px solid var(--border);
  backdrop-filter:blur(16px);padding:0 1.25rem;height:56px;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  position:sticky;top:0;z-index:200;flex-shrink:0;
}
.logo-section{display:flex;align-items:center;gap:.65rem;min-width:0}
.logo{
  width:36px;height:36px;border-radius:10px;background:var(--grad);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 14px var(--glow);flex-shrink:0;
}
.logo svg{width:20px;height:20px;stroke:#fff;fill:none;stroke-width:2}
.header-title{
  font-size:1.05rem;font-weight:800;white-space:nowrap;
  background:var(--grad);-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;
}
.header-center{display:flex;align-items:center;gap:.75rem;flex:1;justify-content:flex-start;padding-left:.75rem}
.header-actions{display:flex;align-items:center;gap:.5rem;flex-shrink:0}
.live-badge-pill{
  display:inline-flex;align-items:center;gap:.3rem;padding:.22rem .65rem;
  border-radius:20px;background:rgba(22,163,74,.12);border:1px solid rgba(22,163,74,.28);
  font-size:.73rem;font-weight:700;color:#16a34a;white-space:nowrap;
}
body[data-theme="dark"] .live-badge-pill,
body[data-theme="duralux-dark"] .live-badge-pill{
  background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.25);color:#22c55e;
}
.status-dot{
  width:6px;height:6px;border-radius:50%;background:#16a34a;
  animation:pulseDot 2s infinite;
}
body[data-theme="dark"] .status-dot,body[data-theme="duralux-dark"] .status-dot{background:#22c55e}
@keyframes pulseDot{0%,100%{box-shadow:0 0 0 0 rgba(22,163,74,.4)}50%{box-shadow:0 0 0 5px rgba(22,163,74,0)}}
.date-badge{font-size:.75rem;color:var(--t3);display:flex;align-items:center;gap:.3rem;white-space:nowrap}
.color-scheme-selector{
  padding:.3rem .65rem;background:var(--bg-input);border:1px solid var(--border);
  border-radius:18px;color:var(--t1);font-size:.75rem;cursor:pointer;transition:border-color .2s;
}
.color-scheme-selector:hover{border-color:var(--border-s)}
.theme-toggle{
  width:34px;height:34px;border-radius:50%;background:var(--bg-input);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t1);transition:all .2s;
}
.theme-toggle:hover{border-color:var(--border-s)}
.theme-toggle svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}

/* ═══════ SIDEBAR ═══════════════════════════════════════════════════════ */
.sidebar-toggle-btn{
  position:absolute;right:-14px;top:20px;z-index:300;width:28px;height:28px;border-radius:50%;
  background:var(--bg-card);border:1px solid var(--border);box-shadow:var(--cs);
  display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t1);transition:all .2s;
}
.sidebar-toggle-btn:hover{border-color:var(--border-s);background:var(--bg-hover)}
.sidebar-toggle-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}
.main-container{display:flex;flex:1;min-height:0;position:relative}
.sidebar{
  width:210px;min-width:210px;background:var(--bg-sidebar);border-right:1px solid var(--border);
  padding:1rem 0;overflow:visible;flex-shrink:0;transition:width .26s ease,min-width .26s ease,opacity .22s,padding .25s;
}
.sidebar.collapsed{width:52px;min-width:52px;padding:1rem 0;border-right:1px solid var(--border);overflow:hidden!important}
.sidebar.collapsed .nav-items{opacity:1;pointer-events:all;}
.sidebar.collapsed .nav-label{display:none;}
.sidebar.collapsed .nav-section-label{display:none;}
.sidebar.collapsed .nav-item{justify-content:center;padding:.55rem 0;}
.sidebar.collapsed .sidebar-toggle-btn{opacity:1!important;pointer-events:all!important;right:-14px;background:var(--bg-card);box-shadow:var(--cs)}
.nav-items{display:flex;flex-direction:column;gap:2px;padding:0 .65rem}
.nav-section-label{
  font-size:.67rem;text-transform:uppercase;letter-spacing:.1em;color:var(--t3);
  padding:.75rem .6rem .3rem;white-space:nowrap;overflow:hidden;
}
.nav-item{
  display:flex;align-items:center;gap:.65rem;padding:.55rem .7rem;border-radius:9px;
  cursor:pointer;color:var(--t2);border:1px solid transparent;transition:all .17s;
  white-space:nowrap;overflow:hidden;font-size:.84rem;font-weight:500;user-select:none;
}
.nav-item .nav-icon{display:flex;align-items:center;flex-shrink:0;width:17px;height:17px}
.nav-item .nav-icon svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:2}
.nav-item .nav-label{font-size:.84rem;font-weight:500}
.nav-item:hover{background:var(--bg-hover);color:var(--t1)}
.nav-item.active{background:var(--nab);border-color:var(--nab2);color:var(--t1);font-weight:600}

/* ═══════ CONTENT ═══════════════════════════════════════════════════════ */
.content{flex:1;overflow-y:auto;min-width:0;background:var(--bg-content);padding:1.1rem 1.25rem}
.dashboard-section{animation:fadeSection .25s ease;padding:.5rem 0}
@keyframes fadeSection{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.glk-spinner{width:52px;height:52px;border-radius:50%;border:4px solid rgba(255,255,255,.14);border-top-color:var(--acc,#c026d3);animation:glkSpin .8s linear infinite}
@keyframes glkSpin{to{transform:rotate(360deg)}}

/* ═══════ SECTION TITLE ══════════════════════════════════════════════════ */
.section-title{
  font-size:1rem;font-weight:800;margin:.85rem 0!important;
  display:flex;align-items:center;gap:.45rem;color:var(--acc);
}
.section-title svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:2}

/* ═══════ STAT CARDS ════════════════════════════════════════════════════ */
.top-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.85rem;margin-bottom:1rem}
.stat-card{
  background:var(--bg-card);border:1px solid var(--border);border-radius:12px;
  padding:1rem 1.1rem;box-shadow:var(--cs);position:relative;overflow:hidden;
  transition:transform .18s,box-shadow .18s;
}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad)}
.stat-card:hover{transform:translateY(-2px);box-shadow:var(--ch)}
.stat-label{font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;color:var(--t3);font-weight:700;margin-bottom:.35rem}
.stat-value{font-size:1.9rem;font-weight:900;line-height:1;color:var(--sc);margin-bottom:.25rem}
.stat-subtitle{font-size:.76rem;font-weight:600;color:var(--t2)}
.stat-breakdown{margin-top:.45rem;display:flex;flex-wrap:wrap;gap:.4rem}
.breakdown-item{display:inline-flex;align-items:center;gap:.2rem;font-size:.7rem}
.breakdown-label{color:var(--t3)}
.breakdown-value{font-weight:700;color:var(--t2)}

/* ═══════ FILTERS ════════════════════════════════════════════════════════ */
.filters-section{
  background:var(--bg-card);border:1px solid var(--border);border-radius:12px;
  padding:.9rem 1rem;margin-bottom:1rem;box-shadow:var(--cs);
}
.filters-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.65rem;margin-bottom:.65rem}
.filter-group{display:flex;flex-direction:column;gap:.25rem}
.filter-label{font-size:.68rem;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.05em}

/* Multi-select widget */
.ms-wrap{position:relative;z-index:auto}.ms-trigger{
  padding:.48rem .7rem;border-radius:8px;border:1px solid var(--border);
  background:var(--bg-input);color:var(--t1);font-size:.83rem;
  cursor:pointer;display:flex;align-items:center;justify-content:space-between;
  transition:border-color .18s,box-shadow .18s;user-select:none;
}
.ms-trigger:hover,.ms-trigger.open{border-color:var(--border-s);box-shadow:0 0 0 3px var(--glow)}
.ms-trigger svg{width:14px;height:14px;stroke:var(--t3);fill:none;stroke-width:2;transition:transform .2s;flex-shrink:0}
.ms-trigger.open svg{transform:rotate(180deg)}
.ms-dropdown{position:fixed;background:var(--bg-card);border:1px solid var(--border-s);border-radius:8px;max-height:230px;overflow-y:auto;z-index:99999;box-shadow:0 8px 32px rgba(0,0,0,.28);display:none;min-width:180px;}
.ms-dropdown.open{display:block}
.ms-option{
  padding:8px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;
  font-size:.83rem;transition:background .15s;
}
.ms-option:hover{background:var(--bg-hover)}
.ms-option input[type=checkbox]{width:14px;height:14px;cursor:pointer;accent-color:var(--acc)}
.ms-option label{cursor:pointer;flex:1;color:var(--t1)}
.filter-actions{display:flex;gap:.5rem;justify-content:flex-end}

/* ═══════ BUTTONS ════════════════════════════════════════════════════════ */
.export-btn{
  padding:.5rem 1rem;border-radius:8px;font-size:.82rem;font-weight:700;cursor:pointer;
  display:inline-flex;align-items:center;gap:.35rem;transition:all .2s;border:none;
  background:var(--grad);color:#fff;box-shadow:0 2px 10px var(--glow);white-space:nowrap;
}
.export-btn:hover{box-shadow:0 4px 16px var(--glow);transform:translateY(-1px)}
.export-btn svg{width:14px;height:14px;stroke:#fff;fill:none;stroke-width:2}
.reset-btn{
  padding:.5rem 1rem;border-radius:8px;font-size:.82rem;font-weight:600;cursor:pointer;
  display:inline-flex;align-items:center;gap:.35rem;transition:all .2s;
  background:var(--bg-input);color:var(--t1);border:1px solid var(--border);white-space:nowrap;
}
.reset-btn:hover{border-color:var(--border-s)}
.reset-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}

/* ═══════ HD / AD TILES (= LM TILES from SM) ════════════════════════════ */
.hd-section,.ad-section{margin-bottom:1rem}
.hd-grid,.ad-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.85rem}
.lm-tile .lm-progress-section{
  border-top: 1px solid var(--border);
  margin-top:.55rem;
  padding-top:.45rem;
}
.lm-tile{
  background:var(--bg-card);border:1px solid var(--border);border-radius:13px;
  padding:.9rem 1rem;cursor:pointer;transition:all .2s;box-shadow:var(--cs);
  position:relative;overflow:hidden;
}
.lm-tile::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad)}
.lm-tile:hover{transform:translateY(-2px);box-shadow:var(--ch);border-color:var(--border-s)}
.lm-tile.selected{border-color:var(--nab2);background:var(--nab)}
.lm-header{display:flex;flex-direction:column;gap:.15rem;margin-bottom:.6rem}
.lm-header h3{font-size:.88rem;font-weight:700;color:var(--t1);line-height:1.2}
.lm-meta{font-size:.68rem;color:var(--t3)}
.lm-stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.6rem}
.lm-stat-box{background:var(--bg-secondary);border-radius:7px;padding:.5rem .6rem;border:1px solid var(--border)}
.lm-stat-label{font-size:.65rem;text-transform:uppercase;color:var(--t3);margin-bottom:.12rem;font-weight:600}
.lm-stat-value{font-size:1.05rem;font-weight:800;color:var(--sc)}
.lm-revenue{border-radius:8px;padding:.55rem .7rem;background:var(--grad);color:#fff;margin-bottom:.55rem}
.lm-revenue-label{font-size:.65rem;text-transform:uppercase;opacity:.82;font-weight:700;margin-bottom:.15rem}
.lm-revenue-count{font-size:1.05rem;font-weight:900;margin-bottom:.3rem}
.lm-revenue-breakdown{display:flex;flex-direction:column;gap:.15rem}
.lm-revenue-item{display:flex;justify-content:space-between;align-items:center}
.lm-revenue-item-label{font-size:.66rem;opacity:.8}
.lm-revenue-item-value{font-size:.72rem;font-weight:700}
.lm-progress-section{margin-top:.45rem}
.lm-progress-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:.12rem}
.lm-progress-label,.lm-progress-value{font-size:.68rem;color:var(--t3)}
.lm-progress-value{font-weight:700}
.progress-bar{background:var(--bg-secondary);border-radius:20px;height:5px;overflow:hidden;margin-bottom:.4rem}
.progress-fill{height:100%;border-radius:20px;background:var(--grad);transition:width .5s ease}

/* ═══════ AM ROWS (= SM ROWS from SM) ═══════════════════════════════════ */
.am-section{margin-bottom:1rem}
.manager-list{display:flex;flex-direction:column;gap:.55rem}
.manager-row{
  background:var(--bg-card);border:1px solid var(--border);border-radius:11px;
  padding:.75rem 1rem;display:flex;align-items:center;flex-wrap:wrap;gap:.85rem;
  box-shadow:var(--cs);transition:all .18s;cursor:pointer;
}
.manager-row:hover{border-color:var(--border-s);transform:translateX(2px)}
.manager-row.selected{border-color:var(--nab2);background:var(--nab)}
.rank-badge{
  width:30px;height:30px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-weight:900;font-size:.76rem;color:#fff;flex-shrink:0;
}
.rank-badge.rank-1{background:var(--grad);box-shadow:0 0 10px var(--glow)}
.rank-badge.rank-2{background:linear-gradient(135deg,#94a3b8,#64748b)}
.rank-badge.rank-3{background:linear-gradient(135deg,#c2853b,#d97706)}
.rank-badge.rank-other{background:var(--bg-secondary);color:var(--t3);border:1px solid var(--border)}
.manager-name-col{flex:0 0 140px;min-width:0}
.manager-name{font-weight:700;font-size:.86rem;color:var(--t1);margin-bottom:.15rem}
.manager-tag{
  display:inline-block;padding:.15rem .5rem;border-radius:5px;font-size:.65rem;font-weight:700;
  background:var(--chip);color:var(--acc);border:1px solid var(--nab2);
}
.stat-col{display:flex;flex-direction:column;min-width:70px}
.stat-col .stat-label{font-size:.62rem;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.15rem}
.stat-col .stat-value{font-size:.82rem;font-weight:700;color:var(--t1)}
.progress-bar-col{flex:1;min-width:120px;max-width:200px}
.progress-label{font-size:.67rem;color:var(--t3);margin-bottom:.12rem}

/* ═══════ CHARTS ════════════════════════════════════════════════════════ */
.charts-section{display:grid;grid-template-columns:repeat(2,1fr);gap:.85rem;margin-bottom:1rem}
.charts-section.charts-3{grid-template-columns:repeat(3,1fr)}
.chart-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem;box-shadow:var(--cs)}
.chart-card.span2{grid-column:span 2}
.chart-title{font-size:.8rem;font-weight:700;color:var(--t2);margin-bottom:.65rem;display:flex;align-items:center;gap:.35rem}
.chart-title svg{width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2}
.chart-container{position:relative;height:260px}

/* ═══════ TABLE SECTION ═════════════════════════════════════════════════ */
.table-section{
  background:var(--bg-card);border:1px solid var(--border);border-radius:12px;
