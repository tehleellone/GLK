<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BCR — Barred Contact Registry</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/ag-grid/32.0.2/ag-grid-community.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/ag-grid-community@32.0.2/styles/ag-grid.css">
<link rel="stylesheet" href="https://unpkg.com/ag-grid-community@32.0.2/styles/ag-theme-alpine.css">
<style id="bcr-styles">
h1,h2,h3,h4,h5,h6{margin:0!important;padding:0!important;font-weight:inherit}
a,a:hover,a:focus,a:active,label,label:hover,span:hover,div:hover,p:hover,.form-label,.form-label:hover,.review-key,.review-val,.mt-label,.stat-label{text-decoration:none!important;border-bottom:none!important;box-shadow:none!important;background-image:none!important}
#bcrApp{position:relative;width:100%;isolation:isolate}
#landingPage{display:none;width:100%}
#landingPage.bcr-show{display:flex!important;flex-direction:row!important;min-height:100vh;width:100%}
#dashboardContent{display:none!important;width:100%}
#dashboardContent.bcr-show{display:flex!important;flex-direction:column!important;width:100%!important;min-height:100vh!important;background:var(--bg-body)!important;margin:0!important;padding:0!important}
#dashboardContent.bcr-show .main-container{flex:1;min-height:0;overflow:hidden}
#dashboardContent.bcr-show #bcrMainPanel{overflow-y:auto;-webkit-overflow-scrolling:touch}
.landing-page{min-height:100vh;display:flex!important;flex-direction:row!important;background:var(--bg-body);width:100%}
.landing-left,.landing-right{flex:1;display:flex;align-items:center;justify-content:center;padding:2rem}
.portal-shell{max-width:1800px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column;background:var(--bg-body);width:100%}
.header{position:relative;top:auto;flex-shrink:0}


:root{--bg-body:linear-gradient(145deg,#f0f7ff,#e6f0ff,#eef4ff);--bg-card:#fff;--bg-header:rgba(255,255,255,.97);--bg-sidebar:linear-gradient(180deg,#f0f7ff,#e8f0ff);--bg-content:#f0f5ff;--bg-input:rgba(37,99,235,.06);--bg-secondary:rgba(37,99,235,.05);--bg-hover:rgba(37,99,235,.07);--border:rgba(37,99,235,.18);--border-s:rgba(37,99,235,.42);--t1:#0f1e3e;--t2:#2d4070;--t3:#7a8fb8;--acc:#2563eb;--acc2:#0ea5e9;--glow:rgba(37,99,235,.26);--grad:linear-gradient(135deg,#1d4ed8,#0ea5e9);--nab:rgba(37,99,235,.09);--nab2:rgba(37,99,235,.32);--sc:#2563eb;--cs:0 1px 8px rgba(37,99,235,.1);--ch:0 6px 20px rgba(37,99,235,.18);--chip:rgba(37,99,235,.08);--green:#16a34a;--amber:#d97706;--red:#dc2626}
body[data-theme="dark"]{--bg-body:linear-gradient(145deg,#070e1f,#0e1835,#09112a);--bg-card:#0d1630;--bg-header:rgba(7,14,31,.98);--bg-sidebar:linear-gradient(180deg,#10193a,#0b1328);--bg-content:#090f25;--bg-input:rgba(37,99,235,.14);--bg-secondary:rgba(37,99,235,.09);--bg-hover:rgba(37,99,235,.13);--border:rgba(37,99,235,.2);--border-s:rgba(37,99,235,.48);--t1:#e2eaff;--t2:#a0b4d8;--t3:#5a7099;--acc:#60a5fa;--acc2:#38bdf8;--glow:rgba(96,165,250,.32);--grad:linear-gradient(135deg,#2563eb,#0ea5e9);--nab:rgba(37,99,235,.16);--nab2:rgba(37,99,235,.44);--sc:#60a5fa;--cs:0 2px 16px rgba(0,0,0,.5);--ch:0 6px 24px rgba(37,99,235,.22);--chip:rgba(37,99,235,.15)}
body[data-theme="magenta"]{--bg-body:linear-gradient(145deg,#f9f0ff,#fce7ff,#f5eeff);--bg-card:#fff;--bg-header:rgba(255,255,255,.97);--bg-sidebar:linear-gradient(180deg,#fdf4ff,#f8ecff);--bg-content:#f9f3ff;--bg-input:rgba(168,85,247,.06);--bg-secondary:rgba(168,85,247,.05);--bg-hover:rgba(168,85,247,.07);--border:rgba(168,85,247,.2);--border-s:rgba(168,85,247,.45);--t1:#1e1133;--t2:#4b3f6b;--t3:#8b7aad;--acc:#a855f7;--acc2:#c724b1;--glow:rgba(168,85,247,.28);--grad:linear-gradient(135deg,#9248b9,#c724b1);--nab:rgba(168,85,247,.1);--nab2:rgba(168,85,247,.35);--sc:#a855f7;--cs:0 1px 8px rgba(168,85,247,.12);--ch:0 6px 20px rgba(168,85,247,.2);--chip:rgba(168,85,247,.08)}
body[data-theme="magenta-dark"]{--bg-body:linear-gradient(145deg,#120820,#1e0d33,#160a28);--bg-card:#1f0d38;--bg-header:rgba(18,8,32,.98);--bg-sidebar:linear-gradient(180deg,#230f3d,#1a0a2e);--bg-content:#160a28;--bg-input:rgba(168,85,247,.12);--bg-secondary:rgba(168,85,247,.08);--bg-hover:rgba(168,85,247,.12);--border:rgba(168,85,247,.2);--border-s:rgba(168,85,247,.5);--t1:#f3e8ff;--t2:#c4b5fd;--t3:#8b5cf6;--acc:#c084fc;--acc2:#e879f9;--glow:rgba(192,132,252,.35);--grad:linear-gradient(135deg,#9248b9,#c724b1);--nab:rgba(168,85,247,.16);--nab2:rgba(168,85,247,.45);--sc:#e879f9;--cs:0 2px 16px rgba(0,0,0,.5);--ch:0 6px 24px rgba(168,85,247,.25);--chip:rgba(168,85,247,.15)}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;background:var(--bg-body);color:var(--t1);min-height:100vh;line-height:1.5;transition:background .3s,color .3s;-webkit-font-smoothing:antialiased;margin:0!important;padding:0!important}
select,input,textarea,button{font-family:inherit}
.portal-shell{max-width:1800px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column;background:var(--bg-body);width:100%}
.header{background:var(--bg-header);border-bottom:1px solid var(--border);backdrop-filter:blur(16px);padding:0 1.25rem;height:56px;display:flex;align-items:center;justify-content:space-between;gap:1rem;position:relative;top:auto;z-index:200;flex-shrink:0}
.logo-section{display:flex;align-items:center;gap:.65rem}
.logo{width:36px;height:36px;border-radius:10px;background:var(--grad);display:flex;align-items:center;justify-content:center;box-shadow:0 0 14px var(--glow)}
.logo svg{width:20px;height:20px;stroke:#fff;fill:none;stroke-width:2}
.header-title{font-size:1.05rem;font-weight:800;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;white-space:nowrap}
.header-center{display:flex;align-items:center;gap:.75rem;flex:1;padding-left:.75rem}
.header-actions{display:flex;align-items:center;gap:.5rem}
.live-badge-pill{display:inline-flex;align-items:center;gap:.3rem;padding:.22rem .65rem;border-radius:20px;background:rgba(22,163,74,.12);border:1px solid rgba(22,163,74,.28);font-size:.73rem;font-weight:700;color:#16a34a}
.status-dot{width:6px;height:6px;border-radius:50%;background:#16a34a;animation:pulseDot 2s infinite}
@keyframes pulseDot{0%,100%{box-shadow:0 0 0 0 rgba(22,163,74,.4)}50%{box-shadow:0 0 0 5px rgba(22,163,74,0)}}
.date-badge{font-size:.75rem;color:var(--t3);white-space:nowrap}
.color-scheme-selector,.reset-btn{padding:.3rem .65rem;background:var(--bg-input);border:1px solid var(--border);border-radius:18px;color:var(--t1);font-size:.75rem;cursor:pointer;transition:border-color .2s}
.color-scheme-selector:hover,.reset-btn:hover{border-color:var(--border-s)}
.theme-toggle{width:34px;height:34px;border-radius:50%;background:var(--bg-input);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t1)}
.theme-toggle svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}
.script-toggle-btn{padding:.35rem .8rem;border-radius:18px;background:var(--nab);border:1px solid var(--nab2);color:var(--acc);font-size:.73rem;font-weight:700;cursor:pointer;white-space:nowrap}
.script-toggle-btn:hover{background:var(--nab2);color:#fff}
.main-container{display:flex;flex:1;min-height:0;position:relative}
.sidebar{width:210px;min-width:210px;background:var(--bg-sidebar);border-right:1px solid var(--border);padding:1rem 0;position:relative;flex-shrink:0;transition:width .26s ease,min-width .26s ease,padding .25s;overflow:visible}
.sidebar.collapsed{width:0;min-width:0;padding:0;border:none}
.sidebar.collapsed .nav-items{opacity:0;pointer-events:none}
.sidebar-toggle-btn{position:absolute;right:-14px;top:18px;z-index:300;width:28px;height:28px;border-radius:50%;background:var(--bg-card);border:1px solid var(--border);box-shadow:var(--cs);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t1);transition:right .26s ease,transform .26s ease}
.sidebar-toggle-btn:hover{border-color:var(--border-s);background:var(--bg-hover)}
.sidebar-toggle-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;transition:transform .26s}
.sidebar.collapsed .sidebar-toggle-btn{right:-28px}
.sidebar.collapsed .sidebar-toggle-btn svg{transform:rotate(180deg)}
.nav-items{display:flex;flex-direction:column;gap:2px;padding:0 .65rem;transition:opacity .2s;white-space:nowrap}
.nav-section-label{font-size:.67rem;text-transform:uppercase;letter-spacing:.1em;color:var(--t3);padding:.75rem .6rem .3rem}
.nav-item{display:flex;align-items:center;gap:.65rem;padding:.6rem .7rem;border-radius:9px;cursor:pointer;color:var(--t2);border:1px solid transparent;font-size:.86rem;font-weight:500;transition:all .17s}
.nav-item .nav-icon svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:2;display:block}
.nav-item.active{background:var(--nab);border-color:var(--nab2);color:var(--t1);font-weight:600}
.nav-item:hover{background:var(--bg-hover);color:var(--t1)}
.content{flex:1;overflow-y:auto;min-width:0;background:var(--bg-content);padding:1.1rem 1.25rem}
.dashboard-section{animation:fadeSection .25s ease}
@keyframes fadeSection{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.section-title{font-size:1.05rem;font-weight:800;margin:.25rem 0 .1rem;display:flex;align-items:center;gap:.45rem;color:var(--t1)}
.dash-head{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:1rem}
.dash-sub{font-size:.75rem;color:var(--t3)}
.top-stats{display:grid;gap:.85rem;margin-bottom:1rem}
.stat-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:.9rem 1rem;box-shadow:var(--cs);position:relative;overflow:hidden;transition:transform .18s,box-shadow .18s}
.stat-card::before{display:none}
.stat-card.clickable{cursor:pointer}
.stat-card.clickable:hover{transform:translateY(-2px);box-shadow:var(--ch)}
.stat-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.05em;color:var(--t3);font-weight:700;margin-bottom:.3rem;display:flex;align-items:center}
.stat-value{font-size:1.7rem;font-weight:900;line-height:1;color:var(--sc)}
.stat-subtitle{font-size:.72rem;color:var(--t2);font-weight:600;margin-top:.25rem}
.insight-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:1rem}
.insight-card{flex:1;min-width:200px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:12px 14px;box-shadow:var(--cs)}
.insight-title{font-size:13px;font-weight:800;color:var(--t1);line-height:1.2}
.insight-sub{font-size:11px;color:var(--t3);margin-top:2px}
.insight-ico{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px}
.panel{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem;margin-bottom:1rem;box-shadow:var(--cs)}
.panel-head{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;margin-bottom:.75rem}
.panel-title{font-size:.9rem;font-weight:800;color:var(--t1);display:flex;align-items:center;gap:.4rem}
.panel-grid{display:grid;gap:.75rem}
.mini-tile{background:var(--bg-card);border:2px solid var(--border);border-radius:12px;padding:.85rem 1rem;box-shadow:var(--cs);cursor:pointer;transition:transform .15s}
.mini-tile:hover{transform:translateY(-2px)}
.mini-tile .mt-label{font-size:.66rem;font-weight:700;text-transform:uppercase;color:var(--t3);margin-bottom:.3rem;display:flex;align-items:center;gap:.3rem}
.mini-tile .mt-val{font-size:1.6rem;font-weight:900;line-height:1}
.mini-tile .mt-sub{font-size:.72rem;font-weight:700;margin-top:.25rem}
.filter-wrap{display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;padding:12px 16px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;box-shadow:var(--cs);margin-bottom:1rem}
.fw-group{flex:1;min-width:135px}
.fw-label{font-size:.62rem;font-weight:700;text-transform:uppercase;color:var(--t3);letter-spacing:.05em;margin-bottom:4px}
.dd-trigger{display:flex;align-items:center;justify-content:space-between;padding:7px 10px;border:1px solid var(--border);border-radius:8px;background:var(--bg-input);cursor:pointer;font-size:12px;color:var(--t1);white-space:nowrap;transition:border-color .18s}
.dd-trigger:hover{border-color:var(--border-s)}
.dd-trigger.has-sel{border-color:var(--acc);background:var(--nab);color:var(--acc);font-weight:700}
.dd-menu{display:none;position:absolute;top:calc(100% + 4px);left:0;min-width:190px;z-index:9999;background:var(--bg-card);border:1px solid var(--border-s);border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,.2);max-height:250px;overflow-y:auto}
.dd-menu.open{display:block}
.dd-opt{padding:6px 12px}
.dd-opt label{display:flex;align-items:center;gap:8px;font-size:12px;cursor:pointer;color:var(--t1)}
.dd-opt input{accent-color:var(--acc)}
.dd-opt.all{border-bottom:1px solid var(--border);font-weight:700}
.chart-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem;box-shadow:var(--cs);margin-bottom:1rem}
.trend-chart-card{background:linear-gradient(145deg,var(--bg-card),rgba(37,99,235,0.05));border:1px solid var(--border);border-radius:16px;padding:1.25rem 1.5rem;box-shadow:var(--ch);margin-bottom:1.25rem}
.trend-chart-head{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:1rem}
.trend-chart-title{font-size:1rem;font-weight:800;color:var(--t1);display:flex;align-items:center;gap:.5rem}
.trend-chart-sub{font-size:.75rem;color:var(--t3);margin-top:2px}
.trend-chart-wrap{position:relative;height:340px}
.chart-title{font-size:.82rem;font-weight:700;color:var(--t2);margin-bottom:.65rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.chart-grid{display:grid;grid-template-columns:1fr 1fr 2fr;gap:1rem;margin-bottom:1rem}
.mini-toggle{padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;border:1px solid var(--border);background:var(--bg-secondary);color:var(--t3)}
.mini-toggle.active{border-color:transparent;background:var(--grad);color:#fff}
.table-section{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem;margin-bottom:1rem;box-shadow:var(--cs)}
.table-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.65rem;margin-bottom:.85rem}
.table-title{font-size:.9rem;font-weight:800;color:var(--t1);display:flex;align-items:center;gap:.4rem}
.table-actions{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
.search-box{padding:.45rem .75rem;border-radius:8px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.82rem;min-width:200px}
.search-box:focus{outline:none;border-color:var(--border-s)}
.export-btn,.btn-primary,.btn-secondary{padding:.5rem 1rem;border-radius:8px;font-size:.82rem;font-weight:700;cursor:pointer;border:none;display:inline-flex;align-items:center;gap:.4rem;transition:all .2s}
.export-btn,.btn-primary{background:var(--grad);color:#fff;box-shadow:0 2px 10px var(--glow)}
.export-btn:hover,.btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 16px var(--glow)}
.export-btn.ghost{background:var(--bg-input);color:var(--t1);border:1px solid var(--border);box-shadow:none}
.btn-secondary{background:var(--bg-input);color:var(--t1);border:1px solid var(--border)}
.btn-secondary:hover{border-color:var(--border-s)}
.lead-table-wrap{max-height:420px;overflow:auto;border:1px solid var(--border);border-radius:10px}
.lead-table{width:100%;border-collapse:collapse}
.lead-table th{padding:8px 10px;text-align:left;font-size:10px;text-transform:uppercase;color:var(--t3);font-weight:700;position:sticky;top:0;background:var(--bg-secondary)}
.lead-table td{padding:8px 10px;font-size:12px;border-bottom:1px solid var(--border);color:var(--t1)}
.lead-table tr{cursor:pointer}
.lead-table tr:hover td{background:var(--bg-hover)}
.avatar-sm{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:12px;color:#fff;flex-shrink:0}
.ag-theme-alpine{--ag-background-color:var(--bg-card);--ag-foreground-color:var(--t1);--ag-border-color:var(--border);--ag-header-background-color:var(--bg-secondary);--ag-odd-row-background-color:var(--bg-secondary);--ag-row-hover-color:var(--bg-hover);--ag-font-family:'Segoe UI',system-ui,sans-serif}
.ag-theme-alpine .ag-root-wrapper{background:var(--bg-card)!important;border-color:var(--border)!important;border-radius:10px!important}
.ag-theme-alpine .ag-header,.ag-theme-alpine .ag-header-cell{background:var(--bg-secondary)!important;color:var(--t1)!important;font-weight:700!important;font-size:.71rem!important;text-transform:uppercase!important}
.ag-theme-alpine .ag-header-cell-text{color:var(--t1)!important}
.ag-theme-alpine .ag-row{background:var(--bg-card)!important;color:var(--t1)!important;border-bottom-color:var(--border)!important}
.ag-theme-alpine .ag-row-odd{background:var(--bg-secondary)!important}
.ag-theme-alpine .ag-row-hover{background:var(--bg-hover)!important}
.ag-theme-alpine .ag-cell{color:var(--t1)!important}
.ag-theme-alpine .ag-paging-panel,.ag-theme-alpine .ag-menu,.ag-theme-alpine .ag-filter{background:var(--bg-card)!important;color:var(--t1)!important;border-color:var(--border)!important}
.ag-theme-alpine input.ag-input-field-input{background:var(--bg-input)!important;color:var(--t1)!important;border-color:var(--border)!important}
.bcr-set-filter{padding:.5rem;min-width:210px;max-width:270px}
.bcr-set-search{width:100%;box-sizing:border-box;margin-bottom:.45rem;padding:.4rem .5rem;border:1px solid var(--border);border-radius:8px;font-size:.75rem;background:var(--bg-card);color:var(--t1)}
.bcr-set-list{max-height:190px;overflow-y:auto;display:flex;flex-direction:column;gap:.2rem}
.bcr-set-option{display:flex;align-items:center;gap:.4rem;font-size:.76rem;cursor:pointer;padding:.15rem 0;color:var(--t1)}
.bcr-set-option input{accent-color:var(--acc)}
.bcr-set-actions{display:flex;gap:.35rem;margin-top:.45rem}
.bcr-set-actions button{flex:1;padding:.3rem .4rem;font-size:.68rem;font-weight:700;border:1px solid var(--border);border-radius:6px;background:var(--nab);color:var(--acc);cursor:pointer}
.status-badge{display:inline-block;padding:.14rem .5rem;border-radius:20px;font-size:.66rem;font-weight:700}
.badge-yes{background:rgba(220,38,38,.12);color:var(--red)}
.badge-no{background:rgba(22,163,74,.12);color:var(--green)}
.badge-dup{background:rgba(217,119,6,.14);color:var(--amber)}

.landing-left,.landing-right{flex:1;display:flex;align-items:center;justify-content:center;padding:2rem}
.landing-container{max-width:420px;width:100%}
.landing-card{background:var(--bg-card);border:1px solid var(--border);border-radius:16px;padding:1.4rem;box-shadow:var(--cs)}
.logo-icon{width:60px;height:60px;border-radius:15px;background:var(--grad);display:flex;align-items:center;justify-content:center;box-shadow:0 0 24px var(--glow)}
.logo-icon svg{width:32px;height:32px;stroke:#fff;fill:none;stroke-width:2}
.landing-brand-title{font-size:1.9rem;font-weight:900}
.landing-brand-title span{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.landing-brand-subtitle,.landing-subtitle{font-size:.86rem;color:var(--t3)}
.landing-title{font-size:1.4rem;font-weight:800}
.landing-header{text-align:center;margin-bottom:1.2rem}
.landing-logo{display:flex;justify-content:center;margin-bottom:.75rem}
.welcome-badge{display:inline-flex;align-items:center;gap:.35rem;padding:.25rem .7rem;border-radius:20px;background:var(--nab);border:1px solid var(--nab2);font-size:.75rem;font-weight:600;color:var(--acc);margin-bottom:.75rem}
.badge-pulse{width:6px;height:6px;border-radius:50%;background:var(--acc);animation:pulseDot 2s infinite}
