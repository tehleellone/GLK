/* ── record detail drawer + history ──────────────────────── */
function openDetail(r){
  if(!r) return;
  var html='<button type="button" class="detail-close" id="detailCloseBtn">Close</button>';
  html+='<h3>Record Detail — '+esc(r.Reference_ID)+'</h3><div class="review-grid">';
  var order=getExportKeys();
  order.forEach(function(k){ html+='<div class="review-item"><div class="review-key">'+k+'</div><div class="review-val">'+esc(pretty(r[k])||'—')+'</div></div>'; });
  html+='</div>';
  if(isAdmin()){
    html+='<div style="margin-top:1rem"><div class="form-label">Internal_Notes (admin)</div><textarea class="form-textarea" id="detailNotes">'+esc(r.Internal_Notes||'')+'</textarea><button type="button" class="btn-primary" style="margin-top:.5rem" id="saveNotesBtn">Save Notes</button></div>';
  }
  html+='<div class="history-block"><div class="form-section-title">Contact History</div>';
  html+='<div class="history-item">Created '+esc(new Date(r.Contact_Time).toLocaleString('en-GB'))+' by '+esc(r.Agent_Name)+'</div>';
  if(r.Previous_Entry_ID){
    var prev=BCR.all.find(function(x){return x.Reference_ID===r.Previous_Entry_ID;});
    if(prev) html+='<div class="history-item">↩ Previous: '+esc(prev.Reference_ID)+' · '+esc(prev.Contact_Date)+' · '+esc(pretty(prev.Complaint_Summary))+'</div>';
  }
  var sameNum=BCR.all.filter(function(x){return x.MSISDN===r.MSISDN && x.Reference_ID!==r.Reference_ID;}).sort(function(a,b){return String(b.Contact_Date).localeCompare(String(a.Contact_Date));});
  if(sameNum.length){
    html+='<div style="font-size:.72rem;color:var(--t3);margin:.5rem 0 .3rem;text-transform:uppercase;font-weight:700">Other contacts on '+esc(r.MSISDN)+' ('+sameNum.length+')</div>';
    sameNum.slice(0,10).forEach(function(x){ html+='<div class="history-item">'+esc(x.Reference_ID)+' · '+esc(x.Contact_Date)+' · '+esc(pretty(x.Complaint_Summary))+' · '+esc(x.Agent_Name)+'</div>'; });
  }
  html+='</div>';
  $('detailDrawerInner').innerHTML=html;
  $('detailDrawer').classList.add('open');
  $('detailCloseBtn').onclick=closeDetail;
  if(isAdmin()){
    $('saveNotesBtn').onclick=function(){
      var idx=BCR.all.findIndex(function(x){return x.Reference_ID===r.Reference_ID;});
      if(idx>=0){ BCR.all[idx].Internal_Notes=$('detailNotes').value; saveRecords(); toast('Internal_Notes saved','success'); refreshDashboard(); }
    };
  }
}
function closeDetail(){ $('detailDrawer').classList.remove('open'); }
$('detailDrawer').onclick=function(e){ if(e.target.id==='detailDrawer') closeDetail(); };

