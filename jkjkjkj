function renderGrid(){
  var el=$('bcrGrid'); if(!el||typeof agGrid==='undefined') return;
  var dupR=function(p){ return p.value==='Yes'?'<span class="status-badge badge-dup">Yes</span>':'<span class="status-badge badge-no">No</span>'; };
  var wide={Complaint_Summary:1,Complaint_Details:1,Action_Taken:1,Internal_Notes:1,Calling_Number_Chat_Social_Email:1};
