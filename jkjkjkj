function renderInsights(){
  var el=$('insightRow'); if(!el) return;
  var t=BCR.filtered; if(!t.length){ el.innerHTML=''; return; }
  var s=getStats(t); var cards=[];
  // top complaint
  var byComp={}; t.forEach(function(r){ if(r.Complaint_Summary) byComp[r.Complaint_Summary]=(byComp[r.Complaint_Summary]||0)+1; });
  var topComp=Object.keys(byComp).sort(function(a,b){return byComp[b]-byComp[a];})[0];
  if(topComp) cards.push({ico:'clipboard-list',color:'#2563eb',title:pretty(topComp),sub:byComp[topComp]+' contacts — most common complaint'});
  // busiest agent
  var byAg={}; t.forEach(function(r){
    var n=r.Agent_Name;
    if(!n||/^agent$/i.test(String(n).trim())) return;
    byAg[n]=(byAg[n]||0)+1;
  });
  var topAg=Object.keys(byAg).sort(function(a,b){return byAg[b]-byAg[a];})[0];
  if(topAg) cards.push({ico:'user',color:'#d97706',title:topAg,sub:byAg[topAg]+' contacts logged'});
  if(s.repeatMsisdn>0) cards.push({ico:'repeat',color:'#8b5cf6',title:s.repeatMsisdn+' repeat contacts',sub:s.dup+' flagged as duplicate (7-day)'});
  cards.push({ico:'users',color:'#16a34a',title:s.emarati+' Emarati / '+s.nonEmarati+' Non-Emarati',sub:'Customer type split'});
  el.innerHTML = cards.slice(0,4).map(function(c){
    return '<div class="insight-card" style="border-left:3px solid '+c.color+'"><div style="display:flex;align-items:center;gap:8px"><div class="insight-ico" style="background:'+c.color+'22;color:'+c.color+'">'+bcrIcon(c.ico,16)+'</div><div style="min-width:0"><div class="insight-title">'+esc(c.title)+'</div><div class="insight-sub">'+esc(c.sub)+'</div></div></div></div>';
  }).join('');
  bcrIcons();
}

