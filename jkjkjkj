    return /^yes|true|1$/i.test(String(val).trim());
  }
  if(t==='Number'||t==='Counter'||t==='Integer'){
    var n=parseFloat(val);
    return isNaN(n)?String(val):n;
  }
  if(t==='DateTime'){
    try{ var d=new Date(val); if(!isNaN(d)) return d.toISOString(); }catch(ex){}
    return String(val);
  }
  return String(val);
}
