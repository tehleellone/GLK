function collectForm(){
  var d={};
  FORM_FIELDS.forEach(function(f){
    var el=$('fld_'+f.key);
    if(!el) return;
    var v=el.value.trim();
    if(EID_FIELD_KEYS.indexOf(f.key)>=0){
      var digits=eidDigits(v);
      v=digits.length===15?formatEmiratesIdDigits(digits):v;
    }
    d[f.key]=v;
  });
  return d;
}
function validateForm(d){
  var ok=true, firstBad=null, msg='';
  FORM_FIELDS.forEach(function(f){ var el=$('fld_'+f.key); if(el) el.classList.remove('invalid'); });
  for(var i=0;i<FORM_FIELDS.length;i++){
    var f=FORM_FIELDS[i];
    if(f.req && !d[f.key]){ firstBad=markInvalid(f.key)||firstBad; ok=false; if(!msg) msg='Please fill all required fields'; }
  }
  if(d.Email_Address && !isValidEmail(d.Email_Address)){ firstBad=markInvalid('Email_Address')||firstBad; ok=false; msg='Enter a valid email address'; }
  if(d.MSISDN && !isValidMsisdn(d.MSISDN)){ firstBad=markInvalid('MSISDN')||firstBad; ok=false; msg='MSISDN must be digits only (e.g. 05xxxxxxxx)'; }
  NUMERIC_FIELD_KEYS.forEach(function(k){
    if(d[k] && !isDigitsOnly(d[k])){ firstBad=markInvalid(k)||firstBad; ok=false; if(!msg) msg=pretty(k)+' must contain digits only'; }
  });
  EID_FIELD_KEYS.forEach(function(k){
    if(!d[k]) return;
    var err=emiratesIdError(d[k]);
    if(err){
      firstBad=markInvalid(k)||firstBad; ok=false;
      if(!msg){
        if(err.indexOf('digits:')===0) msg=pretty(k)+': enter all 15 digits ('+err.split(':')[1]+'/15 — dashes are added automatically)';
        else if(err==='prefix') msg=pretty(k)+' must start with 784';
        else msg=pretty(k)+' must be 784-YYYY-NNNNNNN-C';
      }
    } else {
      d[k]=normalizeEmiratesId(d[k]);
    }
  });
  if(d.Alternative_Contact && d.Alternative_Contact.trim()){
    var alt=d.Alternative_Contact.trim();
    if(!isValidEmail(alt) && !isValidMsisdn(alt) && !/^[\d\+\s\-]{7,15}$/.test(alt)){
      firstBad=markInvalid('Alternative_Contact')||firstBad; ok=false; msg='Alternative_Contact must be a valid phone or email';
    }
  }
  if(d.Contact_Date && d.Contact_Date>todayStr()){ firstBad=markInvalid('Contact_Date')||firstBad; ok=false; msg='Contact_Date cannot be in the future'; }
  if(!ok){ if(firstBad) firstBad.focus(); toast(msg||'Please fix the highlighted fields','error'); }
  return ok;
}
function populateForm(d){
  FORM_FIELDS.forEach(function(f){
    var el=$('fld_'+f.key);
    if(!el) return;
    var v=d[f.key]!=null?d[f.key]:(f.type==='yn'?'No':'');
    if(EID_FIELD_KEYS.indexOf(f.key)>=0&&v) v=formatEmiratesIdDigits(String(v).replace(/\D/g,'').slice(0,15));
    el.value=v;
  });
