    columnDefs:cols, rowData:BCR.filtered,
    defaultColDef:{sortable:true,resizable:true,minWidth:80,filter:true,floatingFilter:false},
    pagination:true,paginationPageSize:25,paginationPageSizeSelector:[25,50,100],
