function bcrFixAgentNames(apply){
  var dryRun=apply!==true;
  console.log(dryRun?'=== DRY RUN (preview only) ===':'=== APPLYING FIXES ===');
  loadSpUserNameMap(function(errA,nameByEmail){
    if(errA) console.warn('Partial user list load:',errA.message);
    nameByEmail=nameByEmail||{};
    console.log('SharePoint display names loaded:',Object.keys(nameByEmail).length);
    loadAllRecordItems(function(err,rows){
      if(err){ console.error('Load failed',err); return; }
      var toFix=[], needLookup=[];
      rows.forEach(function(r){
        var old=String(r.Agent_Name||'').trim();
        if(!isBadAgentName(old)) return;
        var neu=nameByEmail[normEmail(r.Agent_Email)];
        if(neu&&neu!==old) toFix.push({Id:r.Id,email:r.Agent_Email,old:old||'(empty)',neu:neu});
        else if(!neu) needLookup.push({Id:r.Id,email:r.Agent_Email,old:old||'(empty)'});
      });
      var unmatched=[];
      function applyFixes(){
        console.log('Total records:',rows.length,'| To fix:',toFix.length,'| No SP name found:',unmatched.length);
        console.table(toFix.slice(0,30));
        if(toFix.length>30) console.log('... and '+(toFix.length-30)+' more');
        if(unmatched.length){
          console.warn('No SharePoint display name for these emails:');
          console.table(unmatched.slice(0,20));
        }
        if(dryRun){
          console.log('Review above. To apply run: bcrFixAgentNames(true)');
          return;
        }
        getListItemType(SP_CONFIG.recordsList,function(listType){
          if(!listType){ console.error('Cannot get list type'); return; }
          var i=0,ok=0,fail=0;
          function next(){
            if(i>=toFix.length){
              console.log('Finished. Fixed:'+ok+' Failed:'+fail);
              loadRecordsFromSharePoint(function(){ if(typeof refreshDashboard==='function') refreshDashboard(); });
              return;
            }
            var it=toFix[i++], site=getSpSite();
            var patchUrl=site+spListPath(SP_CONFIG.recordsList,'/items('+it.Id+')');
            spPatch(patchUrl,{__metadata:{type:listType},Agent_Name:it.neu},function(e){
              if(e){ fail++; console.error('Fail Id '+it.Id,e.message); }
              else { ok++; if(ok%10===0||ok===toFix.length) console.log('Progress '+ok+'/'+toFix.length); }
              next();
            });
          }
          next();
        });
      }
      if(!needLookup.length){ unmatched=[]; applyFixes(); return; }
      console.log('Looking up '+needLookup.length+' emails individually in SharePoint...');
      var li=0;
      function lookupNext(){
        if(li>=needLookup.length){ applyFixes(); return; }
        var item=needLookup[li++];
        lookupSpUserName(item.email,function(name){
          if(name&&name!==item.old) toFix.push({Id:item.Id,email:item.email,old:item.old,neu:name});
          else unmatched.push(item);
          lookupNext();
        });
      }
      lookupNext();
    });
  });
}
