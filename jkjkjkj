/* ── multi-select filter bar (semailbox-style) ───────────── */
function renderFilterBar(){
  var el=$('filterBar'); if(!el) return;
  var anyActive = FILTER_DIMS.some(function(d){ return BCR.filters[d.id].length; }) || BCR.activeKpi || BCR.activePanel;
  var html='<div class="filter-wrap">';
  FILTER_DIMS.forEach(function(d){
    var opts = uniq(BCR.all.map(function(r){ return r[d.id]; }).filter(function(v){ return v!==undefined && v!==''; }));
    if(d.id==='Entry_Month'){
      opts.sort(function(a,b){ return new Date('01 '+b)-new Date('01 '+a); });
    } else opts.sort();
    var sel=BCR.filters[d.id];
    var label = sel.length ? sel.length+' selected' : 'All';
    html+='<div class="fw-group" style="position:relative">'
      +'<div class="fw-label">'+d.label+'</div>'
      +'<div class="dd-trigger'+(sel.length?' has-sel':'')+'" data-dd="'+d.id+'"><span style="overflow:hidden;text-overflow:ellipsis">'+label+'</span><span style="font-size:10px">▼</span></div>'
      +'<div class="dd-menu" id="dd-'+d.id+'">'
      +'<div class="dd-opt all"><label><input type="checkbox" data-dim="'+d.id+'" data-val="__all__" '+(sel.length===0?'checked':'')+'>All</label></div>'
      + opts.map(function(o){ return '<div class="dd-opt"><label><input type="checkbox" data-dim="'+d.id+'" data-val="'+esc(o)+'" '+(sel.indexOf(o)>=0?'checked':'')+'>'+esc(pretty(o))+'</label></div>'; }).join('')
      +'</div></div>';
  });
  html+='<button type="button" class="reset-btn" id="clearFiltersBtn" style="align-self:flex-end;'+(anyActive?'border-color:var(--acc);color:var(--acc)':'')+'">↺ Clear All</button>';
  html+='</div>';
  el.innerHTML=html;

  el.querySelectorAll('.dd-trigger').forEach(function(tr){
    tr.onclick=function(e){
      e.stopPropagation();
      var id=tr.getAttribute('data-dd');
      var menu=$('dd-'+id);
      var open=menu.classList.contains('open');
      el.querySelectorAll('.dd-menu').forEach(function(m){ m.classList.remove('open'); });
      if(!open) menu.classList.add('open');
    };
  });
  el.querySelectorAll('input[data-dim]').forEach(function(cb){
    cb.onchange=function(){
      var dim=cb.getAttribute('data-dim'), val=cb.getAttribute('data-val');
      var arr=BCR.filters[dim];
      if(val==='__all__'){ arr.length=0; }
      else if(cb.checked){ if(arr.indexOf(val)<0) arr.push(val); }
      else { var i=arr.indexOf(val); if(i>=0) arr.splice(i,1); }
      refreshDashboard();
    };
  });
  $('clearFiltersBtn').onclick=function(){
    FILTER_DIMS.forEach(function(d){ BCR.filters[d.id]=[]; });
    BCR.activeKpi=null; BCR.activePanel=null;
    refreshDashboard();
  };
}
