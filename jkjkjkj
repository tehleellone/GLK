function resolveUserEmails(userData){
  var emails=[];
  if(userData&&userData.Email) emails.push(userData.Email);
  if(userData&&userData.LoginName){
    var ln=String(userData.LoginName);
    var m=ln.match(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}/i);
    if(m) emails.push(m[0]);
    var parts=ln.split('|');
    if(parts.length){
      var last=parts[parts.length-1];
      if(last.indexOf('@')>0) emails.push(last);
    }
  }
  var out=[], seen={};
  emails.forEach(function(e){
    e=normEmail(e);
    if(e&&!seen[e]){ seen[e]=1; out.push(e); }
  });
  return out;
}
