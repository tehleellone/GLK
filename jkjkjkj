  $('lName').textContent='Access Denied'; $('lEmail').textContent=msg; $('lRole').textContent='No Access';
  $('launchBtn').disabled=true;
  $('accessNote').innerHTML=bcrIcon('shield-x',14)+'<span style="color:var(--red);margin-left:6px">'+esc(msg)+'</span>';
  bcrIcons();
}
function initAccess(){
  showLoading('Checking access...');
  var site=getSpSite();
  spGet(site+'/_api/web/currentuser?$select=Title,Email,LoginName',function(err,data){
    if(err){ hideLoading(); showDenied('Cannot reach SharePoint at '+site); return; }
    USER.displayName=data.d.Title||'';
    USER.name=USER.displayName;
    var tryEmails=resolveUserEmails(data.d);
    if(!tryEmails.length){ hideLoading(); showDenied('Cannot determine your email from SharePoint login'); return; }
    USER.email=tryEmails[0];

    function grantAccess(row){
      setupLanding({Title:row.Title||USER.name,User_Email:row.User_Email||USER.email,Role:row.Role||'Agent'});
      ensureListMetadata(function(){});
      $('landingPage').classList.add('bcr-show');
      $('landingPage').style.cssText='display:flex!important;flex-direction:row!important;width:100%;';
      hideLoading();
      bcrIcons();
    }

    function denyAccess(totalLoaded){
      hideLoading();
      showDenied('No BCR_Access row for '+USER.email+(totalLoaded?' — searched all '+totalLoaded+' access records':'')+'. Check User_Email matches your login exactly.');
    }

    function tryFullList(){
      $('loadingStep').textContent='Loading full access list...';
      loadAllAccessRows(function(err3,rows){
        if(err3){ hideLoading(); showDenied('Cannot read BCR_Access — '+err3.message); return; }
        var row=findAccessRow(rows,tryEmails);
        if(row) grantAccess(row);
        else denyAccess(rows.length);
      }, function(count, more){
        $('loadingStep').textContent='Loading access list... '+count+(more?'+':'')+' rows';
      });
    }

    function tryFilter(idx){
      if(idx>=tryEmails.length){ tryFullList(); return; }
      $('loadingStep').textContent='Checking access ('+(idx+1)+'/'+tryEmails.length+')...';
      queryAccessByEmail(tryEmails[idx],function(err2,data2){
        if(!err2&&data2.d&&data2.d.results&&data2.d.results.length){
          grantAccess(data2.d.results[0]);
          return;
        }
        tryFilter(idx+1);
      });
    }

    tryFilter(0);
  });
}

