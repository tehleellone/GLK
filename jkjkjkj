/* Numbers drawn ON the chart (not hover-only) — same idea as semailbox */
var BCR_DATA_LABELS = {
  id: 'bcrDataLabels',
  afterDatasetsDraw: function(chart) {
    var ctx = chart.ctx, area = chart.chartArea;
    if (!area || chart.config._bcrSkipLabels) return;
    if (chart.config.type === 'radar') return;
    var isH = chart.config.options && chart.config.options.indexAxis === 'y';
    var isDoughnut = chart.config.type === 'doughnut' || chart.config.type === 'pie' || chart.config.type === 'polarArea';
    var count = 0;
    (chart.data.datasets||[]).forEach(function(ds){ (ds.data||[]).forEach(function(v){ if (v!=null && v!==0) count++; }); });
    if (count > 50) return;
    chart.data.datasets.forEach(function(dataset, di) {
      if (chart.config._bcrLabelBarsOnly && dataset.type === 'line') return;
      if (chart.config._bcrSkipLineLabels && (dataset.type === 'line' || chart.config.type === 'line')) return;
      var meta = chart.getDatasetMeta(di);
      if (meta.hidden) return;
      var total = (dataset.data||[]).reduce(function(a,b){ return a + (b||0); }, 0);
      meta.data.forEach(function(el, i) {
        var val = dataset.data[i];
        if (val == null || val === 0) return;
        var pos = el.tooltipPosition ? el.tooltipPosition() : { x: el.x, y: el.y };
        ctx.save();
        ctx.font = 'bold 10px Inter, system-ui, sans-serif';
        ctx.textBaseline = 'middle';
        ctx.textAlign = 'center';
        if (isDoughnut) {
          if (total && val / total < 0.05) { ctx.restore(); return; }
          ctx.fillStyle = '#fff';
          ctx.fillText(String(val), pos.x, pos.y);
        } else if (isH) {
          var w = Math.abs(el.width || 0);
          if (w < 18) { ctx.fillStyle = '#334155'; ctx.textAlign = 'left'; ctx.fillText(String(val), el.x + 5, el.y); }
          else { ctx.fillStyle = '#fff'; ctx.fillText(String(val), el.x - w / 2, el.y); }
        } else if (chart.config.type === 'line' || dataset.type === 'line') {
          ctx.fillStyle = '#334155';
          ctx.fillText(String(val), pos.x, pos.y - 10);
        } else {
          var h = Math.abs(el.height || 0);
          if (h >= 18) { ctx.fillStyle = '#fff'; ctx.fillText(String(val), pos.x, el.y + h / 2); }
          else { ctx.fillStyle = '#334155'; ctx.fillText(String(val), pos.x, el.y - 8); }
        }
        ctx.restore();
      });
    });
  }
};

function destroyCharts(){ Object.keys(BCR.charts).forEach(function(k){ try{BCR.charts[k].destroy();}catch(e){} }); BCR.charts={}; }
function makeChart(key,cfg){
  var cv=$('chart-'+key); if(!cv||typeof Chart==='undefined') return;
  if(BCR.charts[key]){ try{BCR.charts[key].destroy();}catch(e){} }
  cfg.options=cfg.options||{}; cfg.options.animation={duration:0};
  if (!cfg.options.layout) cfg.options.layout = {};
  cfg.options.layout.padding = Object.assign({ top: 18, right: 10, left: 4, bottom: 4 }, cfg.options.layout.padding || {});
  if (!cfg._bcrSkipLabels) {
    if (!cfg.plugins) cfg.plugins = [];
    if (!cfg.plugins.some(function(p){ return p && p.id === 'bcrDataLabels'; })) cfg.plugins.push(BCR_DATA_LABELS);
  }
  BCR.charts[key]=new Chart(cv,cfg);
}

function fieldCounts(list, field){
  var map={};
  list.forEach(function(r){ var v=r[field]||'—'; map[v]=(map[v]||0)+1; });
  return Object.keys(map).map(function(k){ return { key:k, label:pretty(k), count:map[k] }; })
    .sort(function(a,b){ return b.count - a.count; });
}

function bucketByPeriod(list, per){
  var map={};
  function keyLbl(d){
    if(per==='D') return [d.toISOString().slice(0,10), d.toLocaleDateString('en-GB',{day:'2-digit',month:'short'})];
    if(per==='W'){ var yr=d.getFullYear(); var wk=Math.ceil((d-new Date(yr,0,1))/6048e5); return [yr+'-W'+String(wk).padStart(2,'0'),'W'+wk+' '+String(yr).slice(2)]; }
    return [d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0'), d.toLocaleDateString('en-GB',{month:'short',year:'2-digit'})];
  }
  list.forEach(function(r){
    var d=new Date(r.Contact_Date); if(isNaN(d)) return;
    var kl=keyLbl(d); (map[kl[0]]=map[kl[0]]||{key:kl[0],label:kl[1],count:0}); map[kl[0]].count++;
  });
  return Object.keys(map).map(function(k){return map[k];}).sort(function(a,b){return a.key<b.key?-1:1;});
}

