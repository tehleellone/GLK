    });
    html+='</div></div>';
  });
  html+='<div class="form-actions"><button type="button" class="btn-secondary" id="reviewEditBtn">Edit</button><button type="button" class="btn-primary" id="reviewConfirmBtn">Confirm & Submit</button></div>'
    +'</div></div></div>';
