function loadRecords(cb){
  if(!USE_DUMMY){ loadRecordsFromSharePoint(cb||function(){}); return; }
  try{
    var raw=localStorage.getItem(STORAGE_KEY);
    BCR.all=raw?JSON.parse(raw):seedRecords();
    if(!raw) saveRecords();
  }catch(e){ BCR.all=seedRecords(); }
  BCR.all.sort(function(a,b){return String(b.Contact_Date).localeCompare(String(a.Contact_Date));});
  if(cb)cb();
}
function saveRecords(){
  if(!USE_DUMMY) return;
  try{ localStorage.setItem(STORAGE_KEY, JSON.stringify(BCR.all)); }catch(e){}
}

function nextRefId(){
  var t = todayStr().replace(/-/g,''), prefix='BCR-'+t+'-', max=0;
  BCR.all.forEach(function(r){
    if(String(r.Reference_ID||'').indexOf(prefix)===0){
      var n=parseInt(String(r.Reference_ID).split('-').pop(),10);
      if(!isNaN(n)&&n>max) max=n;
    }
  });
  return prefix + String(max+1).padStart(5,'0');
}
function findAccess(email){ return BCR_ACCESS.find(function(a){ return normEmail(a.User_Email)===normEmail(email); })||null; }

function checkDuplicate(msisdn){
  if(!msisdn) return null;
  var cutoff = Date.now()-7*86400000, norm=String(msisdn).trim();
  var found = BCR.all.filter(function(r){
    if(String(r.MSISDN).trim()!==norm) return false;
    var tm=new Date(r.Contact_Date).getTime();
    return !isNaN(tm)&&tm>=cutoff;
  }).sort(function(a,b){ return String(b.Contact_Date).localeCompare(String(a.Contact_Date)); });
  return found.length ? found[0] : null;
}

/* ── filter engine ───────────────────────────────────────── */
function applyFilters(){
  var data = BCR.all.slice();
  FILTER_DIMS.forEach(function(d){
    var sel = BCR.filters[d.id];
    if(sel && sel.length) data = data.filter(function(r){ return sel.indexOf(r[d.id])>=0; });
  });
  if(BCR.activeKpi){
    var kf = {
      emarati:function(r){return r.Customer_Type==='Emarati';},
      nonEmarati:function(r){return r.Customer_Type==='Non_Emarati';},
      dup:function(r){return r.Duplicate_Flag==='Yes';}
    }[BCR.activeKpi];
    if(kf) data = data.filter(kf);
  }
  if(BCR.activePanel){
    if(BCR.activePanel.indexOf('TP_')===0){
      var tp=BCR.activePanel.slice(3);
      data=data.filter(function(r){ return r.Touch_Point===tp; });
    } else {
      var pf = {
        Inside_UAE:function(r){return r.Customer_Location==='Inside_UAE';},
        Outside_UAE:function(r){return r.Customer_Location==='Outside_UAE';},
        Consumer:function(r){return r.Customer_Segment==='Consumer';},
        Enterprise:function(r){return r.Customer_Segment==='Enterprise';}
      }[BCR.activePanel];
      if(pf) data = data.filter(pf);
    }
  }
  BCR.filtered = data;
  if(BCR.gridApi) BCR.gridApi.setGridOption('rowData', data);
}

function getStats(list){
  list = list || BCR.filtered;
  var s = { total:list.length };
  s.emarati = list.filter(function(r){return r.Customer_Type==='Emarati';}).length;
  s.nonEmarati = list.filter(function(r){return r.Customer_Type==='Non_Emarati';}).length;
  s.inside = list.filter(function(r){return r.Customer_Location==='Inside_UAE';}).length;
  s.outside = list.filter(function(r){return r.Customer_Location==='Outside_UAE';}).length;
  s.consumer = list.filter(function(r){return r.Customer_Segment==='Consumer';}).length;
  s.enterprise = list.filter(function(r){return r.Customer_Segment==='Enterprise';}).length;
  s.dup = list.filter(function(r){return r.Duplicate_Flag==='Yes';}).length;
  s.uniqMsisdn = uniq(list.map(function(r){return r.MSISDN;})).length;
  s.repeatMsisdn = s.total - s.uniqMsisdn;
  return s;
}

