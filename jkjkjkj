function isValidEmail(v){
  return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/i.test(String(v||'').trim());
}
function isValidMsisdn(v){
  var s=String(v||'').replace(/[\s\-]/g,'');
  if(!/^\d+$/.test(s)) return false;
  if(/^05\d{8}$/.test(s)) return true;
  if(/^9715\d{8}$/.test(s)) return true;
  return s.length>=9&&s.length<=12;
}
function isDigitsOnly(v){ return /^\d+$/.test(String(v||'').trim()); }
function formatEmiratesIdDigits(digits){
  digits=String(digits||'').replace(/\D/g,'').slice(0,15);
  var p=[];
  if(digits.length>0) p.push(digits.slice(0,3));
  if(digits.length>3) p.push(digits.slice(3,7));
  if(digits.length>7) p.push(digits.slice(7,14));
  if(digits.length>14) p.push(digits.slice(14,15));
  return p.join('-');
}
function eidCursorAfterDigits(formatted,digitCount){
  if(digitCount<=0) return 0;
  var seen=0;
  for(var i=0;i<formatted.length;i++){
    if(/\d/.test(formatted[i])){
      seen++;
      if(seen>=digitCount) return i+1;
    }
  }
  return formatted.length;
}
function eidDigits(v){ return String(v||'').replace(/\D/g,''); }
function normalizeEmiratesId(v){
  var d=eidDigits(v);
  if(d.length!==15) return '';
  return formatEmiratesIdDigits(d);
}
function emiratesIdError(v){
  var d=eidDigits(v);
  if(!d.length) return 'required';
  if(d.length!==15) return 'digits:'+d.length;
  if(d.slice(0,3)!=='784') return 'prefix';
  if(!/^\d{4}$/.test(d.slice(3,7))) return 'year';
  return '';
}
function isValidEmiratesId(v){ return !emiratesIdError(v); }
function bindEidField(el){
  el.addEventListener('input',function(){
    var sel=this.selectionStart||0;
    var digitsBefore=this.value.slice(0,sel).replace(/\D/g,'').length;
    var digits=this.value.replace(/\D/g,'').slice(0,15);
    this.value=formatEmiratesIdDigits(digits);
    var newSel=eidCursorAfterDigits(this.value,digitsBefore);
    try{ this.setSelectionRange(newSel,newSel); }catch(e){}
  });
  el.addEventListener('paste',function(e){
    e.preventDefault();
    var text=(e.clipboardData||window.clipboardData).getData('text')||'';
    var digits=(this.value.replace(/\D/g,'')+text.replace(/\D/g,'')).slice(0,15);
    this.value=formatEmiratesIdDigits(digits);
    try{ this.setSelectionRange(this.value.length,this.value.length); }catch(ex){}
  });
  el.addEventListener('blur',function(){
    var digits=this.value.replace(/\D/g,'');
    if(digits.length===15) this.value=formatEmiratesIdDigits(digits);
    this.classList.toggle('invalid',!!this.value.trim()&&!!emiratesIdError(this.value));
  });
}
function markInvalid(key){ var el=$('fld_'+key); if(el) el.classList.add('invalid'); return el; }
function fieldInputHtml(f){
  if(f.type==='eid'||EID_FIELD_KEYS.indexOf(f.key)>=0){
    return '<input class="form-input" type="tel" inputmode="numeric" id="fld_'+f.key+'" placeholder="784-YYYY-NNNNNNN-C" autocomplete="off">';
  }
  if(f.key==='Email_Address') return '<input class="form-input" type="email" id="fld_'+f.key+'" placeholder="name@company.com" autocomplete="off">';
  if(f.key==='Calling_Number_Chat_Social_Email') return '<input class="form-input" type="text" id="fld_'+f.key+'" placeholder="Calling number, Chat ID, Social ID or Email" autocomplete="off">';
  if(f.type==='numeric'||NUMERIC_FIELD_KEYS.indexOf(f.key)>=0){
    var ph=f.key==='MSISDN'?'05xxxxxxxx':'Digits only';
    var max=f.key==='MSISDN'?' maxlength="12"':'';
    return '<input class="form-input" type="tel" inputmode="numeric" id="fld_'+f.key+'" placeholder="'+ph+'"'+max+' autocomplete="off">';
  }
  if(f.key==='Alternative_Contact') return '<input class="form-input" type="tel" inputmode="numeric" id="fld_'+f.key+'" placeholder="05xxxxxxxx" autocomplete="off">';
  if(f.type==='date') return '<input class="form-input" type="date" id="fld_'+f.key+'">';
  return '<input class="form-input" type="text" id="fld_'+f.key+'">';
}
function bindFormValidation(){
  NUMERIC_FIELD_KEYS.forEach(function(key){
