<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GLK Enterprise Pipeline Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/ag-grid/32.0.2/ag-grid-community.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/ag-grid-community@32.0.2/styles/ag-grid.css">
<link rel="stylesheet" href="https://unpkg.com/ag-grid-community@32.0.2/styles/ag-theme-alpine.css">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

/* ═══════ TOKENS ═══════════════════════════════════════════════════════ */
/* MAGENTA LIGHT — default */
:root {
  --bg-body: linear-gradient(145deg, #f9f0ff, #fce7ff, #f5eeff);
  --bg-card: #ffffff;
  --bg-header: rgba(255,255,255,0.97);
  --bg-sidebar: linear-gradient(180deg,#fdf4ff,#f8ecff);
  --bg-content: #f9f3ff;
  --bg-input: rgba(168,85,247,0.06);
  --bg-secondary: rgba(168,85,247,0.05);
  --bg-hover: rgba(168,85,247,0.07);
  --border: rgba(168,85,247,0.2);
  --border-s: rgba(168,85,247,0.45);
  --t1: #1e1133;
  --t2: #4b3f6b;
  --t3: #8b7aad;
  --acc: #a855f7;
  --acc2: #c724b1;
  --glow: rgba(168,85,247,0.28);
  --grad: linear-gradient(135deg,#9248b9,#c724b1);
  --nab: rgba(168,85,247,0.1);
  --nab2: rgba(168,85,247,0.35);
  --sc: #a855f7;
  --cs: 0 1px 8px rgba(168,85,247,0.12);
  --ch: 0 6px 20px rgba(168,85,247,0.2);
  --chip: rgba(168,85,247,0.08);
}
/* MAGENTA DARK */
body[data-theme="dark"] {
  --bg-body: linear-gradient(145deg,#120820,#1e0d33,#160a28);
  --bg-card: #1f0d38;
  --bg-header: rgba(18,8,32,0.98);
  --bg-sidebar: linear-gradient(180deg,#230f3d,#1a0a2e);
  --bg-content: #160a28;
  --bg-input: rgba(168,85,247,0.12);
  --bg-secondary: rgba(168,85,247,0.08);
  --bg-hover: rgba(168,85,247,0.12);
  --border: rgba(168,85,247,0.2);
  --border-s: rgba(168,85,247,0.5);
  --t1: #f3e8ff;
  --t2: #c4b5fd;
  --t3: #8b5cf6;
  --acc: #c084fc;
  --acc2: #e879f9;
  --glow: rgba(192,132,252,0.35);
  --grad: linear-gradient(135deg,#9248b9,#c724b1);
  --nab: rgba(168,85,247,0.16);
  --nab2: rgba(168,85,247,0.45);
  --sc: #e879f9;
  --cs: 0 2px 16px rgba(0,0,0,0.5);
  --ch: 0 6px 24px rgba(168,85,247,0.25);
  --chip: rgba(168,85,247,0.15);
}
/* DURALUX LIGHT */
body[data-theme="duralux"] {
  --bg-body: linear-gradient(145deg,#f0f4ff,#e8edff,#f4f6ff);
  --bg-card: #ffffff;
  --bg-header: rgba(255,255,255,0.97);
  --bg-sidebar: linear-gradient(180deg,#f0f4ff,#e8edff);
  --bg-content: #f0f4ff;
  --bg-input: rgba(76,111,255,0.06);
  --bg-secondary: rgba(76,111,255,0.05);
  --bg-hover: rgba(76,111,255,0.07);
  --border: rgba(76,111,255,0.2);
  --border-s: rgba(76,111,255,0.45);
  --t1: #0f1a3e;
  --t2: #3d4f8a;
  --t3: #7a8fc4;
  --acc: #4c6fff;
  --acc2: #818cf8;
  --glow: rgba(76,111,255,0.28);
  --grad: linear-gradient(135deg,#4c6fff,#818cf8);
  --nab: rgba(76,111,255,0.1);
  --nab2: rgba(76,111,255,0.35);
  --sc: #4c6fff;
  --cs: 0 1px 8px rgba(76,111,255,0.1);
  --ch: 0 6px 20px rgba(76,111,255,0.18);
  --chip: rgba(76,111,255,0.08);
}
/* DURALUX DARK */
body[data-theme="duralux-dark"] {
  --bg-body: linear-gradient(145deg,#060c1f,#0c1535,#080e25);
  --bg-card: #0e1630;
  --bg-header: rgba(6,12,31,0.98);
  --bg-sidebar: linear-gradient(180deg,#101a38,#0c1430);
  --bg-content: #090f28;
  --bg-input: rgba(76,111,255,0.12);
  --bg-secondary: rgba(76,111,255,0.08);
  --bg-hover: rgba(76,111,255,0.12);
  --border: rgba(76,111,255,0.2);
  --border-s: rgba(76,111,255,0.5);
  --t1: #e2e8f0;
  --t2: #a5b4c8;
  --t3: #637899;
  --acc: #818cf8;
  --acc2: #a5b4fc;
  --glow: rgba(129,140,248,0.35);
  --grad: linear-gradient(135deg,#4c6fff,#818cf8);
  --nab: rgba(76,111,255,0.14);
  --nab2: rgba(76,111,255,0.45);
  --sc: #818cf8;
  --cs: 0 2px 16px rgba(0,0,0,0.55);
  --ch: 0 6px 24px rgba(76,111,255,0.2);
  --chip: rgba(76,111,255,0.15);
}

/* ═══════ RESET ════════════════════════════════════════════════════════ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
h1,h2,h3,h4,h5,h6{margin:0!important;padding:0!important;font-weight:inherit}
html{scroll-behavior:smooth}
body{
  font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  background:var(--bg-body);
  color:var(--t1);
  min-height:100vh;
  -webkit-font-smoothing:antialiased;
  transition:background .3s,color .3s;
  line-height:1.5;
}
select,input,textarea,button{font-family:inherit}

/* ═══════ PORTAL SHELL ══════════════════════════════════════════════════ */
.portal-shell{
  max-width:1800px;margin:0 auto;min-height:100vh;
  display:flex;flex-direction:column;background:var(--bg-body);
}

/* ═══════ HEADER ════════════════════════════════════════════════════════ */
.header{
  background:var(--bg-header);border-bottom:1px solid var(--border);
  backdrop-filter:blur(16px);padding:0 1.25rem;height:56px;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  position:sticky;top:0;z-index:200;flex-shrink:0;
}
.logo-section{display:flex;align-items:center;gap:.65rem;min-width:0}
.logo{
  width:36px;height:36px;border-radius:10px;background:var(--grad);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 14px var(--glow);flex-shrink:0;
}
.logo svg{width:20px;height:20px;stroke:#fff;fill:none;stroke-width:2}
.header-title{
  font-size:1.05rem;font-weight:800;white-space:nowrap;
  background:var(--grad);-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;
}
.header-center{display:flex;align-items:center;gap:.75rem;flex:1;justify-content:flex-start;padding-left:.75rem}
.header-actions{display:flex;align-items:center;gap:.5rem;flex-shrink:0}
.live-badge-pill{
  display:inline-flex;align-items:center;gap:.3rem;padding:.22rem .65rem;
  border-radius:20px;background:rgba(22,163,74,.12);border:1px solid rgba(22,163,74,.28);
  font-size:.73rem;font-weight:700;color:#16a34a;white-space:nowrap;
}
body[data-theme="dark"] .live-badge-pill,
body[data-theme="duralux-dark"] .live-badge-pill{
  background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.25);color:#22c55e;
}
.status-dot{
  width:6px;height:6px;border-radius:50%;background:#16a34a;
  animation:pulseDot 2s infinite;
}
body[data-theme="dark"] .status-dot,body[data-theme="duralux-dark"] .status-dot{background:#22c55e}
@keyframes pulseDot{0%,100%{box-shadow:0 0 0 0 rgba(22,163,74,.4)}50%{box-shadow:0 0 0 5px rgba(22,163,74,0)}}
.date-badge{font-size:.75rem;color:var(--t3);display:flex;align-items:center;gap:.3rem;white-space:nowrap}
.color-scheme-selector{
  padding:.3rem .65rem;background:var(--bg-input);border:1px solid var(--border);
  border-radius:18px;color:var(--t1);font-size:.75rem;cursor:pointer;transition:border-color .2s;
}
.color-scheme-selector:hover{border-color:var(--border-s)}
.theme-toggle{
  width:34px;height:34px;border-radius:50%;background:var(--bg-input);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t1);transition:all .2s;
}
.theme-toggle:hover{border-color:var(--border-s)}
.theme-toggle svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}

/* ═══════ SIDEBAR ═══════════════════════════════════════════════════════ */
.sidebar-toggle-btn{
  position:absolute;right:-14px;top:20px;z-index:300;width:28px;height:28px;border-radius:50%;
  background:var(--bg-card);border:1px solid var(--border);box-shadow:var(--cs);
  display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t1);transition:all .2s;
}
.sidebar-toggle-btn:hover{border-color:var(--border-s);background:var(--bg-hover)}
.sidebar-toggle-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}
.main-container{display:flex;flex:1;min-height:0;position:relative}
.sidebar{
  width:210px;min-width:210px;background:var(--bg-sidebar);border-right:1px solid var(--border);
  padding:1rem 0;overflow:visible;flex-shrink:0;transition:width .26s ease,min-width .26s ease,opacity .22s,padding .25s;
}
.sidebar.collapsed{width:52px;min-width:52px;padding:1rem 0;border-right:1px solid var(--border);overflow:hidden!important}
.sidebar.collapsed .nav-items{opacity:1;pointer-events:all;}
.sidebar.collapsed .nav-label{display:none;}
.sidebar.collapsed .nav-section-label{display:none;}
.sidebar.collapsed .nav-item{justify-content:center;padding:.55rem 0;}
.sidebar.collapsed .sidebar-toggle-btn{opacity:1!important;pointer-events:all!important;right:-14px;background:var(--bg-card);box-shadow:var(--cs)}
.nav-items{display:flex;flex-direction:column;gap:2px;padding:0 .65rem}
.nav-section-label{
  font-size:.67rem;text-transform:uppercase;letter-spacing:.1em;color:var(--t3);
  padding:.75rem .6rem .3rem;white-space:nowrap;overflow:hidden;
}
.nav-item{
  display:flex;align-items:center;gap:.65rem;padding:.55rem .7rem;border-radius:9px;
  cursor:pointer;color:var(--t2);border:1px solid transparent;transition:all .17s;
  white-space:nowrap;overflow:hidden;font-size:.84rem;font-weight:500;user-select:none;
}
.nav-item .nav-icon{display:flex;align-items:center;flex-shrink:0;width:17px;height:17px}
.nav-item .nav-icon svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:2}
.nav-item .nav-label{font-size:.84rem;font-weight:500}
.nav-item:hover{background:var(--bg-hover);color:var(--t1)}
.nav-item.active{background:var(--nab);border-color:var(--nab2);color:var(--t1);font-weight:600}

/* ═══════ CONTENT ═══════════════════════════════════════════════════════ */
.content{flex:1;overflow-y:auto;min-width:0;background:var(--bg-content);padding:1.1rem 1.25rem}
.dashboard-section{animation:fadeSection .25s ease;padding:.5rem 0}
@keyframes fadeSection{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}

/* ═══════ SECTION TITLE ══════════════════════════════════════════════════ */
.section-title{
  font-size:1rem;font-weight:800;margin:.85rem 0!important;
  display:flex;align-items:center;gap:.45rem;color:var(--acc);
}
.section-title svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:2}

/* ═══════ STAT CARDS ════════════════════════════════════════════════════ */
.top-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.85rem;margin-bottom:1rem}
.stat-card{
  background:var(--bg-card);border:1px solid var(--border);border-radius:12px;
  padding:1rem 1.1rem;box-shadow:var(--cs);position:relative;overflow:hidden;
  transition:transform .18s,box-shadow .18s;
}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad)}
.stat-card:hover{transform:translateY(-2px);box-shadow:var(--ch)}
.stat-label{font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;color:var(--t3);font-weight:700;margin-bottom:.35rem}
.stat-value{font-size:1.9rem;font-weight:900;line-height:1;color:var(--sc);margin-bottom:.25rem}
.stat-subtitle{font-size:.76rem;font-weight:600;color:var(--t2)}
.stat-breakdown{margin-top:.45rem;display:flex;flex-wrap:wrap;gap:.4rem}
.breakdown-item{display:inline-flex;align-items:center;gap:.2rem;font-size:.7rem}
.breakdown-label{color:var(--t3)}
.breakdown-value{font-weight:700;color:var(--t2)}

/* ═══════ FILTERS ════════════════════════════════════════════════════════ */
.filters-section{
  background:var(--bg-card);border:1px solid var(--border);border-radius:12px;
  padding:.9rem 1rem;margin-bottom:1rem;box-shadow:var(--cs);
}
.filters-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.65rem;margin-bottom:.65rem}
.filter-group{display:flex;flex-direction:column;gap:.25rem}
.filter-label{font-size:.68rem;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.05em}

/* Multi-select widget */
.ms-wrap{position:relative;z-index:auto}.ms-trigger{
  padding:.48rem .7rem;border-radius:8px;border:1px solid var(--border);
  background:var(--bg-input);color:var(--t1);font-size:.83rem;
  cursor:pointer;display:flex;align-items:center;justify-content:space-between;
  transition:border-color .18s,box-shadow .18s;user-select:none;
}
.ms-trigger:hover,.ms-trigger.open{border-color:var(--border-s);box-shadow:0 0 0 3px var(--glow)}
.ms-trigger svg{width:14px;height:14px;stroke:var(--t3);fill:none;stroke-width:2;transition:transform .2s;flex-shrink:0}
.ms-trigger.open svg{transform:rotate(180deg)}
.ms-dropdown{position:fixed;background:var(--bg-card);border:1px solid var(--border-s);border-radius:8px;max-height:230px;overflow-y:auto;z-index:99999;box-shadow:0 8px 32px rgba(0,0,0,.28);display:none;min-width:180px;}
.ms-dropdown.open{display:block}
.ms-option{
  padding:8px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;
  font-size:.83rem;transition:background .15s;
}
.ms-option:hover{background:var(--bg-hover)}
.ms-option input[type=checkbox]{width:14px;height:14px;cursor:pointer;accent-color:var(--acc)}
.ms-option label{cursor:pointer;flex:1;color:var(--t1)}
.filter-actions{display:flex;gap:.5rem;justify-content:flex-end}

/* ═══════ BUTTONS ════════════════════════════════════════════════════════ */
.export-btn{
  padding:.5rem 1rem;border-radius:8px;font-size:.82rem;font-weight:700;cursor:pointer;
  display:inline-flex;align-items:center;gap:.35rem;transition:all .2s;border:none;
  background:var(--grad);color:#fff;box-shadow:0 2px 10px var(--glow);white-space:nowrap;
}
.export-btn:hover{box-shadow:0 4px 16px var(--glow);transform:translateY(-1px)}
.export-btn svg{width:14px;height:14px;stroke:#fff;fill:none;stroke-width:2}
.reset-btn{
  padding:.5rem 1rem;border-radius:8px;font-size:.82rem;font-weight:600;cursor:pointer;
  display:inline-flex;align-items:center;gap:.35rem;transition:all .2s;
  background:var(--bg-input);color:var(--t1);border:1px solid var(--border);white-space:nowrap;
}
.reset-btn:hover{border-color:var(--border-s)}
.reset-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}

/* ═══════ HD / AD TILES (= LM TILES from SM) ════════════════════════════ */
.hd-section,.ad-section{margin-bottom:1rem}
.hd-grid,.ad-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.85rem}
.lm-tile .lm-progress-section{
  border-top: 1px solid var(--border);
  margin-top:.55rem;
  padding-top:.45rem;
}
.lm-tile{
  background:var(--bg-card);border:1px solid var(--border);border-radius:13px;
  padding:.9rem 1rem;cursor:pointer;transition:all .2s;box-shadow:var(--cs);
  position:relative;overflow:hidden;
}
.lm-tile::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad)}
.lm-tile:hover{transform:translateY(-2px);box-shadow:var(--ch);border-color:var(--border-s)}
.lm-tile.selected{border-color:var(--nab2);background:var(--nab)}
.lm-header{display:flex;flex-direction:column;gap:.15rem;margin-bottom:.6rem}
.lm-header h3{font-size:.88rem;font-weight:700;color:var(--t1);line-height:1.2}
.lm-meta{font-size:.68rem;color:var(--t3)}
.lm-stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.6rem}
.lm-stat-box{background:var(--bg-secondary);border-radius:7px;padding:.5rem .6rem;border:1px solid var(--border)}
.lm-stat-label{font-size:.65rem;text-transform:uppercase;color:var(--t3);margin-bottom:.12rem;font-weight:600}
.lm-stat-value{font-size:1.05rem;font-weight:800;color:var(--sc)}
.lm-revenue{border-radius:8px;padding:.55rem .7rem;background:var(--grad);color:#fff;margin-bottom:.55rem}
.lm-revenue-label{font-size:.65rem;text-transform:uppercase;opacity:.82;font-weight:700;margin-bottom:.15rem}
.lm-revenue-count{font-size:1.05rem;font-weight:900;margin-bottom:.3rem}
.lm-revenue-breakdown{display:flex;flex-direction:column;gap:.15rem}
.lm-revenue-item{display:flex;justify-content:space-between;align-items:center}
.lm-revenue-item-label{font-size:.66rem;opacity:.8}
.lm-revenue-item-value{font-size:.72rem;font-weight:700}
.lm-progress-section{margin-top:.45rem}
.lm-progress-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:.12rem}
.lm-progress-label,.lm-progress-value{font-size:.68rem;color:var(--t3)}
.lm-progress-value{font-weight:700}
.progress-bar{background:var(--bg-secondary);border-radius:20px;height:5px;overflow:hidden;margin-bottom:.4rem}
.progress-fill{height:100%;border-radius:20px;background:var(--grad);transition:width .5s ease}

/* ═══════ AM ROWS (= SM ROWS from SM) ═══════════════════════════════════ */
.am-section{margin-bottom:1rem}
.manager-list{display:flex;flex-direction:column;gap:.55rem}
.manager-row{
  background:var(--bg-card);border:1px solid var(--border);border-radius:11px;
  padding:.75rem 1rem;display:flex;align-items:center;flex-wrap:wrap;gap:.85rem;
  box-shadow:var(--cs);transition:all .18s;cursor:pointer;
}
.manager-row:hover{border-color:var(--border-s);transform:translateX(2px)}
.manager-row.selected{border-color:var(--nab2);background:var(--nab)}
.rank-badge{
  width:30px;height:30px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-weight:900;font-size:.76rem;color:#fff;flex-shrink:0;
}
.rank-badge.rank-1{background:var(--grad);box-shadow:0 0 10px var(--glow)}
.rank-badge.rank-2{background:linear-gradient(135deg,#94a3b8,#64748b)}
.rank-badge.rank-3{background:linear-gradient(135deg,#c2853b,#d97706)}
.rank-badge.rank-other{background:var(--bg-secondary);color:var(--t3);border:1px solid var(--border)}
.manager-name-col{flex:0 0 140px;min-width:0}
.manager-name{font-weight:700;font-size:.86rem;color:var(--t1);margin-bottom:.15rem}
.manager-tag{
  display:inline-block;padding:.15rem .5rem;border-radius:5px;font-size:.65rem;font-weight:700;
  background:var(--chip);color:var(--acc);border:1px solid var(--nab2);
}
.stat-col{display:flex;flex-direction:column;min-width:70px}
.stat-col .stat-label{font-size:.62rem;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:.15rem}
.stat-col .stat-value{font-size:.82rem;font-weight:700;color:var(--t1)}
.progress-bar-col{flex:1;min-width:120px;max-width:200px}
.progress-label{font-size:.67rem;color:var(--t3);margin-bottom:.12rem}

/* ═══════ CHARTS ════════════════════════════════════════════════════════ */
.charts-section{display:grid;grid-template-columns:repeat(2,1fr);gap:.85rem;margin-bottom:1rem}
.charts-section.charts-3{grid-template-columns:repeat(3,1fr)}
.chart-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem;box-shadow:var(--cs)}
.chart-card.span2{grid-column:span 2}
.chart-title{font-size:.8rem;font-weight:700;color:var(--t2);margin-bottom:.65rem;display:flex;align-items:center;gap:.35rem}
.chart-title svg{width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2}
.chart-container{position:relative;height:260px}

/* ═══════ TABLE SECTION ═════════════════════════════════════════════════ */
.table-section{
  background:var(--bg-card);border:1px solid var(--border);border-radius:12px;
  padding:1rem 1.1rem;margin-bottom:1rem;box-shadow:var(--cs);
}
.table-header{
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;
  gap:.65rem;margin-bottom:.85rem;
}
.table-title{font-size:.9rem;font-weight:800;color:var(--t1);display:flex;align-items:center;gap:.35rem;margin:0!important}
.table-title svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2}
.table-actions{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
.search-box{
  padding:.45rem .75rem;border-radius:8px;border:1px solid var(--border);
  background:var(--bg-input);color:var(--t1);font-size:.82rem;min-width:180px;transition:border-color .18s;
}
.search-box:focus{outline:none;border-color:var(--border-s)}
.search-box::placeholder{color:var(--t3)}

/* ═══════ STATUS BADGES ═════════════════════════════════════════════════ */
.status-badge{
  display:inline-block;padding:.18rem .55rem;border-radius:20px;font-size:.68rem;
  font-weight:700;text-transform:uppercase;letter-spacing:.04em;
}
.badge-success{background:rgba(22,163,74,.12);color:#16a34a;border:1px solid rgba(22,163,74,.28)}
.badge-warning{background:rgba(245,158,11,.12);color:#b45309;border:1px solid rgba(245,158,11,.28)}
.badge-danger{background:rgba(220,38,38,.12);color:#dc2626;border:1px solid rgba(220,38,38,.28)}
.badge-info{background:rgba(37,99,235,.12);color:#2563eb;border:1px solid rgba(37,99,235,.28)}
body[data-theme="dark"] .badge-success,body[data-theme="duralux-dark"] .badge-success{
  background:rgba(34,197,94,.12);color:#22c55e;border-color:rgba(34,197,94,.25)
}
body[data-theme="dark"] .badge-warning,body[data-theme="duralux-dark"] .badge-warning{
  background:rgba(251,191,36,.12);color:#fbbf24;border-color:rgba(251,191,36,.25)
}

/* ═══════ AG GRID ════════════════════════════════════════════════════════ */
.ag-theme-alpine .ag-root-wrapper{background:var(--bg-card)!important;border-color:var(--border)!important;border-radius:10px!important;overflow:hidden!important}
.ag-theme-alpine .ag-header,.ag-theme-alpine .ag-header-row,.ag-theme-alpine .ag-header-viewport,.ag-theme-alpine .ag-pinned-left-header,.ag-theme-alpine .ag-pinned-right-header{background:var(--bg-secondary)!important;border-bottom:2px solid var(--border-s)!important}
.ag-theme-alpine .ag-header-cell{background:var(--bg-secondary)!important;color:var(--t1)!important;font-weight:700!important;font-size:.71rem!important;text-transform:uppercase!important;letter-spacing:.04em!important}
.ag-theme-alpine .ag-header-cell-text,.ag-theme-alpine .ag-header-cell-label{color:var(--t1)!important;font-weight:700!important}
.ag-theme-alpine .ag-icon{color:var(--t3)!important}
.ag-theme-alpine .ag-body-viewport,.ag-theme-alpine .ag-center-cols-viewport,.ag-theme-alpine .ag-pinned-left-cols-container,.ag-theme-alpine .ag-pinned-right-cols-container{background:var(--bg-card)!important}
.ag-theme-alpine .ag-row{background:var(--bg-card)!important;color:var(--t1)!important;border-bottom-color:var(--border)!important}
.ag-theme-alpine .ag-row-odd{background:var(--bg-secondary)!important}
.ag-theme-alpine .ag-row-hover,.ag-theme-alpine .ag-row-hover.ag-row-even,.ag-theme-alpine .ag-row-hover.ag-row-odd{background:var(--bg-hover)!important}
.ag-theme-alpine .ag-cell{color:var(--t1)!important}
.ag-theme-alpine .ag-paging-panel{background:var(--bg-card)!important;color:var(--t1)!important;border-top-color:var(--border)!important}
.ag-theme-alpine .ag-menu,.ag-theme-alpine .ag-filter,.ag-theme-alpine .ag-filter-body-wrapper{background:var(--bg-card)!important;color:var(--t1)!important;border-color:var(--border)!important}
.ag-theme-alpine input.ag-input-field-input{background:var(--bg-input)!important;color:var(--t1)!important;border-color:var(--border)!important}

/* ═══════ LANDING ════════════════════════════════════════════════════════ */
.landing-page{min-height:100vh;display:flex!important;flex-direction:row!important;background:var(--bg-body)}
.landing-left,.landing-right{flex:1!important;display:flex!important;align-items:center!important;justify-content:center!important;padding:2rem!important;min-width:0!important}
.landing-container{width:100%;max-width:420px}
.landing-card{background:var(--bg-card);border:1px solid var(--border);border-radius:16px;padding:1.4rem;box-shadow:var(--cs);margin-bottom:1rem}
.landing-header{text-align:center;margin-bottom:1.4rem}
.landing-logo{display:flex;justify-content:center;margin-bottom:.85rem}
.logo-icon{width:60px;height:60px;border-radius:15px;background:var(--grad);display:flex;align-items:center;justify-content:center;box-shadow:0 0 24px var(--glow)}
.logo-icon svg{width:32px;height:32px;stroke:#fff;fill:none;stroke-width:2}
.landing-title{font-size:1.4rem;font-weight:800;color:var(--t1);margin-bottom:.25rem}
.landing-subtitle{font-size:.82rem;color:var(--t3)}
.welcome-badge{
  display:inline-flex;align-items:center;gap:.35rem;padding:.25rem .7rem;border-radius:20px;
  background:var(--nab);border:1px solid var(--nab2);font-size:.75rem;font-weight:600;color:var(--acc);margin-bottom:.75rem;
}
.badge-pulse{width:6px;height:6px;border-radius:50%;background:var(--acc);animation:pulseDot 2s infinite}
.landing-user-info{display:flex;align-items:center;gap:.8rem}
.landing-avatar{position:relative;width:48px;height:48px;flex-shrink:0}
.avatar-ring{position:absolute;inset:0;border-radius:50%;border:2px solid var(--acc);opacity:.5}
.avatar-placeholder{width:48px;height:48px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:800;color:#fff}
.landing-details h3{font-size:.95rem;font-weight:700;color:var(--t1)}
.landing-details p{font-size:.77rem;color:var(--t3)}
.landing-role{display:inline-block;margin-top:.25rem;padding:.17rem .55rem;border-radius:5px;font-size:.7rem;font-weight:600;background:var(--chip);color:var(--acc);border:1px solid var(--border)}
.landing-stats-container{margin:.9rem 0}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:.55rem}
.landing-stat-card{background:var(--bg-secondary);border:1px solid var(--border);border-radius:10px;padding:.7rem;display:flex;gap:.55rem;align-items:center}
.stat-icon-wrapper{position:relative;width:34px;height:34px;flex-shrink:0}
.stat-icon-bg{position:absolute;inset:0;border-radius:7px;background:var(--grad);opacity:.15}
.stat-icon{width:18px;height:18px;position:relative;margin:8px;stroke:var(--acc);fill:none;stroke-width:2}
.stat-content{flex:1;min-width:0}
.stat-mini{display:flex;align-items:center;gap:.3rem;font-size:.72rem;color:var(--t3)}
.stats-secondary{display:flex;justify-content:center;gap:1.25rem;margin-top:.65rem}
.landing-actions{margin-top:.9rem}
.landing-btn{
  width:100%;padding:.72rem;border-radius:11px;font-size:.88rem;font-weight:700;cursor:pointer;border:none;
  transition:all .2s;display:flex;align-items:center;justify-content:center;gap:.45rem;position:relative;overflow:hidden;
}
.btn-primary-enhanced{background:var(--grad);color:#fff;box-shadow:0 3px 14px var(--glow)}
.btn-primary-enhanced:hover{box-shadow:0 5px 20px var(--glow);transform:translateY(-1px)}
.btn-primary-enhanced:disabled{opacity:.5;cursor:not-allowed;transform:none}
.btn-shine{position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);transition:left .5s}
.landing-btn:hover .btn-shine{left:100%}
.btn-icon svg{width:20px;height:20px;stroke:#fff;fill:none;stroke-width:2}
.landing-note{display:flex;align-items:flex-start;gap:.35rem;margin-top:.6rem;font-size:.74rem;color:var(--t3)}
.landing-note svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0;margin-top:1px}
.landing-footer{text-align:center;font-size:.72rem;color:var(--t3);margin-top:.4rem}
.landing-branding{max-width:420px}
.landing-brand-title{font-size:1.9rem;font-weight:900;color:var(--t1)}
.landing-brand-title span{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.landing-brand-subtitle{font-size:.86rem;color:var(--t3);margin-top:.4rem}
.landing-features{margin-top:1.3rem;display:flex;flex-direction:column;gap:.7rem}
.landing-feature{display:flex;align-items:flex-start;gap:.65rem}
.landing-feature-icon{
  width:34px;height:34px;border-radius:9px;flex-shrink:0;background:var(--nab);
  border:1px solid var(--nab2);display:flex;align-items:center;justify-content:center;color:var(--acc);
}
.landing-feature-icon svg{width:18px;height:18px;stroke:var(--acc);fill:none;stroke-width:2}
.landing-feature-title{font-weight:700;font-size:.86rem;color:var(--t1)}
.landing-feature-desc{font-size:.76rem;color:var(--t3);margin-top:.12rem}

/* Console login (dev mode) */
.dev-console{
  position:fixed;bottom:12px;right:12px;z-index:9999;
  background:var(--bg-card);border:1px solid var(--border);border-radius:10px;
  padding:.65rem .9rem;display:flex;align-items:center;gap:.5rem;
  box-shadow:var(--cs);font-size:.75rem;
}
.dev-console input{
  padding:.3rem .6rem;border-radius:6px;border:1px solid var(--border);
  background:var(--bg-input);color:var(--t1);font-size:.75rem;width:200px;
}
.dev-console button{
  padding:.3rem .7rem;border-radius:6px;background:var(--grad);color:#fff;
  border:none;font-size:.74rem;font-weight:700;cursor:pointer;
}
.dev-console-label{font-size:.68rem;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.04em}

/* Animate in */
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
.animate-fade-in{animation:fadeIn .55s ease forwards}
.animate-slide-up{animation:slideUp .7s ease forwards}

/* Responsive */
@media(max-width:1200px){
  .charts-section.charts-3{grid-template-columns:repeat(2,1fr)}
  .chart-card.span2{grid-column:span 1}
}
@media(max-width:900px){.charts-section{grid-template-columns:1fr}}
@media(max-width:768px){
  .sidebar{width:180px;min-width:180px}
  .landing-page{flex-direction:column!important}
  .top-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:.85rem;margin-bottom:1rem}
}
.stat-detail{
  position:fixed;
  background:var(--bg-card)!important;
  border:1px solid var(--border-s);
  border-radius:12px;
  padding:.85rem 1rem;
  box-shadow:0 12px 40px rgba(0,0,0,.25);
  z-index:999999;
  width:250px;
  font-size:.75rem;
  line-height:1.7;
  opacity:0;
  pointer-events:none;
  transition:opacity .2s;
}
.stat-detail.visible{opacity:1!important;pointer-events:auto}
.stat-card{overflow:visible!important;z-index:1;}
.stat-card:hover{z-index:10;}
.stat-detail{
  position:fixed!important;
  background:var(--bg-card);border:1px solid var(--border-s);border-radius:10px;
  padding:.75rem 1rem;box-shadow:0 8px 32px rgba(0,0,0,.28);
  z-index:999999;min-width:230px;max-width:280px;font-size:.75rem;line-height:1.65;
  opacity:0;pointer-events:none;transition:opacity .18s;white-space:normal;
  top:0;left:0;
}
.stat-eye{position:absolute;top:8px;right:8px;width:22px;height:22px;border-radius:50%;background:var(--bg-secondary);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .18s;z-index:2;}
.stat-eye:hover{border-color:var(--border-s);background:var(--bg-hover)}
.stat-eye svg{width:13px;height:13px;stroke:var(--t3);fill:none;stroke-width:2;pointer-events:none}
.stat-eye.active svg{stroke:var(--acc)}.stat-eye{position:absolute;top:8px;right:8px;width:22px;height:22px;border-radius:50%;background:var(--bg-secondary);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .18s;z-index:2;}
.stat-eye:hover{border-color:var(--border-s);background:var(--bg-hover)}
.stat-eye svg{width:13px;height:13px;stroke:var(--t3);fill:none;stroke-width:2;pointer-events:none}
.stat-eye.active svg{stroke:var(--acc)}
.stat-detail-title{font-weight:800;font-size:.78rem;color:var(--t1);margin-bottom:.4rem;padding-bottom:.3rem;border-bottom:1px solid var(--border)}
.stat-detail-row{display:flex;justify-content:space-between;gap:.5rem;padding:.07rem 0}
.stat-detail-row span:first-child{color:var(--t3)}
.stat-detail-row span:last-child{font-weight:700;color:var(--t1)}
.stat-detail-note{margin-top:.4rem;font-size:.68rem;color:var(--t3);font-style:italic;border-top:1px solid var(--border);padding-top:.3rem}
.period-btn{
  padding:.2rem .55rem;border-radius:6px;font-size:.7rem;font-weight:600;
  background:var(--bg-secondary);border:1px solid var(--border);
  color:var(--t3);cursor:pointer;transition:all .15s;
}
.period-btn:hover{border-color:var(--border-s);color:var(--t1)}
.period-btn.active{background:var(--grad);border-color:transparent;color:#fff}
.pf-tab{
  padding:.45rem 1.2rem;border-radius:8px;font-size:.82rem;font-weight:700;
  background:var(--bg-card);border:2px solid var(--border);
  color:var(--t2);cursor:pointer;transition:all .18s;
}
.pf-tab:hover{border-color:var(--border-s);color:var(--t1)}
.pf-tab.active{background:var(--grad);border-color:transparent;color:#fff;box-shadow:0 2px 10px var(--glow)}
.status-tile-selected::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:#fff;opacity:.5}
.stat-card.tile-active{box-shadow:0 0 0 2px var(--acc),var(--ch)!important;transform:translateY(-2px)}

.stat-card.tile-dimmed{opacity:.38;transform:none!important;box-shadow:var(--cs)!important}
.lm-tile.selected::after{content:'✓ Selected';position:absolute;bottom:7px;right:10px;font-size:.62rem;font-weight:700;color:var(--acc);background:var(--nab);border:1px solid var(--nab2);padding:1px 7px;border-radius:20px;}
.stat-card.tile-active::after{content:'✓';position:absolute;top:6px;right:8px;font-size:.7rem;font-weight:900;color:var(--acc);}
</style>
</head>
<body>

<!-- ═══════ LANDING PAGE ══════════════════════════════════════════════ -->
<div id="landingPage" class="landing-page" style="display:none;">
  <!-- LEFT — Branding -->
  <div class="landing-left animate-fade-in">
    <div class="landing-branding">
      <div style="margin-bottom:.85rem">
        <div class="logo-icon" style="width:60px;height:60px;">
          <img src="http://sharedspaces:8086/sites/GKA/Shared%20Documents/Image%20(1).png" style="width:60px;height:60px;object-fit:cover;border-radius:15px;transform:scale(1.4);" alt="GLK">
        </div>
      </div>
      <h1 class="landing-brand-title">Salim Khoussas' Legacy...<br>GLK<br><span>Pipeline</span><br>Dashboard</h1>
      <p class="landing-brand-subtitle">Real-time bid tracking, revenue analytics, and team performance insights across your entire sales hierarchy.</p>
      <div class="landing-features">
        <div class="landing-feature">
          <div class="landing-feature-icon"><svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg></div>
          <div>
            <div class="landing-feature-title">Real-time Analytics</div>
            <div class="landing-feature-desc">Track bid trends and pipeline performance live from SharePoint</div>
          </div>
        </div>
        <div class="landing-feature">
          <div class="landing-feature-icon"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <div>
            <div class="landing-feature-title">Role-Based Access</div>
            <div class="landing-feature-desc">Head Director → Account Director → Account Manager hierarchy</div>
          </div>
        </div>
        <div class="landing-feature">
          <div class="landing-feature-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="9" y2="15"/><line x1="15" y1="6" x2="15" y2="15"/><line x1="12" y1="12" x2="12" y2="15"/></svg></div>
          <div>
            <div class="landing-feature-title">CEO-Level Analytics</div>
            <div class="landing-feature-desc">Win rates, TCV tracking, GA points and closure probability</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT — Login Card -->
  <div class="landing-right">
    <div class="landing-container">
      <div class="landing-header animate-slide-up">
        <div class="landing-logo">
          <div class="logo-icon">
           <img src="http://sharedspaces:8086/sites/GKA/Shared%20Documents/Image%20(1).png" style="width:60px;height:60px;object-fit:cover;border-radius:15px;transform:scale(1.4);" alt="GLK">
          </div>
        </div>
        <h1 class="landing-title">Welcome Back</h1>
        <p class="landing-subtitle">Sign in to access your pipeline dashboard</p>
      </div>

      <div class="landing-card animate-slide-up" style="animation-delay:.2s;">
        <div class="welcome-badge"><span class="badge-pulse"></span><span>GLK Pipeline Portal</span></div>
        <div class="landing-user-info">
          <div class="landing-avatar">
            <div class="avatar-ring"></div>
            <div class="avatar-placeholder" id="lAvatar">?</div>
          </div>
          <div class="landing-details">
            <h3 id="lName">Loading...</h3>
            <p id="lEmail">Verifying access...</p>
            <p id="lRole" class="landing-role">—</p>
          </div>
        </div>

        <div class="landing-stats-container">
          <div class="stats-grid">
            <div class="landing-stat-card">
              <div class="stat-icon-wrapper">
                <div class="stat-icon-bg"></div>
                <svg class="stat-icon" viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
              </div>
              <div class="stat-content">
                <div class="stat-label">Total Visits</div>
                <div class="stat-value" id="lVisits" style="font-size:1.1rem;font-weight:800;color:var(--sc)">--</div>
              </div>
            </div>
            <div class="landing-stat-card">
              <div class="stat-icon-wrapper">
                <div class="stat-icon-bg"></div>
                <svg class="stat-icon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="stat-content">
                <div class="stat-label">Last Visit</div>
                <div class="stat-value" id="lLastVisit" style="font-size:.85rem;font-weight:800;color:var(--sc)">--</div>
              </div>
            </div>
          </div>
          <div class="stats-secondary">
            <div class="stat-mini"><svg style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>Secure Session</span></div>
            <div class="stat-mini"><svg style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg><span>Live SharePoint</span></div>
          </div>
        </div>

        <div class="landing-actions">
          <button  type="button" id="launchBtn" class="landing-btn btn-primary-enhanced" disabled>
            <span class="btn-icon"><svg viewBox="0 0 24 24"><polyline points="5 12 19 12"/><polyline points="12 5 19 12 12 19"/></svg></span>
            <span class="btn-text">Verifying Access...</span>
            <span class="btn-shine"></span>
          </button>
          <p class="landing-note" id="accessNote">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>Please wait while we verify your permissions...</span>
          </p>
        </div>
      </div>
      <div class="landing-footer animate-fade-in" style="animation-delay:.6s;">
        <p>GLK Enterprise Pipeline Dashboard · Powered by SharePoint</p>
      </div>
    </div>
  </div>
</div>

<!-- ═══════ MAIN DASHBOARD ════════════════════════════════════════════ -->
<div class="portal-shell" id="dashboardContent" style="display:none;">
  <!-- Header -->
  <div class="header">
    <div class="logo-section">
      <div class="logo">
      <img src="http://sharedspaces:8086/sites/GKA/Shared%20Documents/Image%20(1).png" style="width:36px;height:36px;object-fit:cover;border-radius:10px;" alt="GLK">
      </div>
      <span class="header-title">GLK Pipeline Dashboard</span>
    </div>
    <div class="header-center">
      <div class="live-badge-pill"><span class="status-dot"></span><span>Live</span></div>
      <div class="date-badge">
        <svg style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span id="currentDate">Loading...</span>
      </div>
<div class="date-badge" id="dbUserBadge" style="color:var(--acc);font-weight:600;">—</div>
<div class="date-badge" id="selectionBadge" style="color:var(--acc2);font-weight:600;display:none;"></div>
    </div>
    <div class="header-actions">
      <select class="color-scheme-selector" id="colorSchemeSelector" onchange="changeTheme(event)">
        <option value="magenta">&#9670; Magenta</option>
        <option value="duralux">&#9670; Duralux</option>
      </select>
      <div class="theme-toggle" onclick="toggleTheme()" title="Light/Dark">
        <svg id="themeIcon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </div>
    </div>
  </div>

  <!-- Main Container -->
  <div class="main-container">
    <!-- Sidebar -->
    <div class="sidebar" id="sidebar" style="position:relative;">
      <div class="sidebar-toggle-btn" id="sidebarToggleBtn" onclick="toggleSidebar()" title="Toggle Sidebar">
        <svg id="sidebarToggleIcon" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/><polyline points="9 18 3 12 9 6"/></svg>
      </div>
      <div class="nav-items">
       <div class="nav-section-label">Overview</div>
<div class="nav-item active"onclick="document.getElementById('dashboard-view').style.display='block';document.getElementById('analytics-nav').style.display='none';document.getElementById('table-nav').style.display='block';document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));this.classList.add('active');">
  <div class="nav-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></div>
  <div class="nav-label">Dashboard</div>
</div><div class="nav-item" id="navAnalytics" style="display:none;" onclick="glkShowAnalytics();">
  <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg></div>
  <div class="nav-label">Portal Analytics</div>
</div>
      </div>
    </div>

    <!-- Content -->
    <div class="content">
      <div id="dashboard-view" class="dashboard-section">
<!-- PRODUCT FAMILY TABS -->
        <div id="pfTabs" style="display:flex;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap;">
          <button  type="button"onclick="selectPF('Fixed')" id="pfBtn_Fixed" class="pf-tab active">Fixed</button>
          <button  type="button" onclick="selectPF('Broadcast')" id="pfBtn_Broadcast" class="pf-tab">Broadcast</button>
          <button  type="button" onclick="selectPF('DataMena')" id="pfBtn_DataMena" class="pf-tab">DataMena</button>
          <button  type="button" onclick="selectPF('Mobile')" id="pfBtn_Mobile" class="pf-tab">Mobile</button>
        </div>
        <!-- TOP STAT TILES -->
<div class="top-stats" id="topStats" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr))"></div>
        <!-- FILTERS -->
        <div class="filters-section">
          <div class="filters-grid" id="filtersGrid"></div>
          <div class="filter-actions">
            <button type="button" class="reset-btn" onclick="resetAll()">
              <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
              Reset All Filters
            </button>
          </div>
        </div>

        <!-- HEAD DIRECTOR TILES -->
        <div id="hd-section-nav">
          <h2 class="section-title">
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Head Director Performance
            <span id="hdBadge" style="background:var(--nab);border:1px solid var(--nab2);color:var(--acc);padding:2px 10px;border-radius:20px;font-size:.75rem;font-weight:700;">0</span>
          </h2>
          <div class="hd-grid" id="hdGrid"></div>
        </div>

        <!-- ACCOUNT DIRECTOR TILES -->
        <div id="adSection" style="display:none;margin-top:1rem;">
          <h2 class="section-title">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/></svg>
            Account Directors
            <span id="adBadge" style="background:var(--nab);border:1px solid var(--nab2);color:var(--acc);padding:2px 10px;border-radius:20px;font-size:.75rem;font-weight:700;">0</span>
            <span id="adContext" style="font-size:.78rem;color:var(--t3);font-weight:400;"></span>
          </h2>
          <div class="ad-grid" id="adGrid"></div>
        </div>

        <!-- ACCOUNT MANAGER ROWS -->
        <div id="amSection" style="display:none;margin-top:1rem;" class="am-section">
          <h2 class="section-title">
            <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Account Managers
            <span id="amBadge" style="background:var(--nab);border:1px solid var(--nab2);color:var(--acc);padding:2px 10px;border-radius:20px;font-size:.75rem;font-weight:700;">0</span>
            <span id="amContext" style="font-size:.78rem;color:var(--t3);font-weight:400;"></span>
          </h2>
          <div class="manager-list" id="amList"></div>
        </div>

        <!-- CHARTS -->
        <div id="charts-nav" style="margin-top:1rem;">
          <div style="text-align:center;margin-bottom:.85rem;">
            <button type="button" class="export-btn" onclick="toggleCharts()">
              <svg id="chartsToggleIcon" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="9" y2="15"/><line x1="15" y1="6" x2="15" y2="15"/><line x1="12" y1="12" x2="12" y2="15"/></svg>
              <span id="chartsToggleText">Show Analytics Charts</span>
            </button>
          </div>
         <div id="chartsSection" style="display:none;">

            <!-- ROW 1: Revenue Trend full width -->
            <div style="display:grid;grid-template-columns:1fr;gap:.85rem;margin-bottom:.85rem;">
              <div class="chart-card">
                <div class="chart-title"><svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>Revenue Trend</div>
                <div class="chart-container" style="height:280px;"><canvas id="chartTrend"></canvas></div>
                <div id="trendControlsWrap"></div>
              </div>
            </div>

            <!-- ROW 2: Billed/Lost/Pipeline (half) | TCV by Probability donut (half) -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.85rem;margin-bottom:.85rem;">
              <div class="chart-card">
                <div class="chart-title"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Billed / Lost / Pipeline</div>
                <div class="chart-container" style="height:300px;"><canvas id="chartWinLoss"></canvas></div>
              </div>
              <div class="chart-card">
                <div class="chart-title"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 10 10"/></svg>TCV by Closure Probability</div>
                <div class="chart-container" style="height:300px;"><canvas id="chartProbTCV"></canvas></div>
              </div>
            </div>

            <!-- ROW 3: Leaderboard full width with metric toggle -->
            <div style="display:grid;grid-template-columns:1fr;gap:.85rem;margin-bottom:.85rem;">
              <div class="chart-card">
                <div class="chart-title" style="justify-content:space-between;">
                  <span style="display:flex;align-items:center;gap:.35rem;"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Leaderboard</span>
                  <div style="display:flex;gap:.35rem;" id="lbMetricToggle"></div>
                </div>
                <div id="lbControlsWrap"></div>
                <div class="chart-container" style="height:420px;"><canvas id="chartLeaderboard"></canvas></div>
              </div>
            </div>

            
         

            <!-- ROW 4: Vertical Performance (half) | MRC/GA Trend (half) -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.85rem;margin-bottom:.85rem;">
              <div class="chart-card">
                <div class="chart-title" style="justify-content:space-between;">
                  <span style="display:flex;align-items:center;gap:.35rem;"><svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Vertical Performance</span>
                  <div style="display:flex;gap:.3rem;">
                    <button type="button" id="vertBtnTCV" onclick="setVertMetric('tcv')" style="padding:.2rem .6rem;border-radius:6px;font-size:.7rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:var(--grad);color:#fff;">TCV</button>
                    <button type="button" id="vertBtnCount" onclick="setVertMetric('count')" style="padding:.2rem .6rem;border-radius:6px;font-size:.7rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:var(--bg-secondary);color:var(--t3);">Count</button>
                  </div>
                </div>
                <div class="chart-container" style="height:320px;"><canvas id="chartVertical"></canvas></div>
              </div>
              <div class="chart-card">
                <div class="chart-title"><svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg><span id="gaTrendTitle">MRC Trend</span></div>
                <div class="chart-container" style="height:280px;"><canvas id="chartGA"></canvas></div>
                <div id="gaControlsWrap"></div>
              </div>
            </div>
            <!-- ROW 5: Top Customers/Services full width -->
   <div style="display:grid;grid-template-columns:1fr;gap:.85rem;margin-bottom:.85rem;">
              <div class="chart-card">
                <div class="chart-title" style="justify-content:space-between;">
                  <span id="topChartTitle" style="display:flex;align-items:center;gap:.35rem;">
                    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    Top 10 Customers by TCV
                  </span>
                  <div style="display:flex;gap:.35rem;align-items:center;">
                    <button type="button" id="topChartBtnCust" onclick="setTopChart('customers')" style="padding:.25rem .8rem;border-radius:6px;font-size:.72rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:var(--grad);color:#fff;">Top Customers</button>
                    <button type="button" id="topChartBtnSvc" onclick="setTopChart('services')" style="padding:.25rem .8rem;border-radius:6px;font-size:.72rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:var(--bg-secondary);color:var(--t3);">Top Services</button>
                    <span id="svcSubToggle" style="display:none;gap:.35rem;">
                      <button type="button" id="svcBtnTCV" onclick="setSvcMetric('tcv')" style="padding:.25rem .7rem;border-radius:6px;font-size:.72rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:var(--grad);color:#fff;">TCV</button>
                      <button type="button" id="svcBtnBids" onclick="setSvcMetric('bids')" style="padding:.25rem .7rem;border-radius:6px;font-size:.72rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:var(--bg-secondary);color:var(--t3);">Bids</button>
                    </span>
                  </div>
                </div>
                <div class="chart-container" style="height:360px;"><canvas id="chartTopCustomers"></canvas></div>
              </div>
            </div>
          </div>
           
          </div>
        
    </div>
      <div id="analytics-nav" style="display:none;"></div>

        <!-- TABLE -->
        <div id="table-nav" class="table-section" style="margin-top:1rem;">
          <div class="table-header">
            <h3 class="table-title">
              <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Detailed Bid Records
            </h3>
            <div class="table-actions">
              <button type="button" class="export-btn" onclick="exportExcel()">
                <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export to Excel
              </button>
              <input type="text" class="search-box" id="searchInp" placeholder="Search all columns..." oninput="gridSearch(this.value)">
            </div>
          </div>
          <div id="myGrid" class="ag-theme-alpine" style="height:580px;width:100%;"></div>
        </div>

      </div><!-- /dashboard-view -->
    </div><!-- /content -->
  </div><!-- /main-container -->
</div><!-- /portal-shell -->

<!-- Developer Console Login -->
<div class="dev-console" id="devConsole" style="display:none;">
  <span class="dev-console-label">Dev Login</span>
  <input type="text" id="devEmailInput" placeholder="email@example.com" onkeydown="if(event.key==='Enter')devLogin()">
  <select id="devRoleInput" style="padding:.3rem .6rem;border-radius:6px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.75rem;">
    <option value="Admin">Admin</option>
    <option value="Head Director">Head Director</option>
    <option value="Account Director">Account Director</option>
    <option value="Account Manager">Account Manager</option>
  </select>
  <button type="button" onclick="devLogin()">Login As</button>
</div>

<script>
// ══════════════════════════════════════════════════════════════════
//  CONFIG
// ══════════════════════════════════════════════════════════════════
const SP_SITE   = 'http://sharedspaces:8086/sites/GKA';
const SP_LIST   = 'GLK Pipeline Portal';
const SP_ACCESS = 'GKLA_ACCESS';
const STATUS_WON  = ['Won','Billed'];
const STATUS_IP   = ['Lead','Opportunity','On Hold','Proposed'];
const STATUS_LOST = ['Lost','Cancelled','No Bid'];
const PROB_ORDER  = ['0%','25%','50%','75%','100%'];

// ══════════════════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════════════════
window.USER = {email:'',name:'',role:''};
let ALL_BIDS = [];
let FILTERED  = [];
let CHARTS    = {};
let GRID_API  = null;
let chartsVisible = false;
let trendPeriod='M';
let gaPeriod='M';
function selectPF(pf){
  selPF=pf;
  selStatusTile=null;
  document.querySelectorAll('.pf-tab').forEach(b=>b.classList.remove('active'));
  el('pfBtn_'+pf)?.classList.add('active');
  applyAll();
}
function setTrendPeriod(p){
  trendPeriod=p;
  ['W','M','Y'].forEach(x=>el('trendBtn'+x)?.classList.toggle('active',x===p));
  const bids=getViewBids();const c=getChartColors();renderTrend(bids,c);
}
function setGAPeriod(p){
  gaPeriod=p;
  ['W','M','Y'].forEach(x=>el('gaBtn'+x)?.classList.toggle('active',x===p));
  const bids=getViewBids();const c=getChartColors();renderGA(bids,c);
}
let selHD = null, selAD = null, selAM = null;
let selPF = 'Fixed'; // active product family tab
let selStatusTile = null; // clicked status tile filter
const PF_FAMILIES = {
  'Fixed':   v=>v==='Fixed',
  'Broadcast': v=>v==='Broadcast',
  'DataMena':  v=>v==='DataMena'||v==='Data Mena'||v==='Datamena',
  'Mobile':    v=>v==='Mobile',
};
const MOBILE_PF = 'Mobile';
// ══════════════════════════════════════════════════════════════════
//  UTILITIES
// ══════════════════════════════════════════════════════════════════
const num = v => { const n=parseFloat(v); return isNaN(n)?0:n; };
function fmt(v){
  const n=num(v);
  if(n>=1e9) return (n/1e9).toFixed(2)+'B';
  if(n>=1e6) return (n/1e6).toFixed(2)+'M';
  if(n>=1e3) return (n/1e3).toFixed(1)+'K';
  return n.toFixed(0);
}
function fmtGA(v){ const n=num(v); return n%1===0?n.toFixed(0):n.toFixed(2); }
const fmtDate = iso => { if(!iso) return '—'; const d=new Date(iso); return isNaN(d)?'—':d.toLocaleDateString('en-GB'); };
  function fmtYearImpact(v) {
  if (v === null || v === undefined) return '—';
  if (v === 0) return 'AED 0';
  if (v >= 1e6) return 'AED ' + (v / 1e6).toFixed(2) + 'M';
  if (v >= 1e3) return 'AED ' + v.toLocaleString('en-US');
  return 'AED ' + v.toFixed(0);
}

function calcYearImpact(bid) {
  const STATUS_SKIP = ['Lost', 'Cancelled', 'No Bid'];
  if (STATUS_SKIP.includes(bid.status)) return { val: null, note: null };
  if (!bid.expectedActivation) return { val: null, note: null };
  const actDate = new Date(bid.expectedActivation);
  if (isNaN(actDate)) return { val: null, note: null };
  const currentYear = new Date().getFullYear();
  const actYear = actDate.getFullYear();
  if (actYear < currentYear) return { val: null, note: null };
  if (actYear > currentYear) return { val: null, note: 'Expected activation in ' + actYear + ' — cannot calculate this year' };
  const monthsRemaining = 12 - actDate.getMonth();
  const impact = bid.mrc * monthsRemaining;
  return { val: impact, note: null };
}
function getInitials(name){ if(!name) return '?'; const p=name.trim().split(' '); return p.length>=2?(p[0][0]+p[p.length-1][0]).toUpperCase():name[0].toUpperCase(); }
function getRelevantDate(bid){
  const s=bid.status;
  if(s==='Won') return bid.contractSigned;
  if(s==='Billed') return bid.billedDate;
  if(STATUS_IP.includes(s)) return bid.expectedActivation;
  if(STATUS_LOST.includes(s)) return bid.lostDate;
  return bid.proposedDate||bid.contractSigned;
}
const getQuarter = d => 'Q'+Math.ceil((new Date(d).getMonth()+1)/3);
function getWeekOfYear(date){ const d=new Date(date); d.setHours(0,0,0,0); d.setDate(d.getDate()+3-(d.getDay()+6)%7); const w1=new Date(d.getFullYear(),0,4); return 1+Math.round(((d-w1)/864e5-3+(w1.getDay()+6)%7)/7); }
function getVisitCount(){ try{ return parseInt(localStorage.getItem('glk_vc_'+USER.email)||'0'); }catch(e){return 0;} }
function incVisit(){ try{ const c=getVisitCount()+1; localStorage.setItem('glk_vc_'+USER.email,c); return c; }catch(e){return 1;} }
function getLastVisit(){
  try{
    const lv=localStorage.getItem('glk_lv_'+USER.email);
    if(!lv) return 'First visit';
    const diff=Date.now()-new Date(lv).getTime();
    const m=Math.floor(diff/6e4),h=Math.floor(diff/36e5),day=Math.floor(diff/864e5);
    if(m<60) return m+'m ago'; if(h<24) return h+'h ago'; if(day<7) return day+'d ago';
    return new Date(lv).toLocaleDateString('en-GB');
  }catch(e){ return '—'; }
}
function saveLastVisit(){ try{ localStorage.setItem('glk_lv_'+USER.email,new Date().toISOString()); }catch(e){} }
function el(id){ return document.getElementById(id); }
function set(id,val){ const e=el(id); if(e) e.textContent=val; }



// ══════════════════════════════════════════════════════════════════
//  SHAREPOINT FETCH
// ══════════════════════════════════════════════════════════════════
function spGet(url,cb){
  const xhr=new XMLHttpRequest();
  xhr.open('GET',url,true);
  xhr.setRequestHeader('Accept','application/json;odata=verbose');
  xhr.onreadystatechange=function(){
    if(xhr.readyState!==4) return;
    if(xhr.status>=200&&xhr.status<300){ try{ cb(null,JSON.parse(xhr.responseText)); }catch(e){ cb(e,null); } }
    else { cb(new Error('HTTP '+xhr.status),null); }
  };
  xhr.onerror=function(){ cb(new Error('Network error'),null); };
  xhr.send();
}

// ══════════════════════════════════════════════════════════════════
//  ACCESS CONTROL
// ══════════════════════════════════════════════════════════════════
function initAccess(){
  spGet(SP_SITE+'/_api/web/currentuser?$select=Title,Email',function(err,data){
    if(err){ showDenied('Cannot reach SharePoint'); return; }
    USER.email=data.d.Email; USER.name=data.d.Title;
    spGet(SP_SITE+"/_api/web/lists/getbytitle('"+SP_ACCESS+"')/items?$select=UserEmailID,Role&$filter=UserEmailID eq '"+USER.email+"'",function(err2,data2){
if(err2||!data2.d.results.length){ 
    showDenied('You are not authorised. Contact tehleel.lone@du.ae');
    return; 
}
const role=(data2.d.results[0].Role||'').trim();
const ALLOWED=['Admin','CEO','Head Director','Account Director','Account Manager','Viewer'];
if(!ALLOWED.includes(role)){
    showDenied('Your role "'+role+'" has no access. Contact tehleel.lone@du.ae');
    return;
}
USER.role=role;
      console.log('[GLK] Role:', JSON.stringify(data2.d.results[0]));
      populateLanding();
    });
  });
}
function showDenied(msg){
  set('lName','Access Denied'); set('lEmail',msg); set('lRole','No Access');
  el('accessNote').innerHTML='<svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:#dc2626;fill:none;stroke-width:2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg><span style="color:#dc2626;">'+msg+'</span>';
}
function populateLanding(){
  el('lAvatar').textContent=getInitials(USER.name);
  set('lName',USER.name); set('lEmail',USER.email); set('lRole',USER.role);
  set('lVisits',getVisitCount()); set('lLastVisit',getLastVisit());
  const btn=el('launchBtn');
  btn.disabled=false;
  btn.innerHTML='<span class="btn-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span><span class="btn-text">Launch Dashboard</span><span class="btn-shine"></span>';
  btn.onclick=launchDashboard;
  el('accessNote').innerHTML='<svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:#16a34a;fill:none;stroke-width:2"><polyline points="20 6 9 17 4 12"/></svg><span style="color:#16a34a;font-weight:600;">Access granted — click above to proceed</span>';
}
function launchDashboard(){
  incVisit(); saveLastVisit();
document.getElementById('landingPage').style.cssText='display:none!important';
el('dashboardContent').style.display='flex';
el('dashboardContent').style.flexDirection='column';
  set('dbUserBadge',USER.name+' · '+USER.role);
  // Role-based UI visibility
  const role=USER.role;
  
  // Portal Intelligence — Admin, HD, AD only
  if(role==='Admin'||role==='CEO'||role==='Head Director'||role==='Account Director'){
    el('navAnalytics').style.display='flex';
  }
  
  // HD section — hide completely for AD and AM
  if(role==='Account Director'||role==='Account Manager'||role==='Viewer'){
    el('hd-section-nav').style.display='none';
  }
  

  el('currentDate').textContent=new Date().toLocaleDateString('en-US',{weekday:'short',year:'numeric',month:'short',day:'numeric'});
  loadData();
if(typeof glkStartSession === 'function') glkStartSession();
setTimeout(function(){
    if(USER.role==='Admin'||USER.role==='CEO'||USER.role.toLowerCase().includes('admin')){
        document.getElementById('navAnalytics').style.display='flex';
    }
}, 500);
  // restore saved theme
  try{
    const bt=localStorage.getItem('glk_base_theme')||'magenta';
    const dm=localStorage.getItem('glk_dark_mode')==='true';
    const sel=el('colorSchemeSelector'); if(sel) sel.value=bt;
    applyTheme(bt,dm);
  }catch(e){}

    
    
    setTimeout(function(){
    if(USER.email.toLowerCase()==='tehleel.lone@du.ae') glkInitViewAs();
  },1500);
}

function glkInitViewAs(){
  if(document.getElementById('viewAsPanel')) return;
  if(USER.email.toLowerCase()!=='tehleel.lone@du.ae') return;
  const panel=document.createElement('div');
  panel.id='viewAsPanel';
  panel.style.cssText='position:fixed;bottom:16px;left:16px;z-index:999999;background:var(--bg-card);border:2px solid var(--border-s);border-radius:14px;padding:12px 16px;box-shadow:0 8px 32px rgba(0,0,0,0.35);font-family:Inter,sans-serif;font-size:.78rem;min-width:320px;';
  panel.innerHTML=`
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
      <div style="font-weight:800;font-size:.82rem;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
        🔍 View As &nbsp;<span style="font-size:.65rem;background:rgba(168,85,247,.15);border:1px solid rgba(168,85,247,.4);color:var(--acc);padding:2px 8px;border-radius:20px;font-weight:700;-webkit-text-fill-color:var(--acc);">ADMIN ONLY</span>
      </div>
      <div onclick="document.getElementById('viewAsPanel').classList.toggle('va-collapsed')" style="cursor:pointer;width:22px;height:22px;border-radius:50%;border:1px solid var(--border);background:var(--bg-secondary);display:flex;align-items:center;justify-content:center;font-size:.7rem;color:var(--t3);">▼</div>
    </div>
    <div id="vaBody">
      <div id="vaCurrentUser" style="font-size:.72rem;color:var(--t3);padding:6px 10px;background:var(--bg-secondary);border-radius:7px;border:1px solid var(--border);margin-bottom:8px;">
        Viewing as: <strong style="color:var(--acc)">${USER.email}</strong> · <strong style="color:var(--acc)">${USER.role}</strong>
      </div>
      <div style="display:flex;gap:.5rem;margin-bottom:8px;">
        <input type="text" id="vaEmailInput" placeholder="email@du.ae"
          style="flex:1;padding:.4rem .7rem;border-radius:8px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.78rem;font-family:inherit;"
          onkeydown="if(event.key==='Enter')glkViewAs()">
        <select id="vaRoleOverride"
          style="padding:.4rem .6rem;border-radius:8px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.78rem;font-family:inherit;">
          <option value="">Auto</option>
          <option value="Admin">Admin</option>
          <option value="Viewer">Viewer</option>
          <option value="Head Director">Head Director</option>
          <option value="Account Director">Account Director</option>
          <option value="Account Manager">Account Manager</option>
        </select>
      </div>
      <div style="display:flex;gap:.5rem;margin-bottom:6px;">
        <button onclick="glkViewAs()" style="flex:1;padding:.4rem 1rem;border-radius:8px;background:var(--grad);color:#fff;border:none;font-size:.78rem;font-weight:700;cursor:pointer;font-family:inherit;">Apply View</button>
      </div>
      <button id="vaRestoreBtn" onclick="glkRestoreMyView()"
        style="display:none;width:100%;margin-top:4px;padding:.38rem;border-radius:8px;background:var(--bg-secondary);color:var(--t2);border:1px solid var(--border);font-size:.76rem;font-weight:700;cursor:pointer;font-family:inherit;text-align:center;">
        ↩ Restore My View (${USER.email})
      </button>
      <div id="vaLog" style="margin-top:8px;font-size:.68rem;color:var(--t3);max-height:50px;overflow-y:auto;"></div>
    </div>`;
  document.body.appendChild(panel);
  const s=document.createElement('style');
  s.innerHTML='#viewAsPanel.va-collapsed #vaBody{display:none}';
  document.head.appendChild(s);
}

let _realUser=null;

function glkViewAs(){
  const email=(document.getElementById('vaEmailInput').value||'').trim();
  const roleOv=document.getElementById('vaRoleOverride').value;
  if(!email){document.getElementById('vaLog').innerHTML='⚠ Enter an email';return;}

  document.getElementById('vaLog').innerHTML='⏳ Looking up '+email+'...';
  if(!_realUser) _realUser={email:USER.email,name:USER.name,role:USER.role};

  // Step 1: Get real display name from SharePoint
  spGet(SP_SITE+"/_api/web/siteusers?$filter=Email eq '"+email+"'&$select=Title,Email",
    function(err,userData){
      const resolvedName=(!err&&userData.d.results.length)
        ?userData.d.results[0].Title
        :email.split('@')[0].replace(/\./g,' ').replace(/\b\w/g,c=>c.toUpperCase());

      // Step 2: Get role from access list
      spGet(SP_SITE+"/_api/web/lists/getbytitle('"+SP_ACCESS+"')/items?$select=UserEmailID,Role&$filter=UserEmailID eq '"+email+"'",
        function(err2,data){
          let role=roleOv;
          if(!err2&&data.d.results.length){
            role=(data.d.results[0].Role||'').trim();
            document.getElementById('vaLog').innerHTML='✓ Found: '+resolvedName+' · '+role;
          } else if(!role){
            document.getElementById('vaLog').innerHTML='⚠ Not in access list. Select role manually.';
            return;
          }

          USER.email=email;
          USER.name=resolvedName;
          USER.role=role;

          el('dashboardContent').style.cssText='display:none!important';
          el('landingPage').style.cssText='display:flex!important';
          el('lAvatar').textContent=getInitials(resolvedName);
          set('lName',resolvedName);
          set('lEmail',email);
          set('lRole',role+' (Spoofed)');
          set('lVisits',getVisitCount());
          set('lLastVisit',getLastVisit());

          const btn=el('launchBtn');
          btn.disabled=false;
          btn.innerHTML='<span class="btn-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span><span class="btn-text">Launch as '+resolvedName+'</span><span class="btn-shine"></span>';
          btn.onclick=function(){glkLaunchSpoofed();};
          el('accessNote').innerHTML='<svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:#f97316;fill:none;stroke-width:2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><span style="color:#f97316;font-weight:600;">👁 Spoofed as '+resolvedName+'</span>';
          document.getElementById('vaLog').innerHTML='✓ Ready. Click Launch to enter as '+resolvedName+' ('+role+')';
        }
      );
    }
  );
}function glkRestoreMyView(){
  if(!_realUser) return;
  USER.email=_realUser.email;
  USER.name=_realUser.name;
  USER.role=_realUser.role;

  // Go back to landing as real user
  el('dashboardContent').style.cssText='display:none!important';
  el('landingPage').style.cssText='display:flex!important';

  el('lAvatar').textContent=getInitials(USER.name);
  set('lName',USER.name);
  set('lEmail',USER.email);
  set('lRole',USER.role);
  set('lVisits',getVisitCount());
  set('lLastVisit',getLastVisit());

  const btn=el('launchBtn');
  btn.disabled=false;
  btn.innerHTML='<span class="btn-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span><span class="btn-text">Launch Dashboard</span><span class="btn-shine"></span>';
  btn.onclick=launchDashboard;
  el('accessNote').innerHTML='<svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:#16a34a;fill:none;stroke-width:2"><polyline points="20 6 9 17 4 12"/></svg><span style="color:#16a34a;font-weight:600;">Access granted — click above to proceed</span>';

  el('vaRestoreBtn').style.display='none';
  el('vaCurrentUser').innerHTML='Viewing as: <strong style="color:var(--acc)">'+USER.email+'</strong> · <strong style="color:var(--acc)">'+USER.role+'</strong>';
  document.getElementById('vaLog').innerHTML='↩ Restored to '+USER.email;
}
function glkLaunchSpoofed(){
  incVisit(); saveLastVisit();
  el('landingPage').style.cssText='display:none!important';
  el('dashboardContent').style.display='flex';
  el('dashboardContent').style.flexDirection='column';
  
  set('dbUserBadge','👁 '+USER.name+' · '+USER.role+' (Spoofed)');
  el('dbUserBadge').style.color='#f97316';
  el('dbUserBadge').style.fontWeight='800';

  el('currentDate').textContent=new Date().toLocaleDateString('en-US',{weekday:'short',year:'numeric',month:'short',day:'numeric'});

  // Apply role-based UI for spoofed user
  glkApplyRoleUI();

  // Restore theme
  try{
    const bt=localStorage.getItem('glk_base_theme')||'magenta';
    const dm=localStorage.getItem('glk_dark_mode')==='true';
    const sel=el('colorSchemeSelector'); if(sel) sel.value=bt;
    applyTheme(bt,dm);
  }catch(e){}

  // Reset and rebuild everything scoped to spoofed user
  resetAll();
  buildFilters();
  applyRoleLocks();
  applyAll();

  // Re-show the View-As panel with restore button visible
  setTimeout(function(){
    const cur=el('vaCurrentUser');
    if(cur) cur.innerHTML='👁 Spoofed: <strong style="color:#f97316">'+USER.email+'</strong> · <strong style="color:#f97316">'+USER.role+'</strong>';
    const rb=el('vaRestoreBtn');
    if(rb) rb.style.display='block';
  },200);
}
function glkApplyRoleUI(){
  const role=USER.role;
  const na=el('navAnalytics');
  if(na) na.style.display=(role==='Admin'||role==='CEO'||role==='Head Director'||role==='Account Director')?'flex':'none';
  const hds=el('hd-section-nav');
  if(hds) hds.style.display=(role==='Account Director'||role==='Account Manager'||role==='Viewer')?'none':'block';
  const pft=el('pfTabs');
  if(pft) pft.style.display='flex';
}
// ══════════════════════════════════════════════════════════════════
//  DEV CONSOLE — login as any email
// ══════════════════════════════════════════════════════════════════
// Activate with: Ctrl+Shift+D
document.addEventListener('keydown',function(e){
  if(e.ctrlKey&&e.shiftKey&&e.key==='D'){
    const dc=el('devConsole'); dc.style.display=dc.style.display==='none'?'flex':'none';
  }
});
function devLogin(){
  const email=el('devEmailInput').value.trim();
  if(!email){ alert('Enter an email'); return; }
  USER.email=email;
  USER.name=email.split('@')[0].replace(/\./g,' ').replace(/\b\w/g,c=>c.toUpperCase());
USER.role=el('devRoleInput').value.trim()||'Admin';  el('devConsole').style.display='none';
  // Bypass SP and launch directly
  el('lAvatar').textContent=getInitials(USER.name);
  set('lName',USER.name); set('lEmail',USER.email); set('lRole',USER.role+' (Dev)');
  set('lVisits',getVisitCount()); set('lLastVisit',getLastVisit());
  const btn=el('launchBtn');
  btn.disabled=false;
  btn.innerHTML='<span class="btn-text">Launch Dashboard (Dev)</span>';
  btn.onclick=launchDashboard;
  el('landingPage').style.display='flex';
  console.log('[DEV] Logged in as:',USER.email);
}
// Also expose as console function: window.loginAs('email@x.com')
window.loginAs=function(email,role){
  el('devEmailInput').value=email;
  if(role) USER.role=role;
  devLogin();
};

// ══════════════════════════════════════════════════════════════════
//  LOAD DATA
// ══════════════════════════════════════════════════════════════════
function loadData(){
  const select=[
    'Id','Title','Type_x0020_of_x0020_Request','Type_x0020_of_x0020_Contract',
    'Segment','Account_x0020_Director','Solution_x0020_Manager','Head_x0020_Director',
    'Product_x0020_Family','Product_x0020_Category','Services','Gross_x0020_Adds',
    'Monthly_x0020_Recurring_x0020_Ch','One_x0020_Time_x0020_Charges_x00',
    'Contract_x0020_Duration','Total_x0020_Contact_x0020_Value_','Opportunity_x0020_Status',
    'Closure_x0020_Probability','Expected_x0020_Contract_x0020_Si','Actual_x0020_Contract_x0020_Sign',
    'Proposed_x0020_Date','No_x0020_Bid_x002f_Lost_x002f_Ca','BilledDate','Lost_x0020_Reason',
    'CustomerCode','Complexity','BidManager','ProjectManager0','field5','field8',
    'group/Title','group/EMail'
  ].join(',');

  const cutoff=new Date('2025-01-01T00:00:00Z');
  let allResults=[];

  function fetchPage(url){
    spGet(url,function(err,data){
      if(err){
        console.error('Data load error:',err);
        ALL_BIDS=[];
        remapBlankHD();
        buildFilters();
        applyAll();
        return;
      }
      allResults=allResults.concat(data.d.results);
      console.log('[GLK] Fetched so far:',allResults.length);
      if(data.d.__next){
        fetchPage(data.d.__next);
      } else {
        console.log('[GLK] All records loaded:',allResults.length);
        ALL_BIDS=allResults.map(mapItem).filter(function(bid){
          const rd=getRelevantDate(bid); if(!rd) return false;
          const d=new Date(rd); return !isNaN(d)&&d>=cutoff;
        });
        remapBlankHD();
        buildFilters();
        applyAll();
      }
    });
  }

  const firstUrl=SP_SITE+
    "/_api/web/lists/getbytitle('"+SP_LIST+"')/items"+
    "?$select="+encodeURIComponent(select)+
    "&$expand=group"+
    "&$filter=Expected_x0020_Contract_x0020_Si ge '2025-01-01T00:00:00Z' or "+
    "Actual_x0020_Contract_x0020_Sign ge '2025-01-01T00:00:00Z' or "+
    "Proposed_x0020_Date ge '2025-01-01T00:00:00Z' or "+
    "No_x0020_Bid_x002f_Lost_x002f_Ca ge '2025-01-01T00:00:00Z' or "+
    "BilledDate ge '2025-01-01T00:00:00Z'"+
    "&$top=5000&$orderby=Id asc";

  fetchPage(firstUrl);
}function mapItem(it){
  return {
    id:it.Id,customerName:it.Title||'—',typeOfRequest:it.Type_x0020_of_x0020_Request||'—',
    typeOfContract:it.Type_x0020_of_x0020_Contract||'—',vertical:it.Segment||'—',
    accountDirector:it.Account_x0020_Director||'—',solutionManager:it.Solution_x0020_Manager||'—',
   headDirector:it.Head_x0020_Director||'(Blank)',productFamily:it.Product_x0020_Family||'—',
    productCategory:it.Product_x0020_Category||'—',services:it.Services||'—',
    gaPoints:num(it.Gross_x0020_Adds),mrc:num(it.Monthly_x0020_Recurring_x0020_Ch),
    otc:num(it.One_x0020_Time_x0020_Charges_x00),duration:it.Contract_x0020_Duration||'—',
    tcv:num(it.Total_x0020_Contact_x0020_Value_),status:it.Opportunity_x0020_Status||'—',
    closureProb:it.Closure_x0020_Probability||'—',
    expectedActivation:it.Expected_x0020_Contract_x0020_Si||null,
    contractSigned:it.Actual_x0020_Contract_x0020_Sign||null,
    proposedDate:it.Proposed_x0020_Date||null,lostDate:it.No_x0020_Bid_x002f_Lost_x002f_Ca||null,
    billedDate:it.BilledDate||null,lostReason:it.Lost_x0020_Reason||'—',
    customerCode:it.CustomerCode||'—',complexity:it.Complexity||'—',
    bidManager:it.BidManager||'—',projectManager:it.ProjectManager0||'—',
    pcv:num(it.field5),prepaidPostpaid:it.field8||'—',
    amName:it.group?(it.group.Title||'—'):'—',amEmail:it.group?(it.group.EMail||''):'',
  };
}

// ══════════════════════════════════════════════════════════════════
//  FILTERS
// ══════════════════════════════════════════════════════════════════
const FILTER_DEFS=[
  {key:'typeOfRequest',label:'Type of Request'},
  {key:'typeOfContract',label:'Type of Contract'},
  {key:'vertical',label:'Vertical'},
  {key:'status',label:'Opp. Status'},
  {key:'_year',label:'Year'},
  {key:'_quarter',label:'Quarter'},
  {key:'_month',label:'Month'},
];
const MONTH_NAMES=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

function getBidMeta(bid){
  const rd=getRelevantDate(bid); const d=rd?new Date(rd):null;
  return {
    _year:d&&!isNaN(d)?String(d.getFullYear()):null,
    _quarter:d&&!isNaN(d)?getQuarter(rd):null,
    _month:d&&!isNaN(d)?String(d.getMonth()):null,
  };
}
function getFilterVals(key){
  if(key==='_year') return [...new Set(ALL_BIDS.map(b=>{const rd=getRelevantDate(b);const d=rd?new Date(rd):null;return d&&!isNaN(d)?String(d.getFullYear()):null;}).filter(Boolean))].sort();
  if(key==='_quarter') return ['Q1','Q2','Q3','Q4'];
  if(key==='_month') return MONTH_NAMES.map((_,i)=>String(i));
  if(key==='closureProb') return PROB_ORDER;
return [...new Set(ALL_BIDS.map(b=>b[key]).filter(Boolean))].sort();
}
function remapBlankHD(){
  const STATUS_ONGOING=['Lead','Opportunity','On Hold','Proposed'];

  // Step 1: Build AD -> HD map from bids that have a real (non-blank) HD
  const adToHD={};
  ALL_BIDS.forEach(function(b){
    if(b.headDirector&&b.headDirector!=='(Blank)'&&b.headDirector!=='—'&&b.accountDirector&&b.accountDirector!=='—'){
      adToHD[b.accountDirector]=b.headDirector;
    }
  });

  // Step 2: Process blank HD bids
  const remapped=[];
  ALL_BIDS.forEach(function(b){
    if(b.headDirector!=='(Blank)'){
      remapped.push(b); // normal bid, keep as is
      return;
    }
    // Blank HD bid
    if(!STATUS_ONGOING.includes(b.status)){
      // Closed bid with blank HD -> discard completely
      return;
    }
    // Ongoing bid with blank HD -> try to remap
    const realHD=adToHD[b.accountDirector];
    if(!realHD){
      // AD has no known HD mapping -> discard
      return;
    }
    // Reassign HD and keep
    remapped.push(Object.assign({},b,{headDirector:realHD}));
  });

  ALL_BIDS=remapped;
}
function buildFilters(){
  const grid=el('filtersGrid'); grid.innerHTML='';
  const lockedKeys=new Set();
  if(USER.role==='Head Director') lockedKeys.add('headDirector');
  if(USER.role==='Account Director'){lockedKeys.add('headDirector');lockedKeys.add('accountDirector');}
  if(USER.role==='Account Manager'){lockedKeys.add('headDirector');lockedKeys.add('accountDirector');lockedKeys.add('amName');}

  FILTER_DEFS.forEach(function(fd){
    const isLocked=lockedKeys.has(fd.key);
    const div=document.createElement('div'); div.className='filter-group';
    div.innerHTML='<div class="filter-label">'+fd.label+'</div>';
    const wrap=document.createElement('div'); wrap.className='ms-wrap'; wrap.id='ms_'+fd.key;
    const trig=document.createElement('div'); trig.className='ms-trigger'; trig.id='mst_'+fd.key;
    if(isLocked) trig.style.opacity='.5';
    trig.innerHTML='<span id="mstext_'+fd.key+'">All</span><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>';
    if(!isLocked) trig.onclick=function(e){e.stopPropagation();toggleMs(fd.key);};
    const drop=document.createElement('div'); drop.className='ms-dropdown'; drop.id='msd_'+fd.key;
    getFilterVals(fd.key).forEach(function(v){
      if(!v||v==='—'||v==='All') return;
      const label=fd.key==='_month'?MONTH_NAMES[+v]:v;
      const opt=document.createElement('div'); opt.className='ms-option';
      const cid='cb_'+fd.key+'_'+v.toString().replace(/[^a-zA-Z0-9]/g,'_');
      opt.innerHTML='<input type="checkbox" id="'+cid+'" value="'+v+'" onchange="onFilterChange(\''+fd.key+'\')"><label for="'+cid+'">'+label+'</label>';
      drop.appendChild(opt);
    });
    wrap.appendChild(trig); wrap.appendChild(drop); div.appendChild(wrap); grid.appendChild(div);
  });
  applyRoleLocks();
}
function applyRoleLocks(){
  if(USER.role==='Viewer'||USER.role==='Admin'||USER.role==='CEO') return;
  
  if(USER.role==='Head Director'){
    const v=findMyHD();
    if(!v){preSelectAndLock('headDirector',['__NOACCESS__']);return;}
    preSelectAndLock('headDirector',[v]);
  }
  
  if(USER.role==='Account Director'){
    const v=findMyAD();
    if(!v){preSelectAndLock('accountDirector',['__NOACCESS__']);return;}
    const hd=[...new Set(ALL_BIDS.filter(b=>b.accountDirector===v).map(b=>b.headDirector))];
    preSelectAndLock('headDirector',hd);
    preSelectAndLock('accountDirector',[v]);
  }
  
if(USER.role==='Account Manager'){
    let amBids=ALL_BIDS.filter(b=>b.amEmail&&b.amEmail.toLowerCase()===USER.email.toLowerCase());
    if(!amBids.length&&USER.name) amBids=ALL_BIDS.filter(b=>b.amName&&b.amName.toLowerCase()===USER.name.toLowerCase());
    if(!amBids.length){preSelectAndLock('amName',['__NOACCESS__']);return;}
    const amName=amBids[0].amName;
    preSelectAndLock('headDirector',[...new Set(amBids.map(b=>b.headDirector))]);
    preSelectAndLock('accountDirector',[...new Set(amBids.map(b=>b.accountDirector))]);
    preSelectAndLock('amName',[amName]);
  }
}
function findMyHD(){ 
  const name=USER.name.toLowerCase().trim();
  const d=ALL_BIDS.find(b=>b.headDirector&&(
    b.headDirector.toLowerCase().trim()===name||
    b.headDirector.toLowerCase().includes(name)||
    name.includes(b.headDirector.toLowerCase().trim())
  ));
  return d?d.headDirector:null; 
}
function findMyAD(){ 
  const name=USER.name.toLowerCase().trim();
  const d=ALL_BIDS.find(b=>b.accountDirector&&(
    b.accountDirector.toLowerCase().trim()===name||
    b.accountDirector.toLowerCase().includes(name)||
    name.includes(b.accountDirector.toLowerCase().trim())
  ));
  return d?d.accountDirector:null; 
}
function preSelectAndLock(key,values){
  const drop=el('msd_'+key); if(!drop) return;
  drop.querySelectorAll('input[type=checkbox]').forEach(function(cb){cb.checked=values.includes(cb.value);cb.disabled=true;});
  updateMsText(key);
}
function toggleMs(key){
  const drop=el('msd_'+key),trig=el('mst_'+key);
  const isOpen=drop.classList.contains('open');
  document.querySelectorAll('.ms-dropdown.open').forEach(d=>{
    d.classList.remove('open');
    const t=el('mst_'+d.id.replace('msd_',''));
    if(t) t.classList.remove('open');
  });
  if(!isOpen){
    const rect=trig.getBoundingClientRect();
    drop.style.top=(rect.bottom+4)+'px';
    drop.style.left=rect.left+'px';
    drop.style.width=Math.max(rect.width,180)+'px';
    drop.classList.add('open');
    trig.classList.add('open');
  }
}
document.addEventListener('click',function(){ document.querySelectorAll('.ms-dropdown.open').forEach(function(d){ d.classList.remove('open'); const t=el('mst_'+d.id.replace('msd_','')); if(t) t.classList.remove('open'); }); });
window.addEventListener('scroll', function(){
  document.querySelectorAll('.ms-dropdown.open').forEach(function(d){
    const key=d.id.replace('msd_','');
    const trig=el('mst_'+key);
    if(trig){const rect=trig.getBoundingClientRect();d.style.top=(rect.bottom+4)+'px';d.style.left=rect.left+'px';}
  });
}, true);
window.addEventListener('resize', function(){
  document.querySelectorAll('.ms-dropdown.open').forEach(function(d){
    const key=d.id.replace('msd_','');
    const trig=el('mst_'+key);
    if(trig){const rect=trig.getBoundingClientRect();d.style.top=(rect.bottom+4)+'px';d.style.left=rect.left+'px';}
  });
});
function getChecked(key){ const drop=el('msd_'+key); if(!drop) return []; return Array.from(drop.querySelectorAll('input:checked')).map(c=>c.value); }
function updateMsText(key){
  const checked=getChecked(key); const e=el('mstext_'+key); if(!e) return;
  if(!checked.length) e.textContent='All';
  else if(checked.length===1) e.textContent=key==='_month'?MONTH_NAMES[+checked[0]]:checked[0];
  else e.textContent=checked.length+' selected';
}
function onFilterChange(key){
  updateMsText(key);
  // Cascade: year change resets quarter+month; quarter change resets month
  if(key==='_year'){
    clearFilter('_quarter');
    clearFilter('_month');
    rebuildQuarterMonth();
  } else if(key==='_quarter'){
    clearFilter('_month');
    rebuildQuarterMonth();
  }
  applyAll();
}
function rebuildQuarterMonth(){
  const selYears=getChecked('_year');
  const selQuarters=getChecked('_quarter');
  // Filter available months based on selected years+quarters
  const available=ALL_BIDS.filter(b=>{
    const rd=getRelevantDate(b); const d=rd?new Date(rd):null; if(!d||isNaN(d)) return false;
    const yr=String(d.getFullYear());
    const qr='Q'+Math.ceil((d.getMonth()+1)/3);
    if(selYears.length&&!selYears.includes(yr)) return false;
    if(selQuarters.length&&!selQuarters.includes(qr)) return false;
    return true;
  });
  const availMonths=new Set(available.map(b=>{const rd=getRelevantDate(b);const d=rd?new Date(rd):null;return d&&!isNaN(d)?String(d.getMonth()):null;}).filter(Boolean));
  const drop=el('msd__month'); if(!drop) return;
  drop.querySelectorAll('input[type=checkbox]').forEach(cb=>{
    const inScope=availMonths.has(cb.value);
    cb.parentElement.style.opacity=inScope?'1':'0.35';
    cb.parentElement.style.pointerEvents=inScope?'auto':'none';
    if(!inScope) cb.checked=false;
  });
  updateMsText('_month');
}
function clearFilter(key){ const drop=el('msd_'+key); if(!drop) return; drop.querySelectorAll('input:not([disabled])').forEach(c=>c.checked=false); updateMsText(key); }

// ══════════════════════════════════════════════════════════════════
//  APPLY ALL
// ══════════════════════════════════════════════════════════════════
function applyAll(){
  const filters={};
  FILTER_DEFS.forEach(function(fd){ filters[fd.key]=getChecked(fd.key); });
FILTERED=ALL_BIDS.filter(function(bid){
    const meta=getBidMeta(bid);
    for(const fd of FILTER_DEFS){
      const vals=filters[fd.key]; if(!vals.length) continue;
      const bidVal=fd.key.startsWith('_')?meta[fd.key]:bid[fd.key];
      if(!vals.includes(bidVal)) return false;
    }
    return true;
  });

  // Hard-scope FILTERED by role regardless of filter dropdowns
  if(USER.role==='Head Director'){
    const myHD=findMyHD();
    if(myHD) FILTERED=FILTERED.filter(b=>b.headDirector===myHD);
  }
  if(USER.role==='Account Director'){
    const myAD=findMyAD();
    if(myAD) FILTERED=FILTERED.filter(b=>b.accountDirector===myAD);
  }
  if(USER.role==='Account Manager'){
    const byEmail=FILTERED.filter(b=>b.amEmail&&b.amEmail.toLowerCase()===USER.email.toLowerCase());
    FILTERED=byEmail.length?byEmail:FILTERED.filter(b=>b.amName&&b.amName.toLowerCase()===USER.name.toLowerCase());
  }
updateTopStats();

// For Account Manager role
  if(USER.role==='Account Manager'){
    el('hd-section-nav').style.display='none';
    el('adSection').style.display='none';
    renderAMTile();
    return;
  }

  // For Account Director role — skip HD tiles, show only their AD tile
  if(USER.role==='Account Director'){
    el('hd-section-nav').style.display='none';
    const myAD=findMyAD();
    if(myAD){
      const myHD=ALL_BIDS.find(b=>b.accountDirector===myAD);
      if(myHD) selHD=myHD.headDirector;
    }
    renderADTiles(selHD);
    el('adSection').style.display='block';
    if(selAD){ renderAMRows(selAD); el('amSection').style.display='block'; }
    else { el('amSection').style.display='none'; }
    renderCharts();
    renderGrid();
    return;
  }

  renderHDTiles();
  if(selHD){ renderADTiles(selHD); el('adSection').style.display='block'; }
  else { el('adSection').style.display='none'; }
  if(selAD){ renderAMRows(selAD); el('amSection').style.display='block'; }
  else { el('amSection').style.display='none'; }
  renderCharts();
  renderGrid();
}
function renderAMTile(){
  el('amSection').style.display='block';
  set('amContext','');

  // Get this AM's bids
  let amBids=FILTERED.filter(b=>b.amEmail&&b.amEmail.toLowerCase()===USER.email.toLowerCase());
  if(!amBids.length && USER.name){
    amBids=FILTERED.filter(b=>b.amName&&b.amName.toLowerCase()===USER.name.toLowerCase());
  }

  // Apply PF filter
  const pfTest=PF_FAMILIES[selPF];
  if(pfTest) amBids=amBids.filter(b=>pfTest(b.productFamily));

  const isMobile=selPF===MOBILE_PF;
  const s=buildTileStats(amBids,amBids);
  const billed=amBids.filter(b=>b.status==='Billed');
  const won=amBids.filter(b=>b.status==='Won');
  const lost=amBids.filter(b=>STATUS_LOST.includes(b.status));
  const ip=amBids.filter(b=>STATUS_IP.includes(b.status));
  const mainLabel=isMobile?'GA':'MRC';
  const mainVal=isMobile?fmtGA(s.ga):fmt(amBids.reduce((sum,b)=>sum+b.mrc,0));
  const verticals=[...new Set(amBids.map(b=>b.vertical).filter(v=>v&&v!=='—'))].join(', ');

  set('amBadge','1');

  const list=el('amList');
  list.innerHTML=`
    <div class="manager-row selected" style="cursor:default;">
      <div class="rank-badge rank-1">★</div>
      <div class="manager-name-col">
        <div class="manager-name">${USER.name}</div>
        <div class="manager-tag">Account Manager</div>
        <div style="font-size:.65rem;color:var(--t3);margin-top:.2rem;">${verticals||'—'}</div>
      </div>
      <div class="stat-col"><div class="stat-label">Opps</div><div class="stat-value">${s.total}</div></div>
      <div class="stat-col"><div class="stat-label">Billed</div><div class="stat-value" style="color:#16a34a">${billed.length}</div></div>
      <div class="stat-col"><div class="stat-label">Won</div><div class="stat-value" style="color:#16a34a">${won.length}</div></div>
      <div class="stat-col"><div class="stat-label">Lost</div><div class="stat-value" style="color:#dc2626">${lost.length}</div></div>
      <div class="stat-col"><div class="stat-label">TCV</div><div class="stat-value">${fmt(s.allTCV)}</div></div>
      <div class="stat-col"><div class="stat-label">${mainLabel}</div><div class="stat-value">${mainVal}</div></div>
      <div class="stat-col"><div class="stat-label">OTC</div><div class="stat-value">${fmt(amBids.reduce((sum,b)=>sum+b.otc,0))}</div></div>
      <div class="stat-col"><div class="stat-label">Catelog MRC</div><div class="stat-value">${fmt(amBids.reduce((sum,b)=>sum+b.pcv,0))}</div></div>
      <div class="progress-bar-col">
        <div class="progress-label">Billed Ratio: ${s.total?(billed.length/s.total*100).toFixed(1):0}%</div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.total?(billed.length/s.total*100).toFixed(1):0}%"></div></div>
      </div>
    </div>`;

  // Also update grid and charts to only show AM's data
  renderCharts();
  renderGrid();
}
function getViewBids(){
  const pfTest=PF_FAMILIES[selPF];
  let bids=FILTERED.filter(b=>pfTest(b.productFamily));

  if(USER.role==='Account Manager'){
    const byEmail=FILTERED.filter(b=>b.amEmail&&b.amEmail.toLowerCase()===USER.email.toLowerCase());
    bids=byEmail.length?byEmail:FILTERED.filter(b=>b.amName&&b.amName.toLowerCase()===USER.name.toLowerCase());
    bids=bids.filter(b=>pfTest(b.productFamily));
    if(selStatusTile) bids=bids.filter(b=>b.status===selStatusTile);
    return bids;
  }

  if(selAM) bids=bids.filter(b=>b.headDirector===selHD&&b.accountDirector===selAD&&(b.amEmail===selAM||b.amName===selAM));
  else if(selAD) bids=bids.filter(b=>b.headDirector===selHD&&b.accountDirector===selAD);
  else if(selHD) bids=bids.filter(b=>b.headDirector===selHD);
  if(selStatusTile) bids=bids.filter(b=>b.status===selStatusTile);
  return bids;
}// ══════════════════════════════════════════════════════════════════
function updateTopStats(){
  const isMobile=selPF===MOBILE_PF;
  const container=el('topStats');
  container.innerHTML='';
  const pfTest=PF_FAMILIES[selPF];
  let baseBids;

  if(USER.role==='Account Manager'){
    const byEmail=FILTERED.filter(b=>b.amEmail&&b.amEmail.toLowerCase()===USER.email.toLowerCase());
    baseBids=byEmail.length?byEmail:FILTERED.filter(b=>b.amName&&b.amName.toLowerCase()===USER.name.toLowerCase());
    baseBids=baseBids.filter(b=>pfTest(b.productFamily));
  } else {
    baseBids=FILTERED.filter(b=>pfTest(b.productFamily));
    if(selAM) baseBids=baseBids.filter(b=>b.amEmail===selAM||b.amName===selAM);
    else if(selAD) baseBids=baseBids.filter(b=>b.accountDirector===selAD);
    else if(selHD) baseBids=baseBids.filter(b=>b.headDirector===selHD);
  }

  const total=baseBids.length;
  const pct=n=>total?((n/total)*100).toFixed(1)+'%':'0%';

  const ongoingStatuses=['Lead','Opportunity','Proposed','Won','On Hold'];
  const ongoing=baseBids.filter(b=>ongoingStatuses.includes(b.status));
  const closed=baseBids.filter(b=>!ongoingStatuses.includes(b.status));

  const tileDefs=[
    {key:null,label:'Overall Opportunity',isOverall:true,value:total,color:'var(--sc)'},
    {key:'Billed',    label:'Billed',      color:'#16a34a'},
    {key:'Won',       label:'Won',         color:'#16a34a'},
    {key:'Proposed',  label:'Proposed',    color:'#b45309'},
    {key:'Lost',      label:'Lost',        color:'#dc2626'},
    {key:'Cancelled', label:'Cancelled',   color:'#dc2626'},
    {key:'No Bid',    label:'No Bid',      color:'#6b7280'},
    {key:'On Hold',   label:'On Hold',     color:'#b45309'},
    {key:'Lead',      label:'Lead',        color:'var(--acc)'},
    {key:'Opportunity',label:'Opportunity',color:'var(--acc)'},
  ];

  tileDefs.forEach(td=>{
    const card=document.createElement('div');
    const isActive=selStatusTile===td.key&&td.key;
    const isDimmed=selStatusTile&&!isActive&&td.key;
    card.className='stat-card'+(isActive?' tile-active':'')+(isDimmed?' tile-dimmed':'');
    card.style.cursor=td.key?'pointer':'default';

    if(td.isOverall){
      card.innerHTML=`
        <div class="stat-label">${td.label}</div>
        <div class="stat-value" style="color:${td.color}">${total}</div>
        <div class="stat-subtitle">All Opportunities</div>
        <div class="stat-breakdown">
          <div class="breakdown-item"><span class="breakdown-label">Ongoing</span>&nbsp;<span class="breakdown-value">${ongoing.length}</span></div>
          <div class="breakdown-item"><span class="breakdown-label">Closed</span>&nbsp;<span class="breakdown-value">${closed.length}</span></div>
        </div>`;
    } else {
      const grp=baseBids.filter(b=>b.status===td.key);
      const cnt=grp.length;
      const mrc=grp.reduce((s,b)=>s+b.mrc,0);
      const otc=grp.reduce((s,b)=>s+b.otc,0);
      const tcv=grp.reduce((s,b)=>s+b.tcv,0);
      const pcv=grp.reduce((s,b)=>s+b.pcv,0);
      const ga=grp.reduce((s,b)=>s+b.gaPoints,0);
      const mainMetricLabel=isMobile?'GA Points':'MRC';
      const mainMetricVal=isMobile?fmtGA(ga):fmt(mrc);
      card.innerHTML=`
        <div class="stat-label">${td.label}</div>
        <div class="stat-value" style="color:${td.color}">${pct(cnt)}</div>
        <div class="stat-subtitle">${cnt} ${td.label.toLowerCase()} opportunities</div>
        <div style="margin-top:.5rem;display:flex;flex-direction:column;gap:.35rem;">
          <div style="display:flex;justify-content:space-between;font-size:.82rem;"><span style="color:var(--t3);font-weight:700;">TCV</span><span style="font-weight:800;color:var(--t1);">${fmt(tcv)}</span></div>
          <div style="display:flex;justify-content:space-between;font-size:.82rem;"><span style="color:var(--t3);font-weight:700;">${mainMetricLabel}</span><span style="font-weight:800;color:var(--t1);">${mainMetricVal}</span></div>
          <div style="display:flex;justify-content:space-between;font-size:.82rem;"><span style="color:var(--t3);font-weight:700;">OTC</span><span style="font-weight:800;color:var(--t1);">${fmt(otc)}</span></div>
          <div style="display:flex;justify-content:space-between;font-size:.82rem;"><span style="color:var(--t3);font-weight:700;">Catelog MRC</span><span style="font-weight:800;color:var(--t1);">${fmt(pcv)}</span></div>
        </div>`;
      card.onclick=()=>toggleStatusTile(td.key);
    }
    container.appendChild(card);
  });
}
function toggleStatusTile(status){
  if(selStatusTile===status) selStatusTile=null;
  else selStatusTile=status;
  applyAll();
  updateSelectionBadge();
}
// ══════════════════════════════════════════════════════════════════
//  TILE STATS HELPER
// ══════════════════════════════════════════════════════════════════
function buildTileStats(bids, parentBids){  const total=bids.length;
  const won=bids.filter(b=>STATUS_WON.includes(b.status));
  const ip=bids.filter(b=>STATUS_IP.includes(b.status));
  const lost=bids.filter(b=>STATUS_LOST.includes(b.status));
  const wonTCV=won.reduce((s,b)=>s+b.tcv,0);
  const ipTCV=ip.reduce((s,b)=>s+b.tcv,0);
  const lostTCV=lost.reduce((s,b)=>s+b.tcv,0);
  const allTCV=bids.reduce((s,b)=>s+b.tcv,0);
  const winRatio=total?(won.length/total*100).toFixed(1):0;
  const ga=bids.reduce((s,b)=>s+b.gaPoints,0);
const pool=parentBids||FILTERED;
const contribPct=pool.length?(bids.length/pool.length*100).toFixed(1):0;
const allTCV2=pool.reduce((s,b)=>s+b.tcv,0);
  const tcvPct=allTCV2?(allTCV/allTCV2*100).toFixed(1):0;
  return {total,won:won.length,ip:ip.length,lost:lost.length,wonTCV,ipTCV,lostTCV,allTCV,winRatio,ga,contribPct,tcvPct,highProb:bids.filter(b=>['75%','100%'].includes(b.closureProb)).length};
}

// ══════════════════════════════════════════════════════════════════
//  HD TILES (= LM tiles)
// ══════════════════════════════════════════════════════════════════
function renderHDTiles(){
  const pfTest=PF_FAMILIES[selPF];
  const isMobile=selPF===MOBILE_PF;
const allPFBids=FILTERED.filter(b=>pfTest(b.productFamily)&&(!selStatusTile||b.status===selStatusTile));
let hds=[...new Set(allPFBids.map(b=>b.headDirector).filter(v=>v&&v!=='—'))].sort();
if(USER.role==='Head Director'){
  const myHD=findMyHD();
  if(myHD) hds=hds.filter(h=>h===myHD);
  else hds=[];
}  set('hdBadge',hds.length);
  const grid=el('hdGrid'); grid.innerHTML='';
hds.forEach(function(hd){
    const hdBids=FILTERED.filter(b=>pfTest(b.productFamily)&&b.headDirector===hd&&(!selStatusTile||b.status===selStatusTile));    const s=buildTileStats(hdBids,FILTERED.filter(b=>pfTest(b.productFamily)));
    const verticals=[...new Set(hdBids.map(b=>b.vertical).filter(v=>v&&v!=='—'))].join(', ');
    const billed=hdBids.filter(b=>b.status==='Billed');
    const won=hdBids.filter(b=>b.status==='Won');
    const lost=hdBids.filter(b=>STATUS_LOST.includes(b.status));
    const ip=hdBids.filter(b=>STATUS_IP.includes(b.status));
    const mainLabel=isMobile?'GA Points':'MRC';
    const mainVal=isMobile?fmtGA(s.ga):fmt(hdBids.reduce((sum,b)=>sum+b.mrc,0));
    const tile=document.createElement('div');
    tile.className='lm-tile'+(selHD===hd?' selected':'');
    tile.innerHTML=`
      <div class="lm-header" style="flex-direction:row;justify-content:space-between;align-items:flex-start">
        <div><h3>${hd}</h3><div class="lm-meta">Head Director</div></div>
        <div style="font-size:.65rem;font-weight:700;color:var(--acc);background:var(--nab);border:1px solid var(--nab2);padding:2px 7px;border-radius:20px;white-space:nowrap;max-width:100px;overflow:hidden;text-overflow:ellipsis;text-align:right">${verticals||'—'}</div>
      </div>
      <div class="lm-stats-grid">
        <div class="lm-stat-box"><div class="lm-stat-label">Opportunities</div><div class="lm-stat-value">${s.total}</div></div>
        <div class="lm-stat-box"><div class="lm-stat-label">TCV</div><div class="lm-stat-value">${fmt(s.allTCV)}</div></div>
      </div>
      <div class="lm-revenue">
        <div class="lm-revenue-label">Billed / Won / Lost / In Progress</div>
        <div class="lm-revenue-count">${billed.length} / ${won.length} / ${lost.length} / ${ip.length}</div>
        <div class="lm-revenue-breakdown">
          <div class="lm-revenue-item"><div class="lm-revenue-item-label">${mainLabel}</div><div class="lm-revenue-item-value">${mainVal}</div></div>
          <div class="lm-revenue-item"><div class="lm-revenue-item-label">OTC</div><div class="lm-revenue-item-value">${fmt(hdBids.reduce((sum,b)=>sum+b.otc,0))}</div></div>
          <div class="lm-revenue-item"><div class="lm-revenue-item-label">Catelog MRC</div><div class="lm-revenue-item-value">${fmt(hdBids.reduce((sum,b)=>sum+b.pcv,0))}</div></div>
        </div>
      </div>
      <div class="lm-progress-section">
        <div class="lm-progress-row"><span class="lm-progress-label">Billed Ratio</span><span class="lm-progress-value">${s.total?(billed.length/s.total*100).toFixed(1):0}%</span></div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.total?(billed.length/s.total*100).toFixed(1):0}%"></div></div>
        <div class="lm-progress-row"><span class="lm-progress-label">Opportunity Contribution</span><span class="lm-progress-value">${s.contribPct}%</span></div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.contribPct}%"></div></div>
        <div class="lm-progress-row"><span class="lm-progress-label">TCV Contribution</span><span class="lm-progress-value">${s.tcvPct}%</span></div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.tcvPct}%"></div></div>
      </div>`;
    tile.onclick=function(){ selectHD(hd); };
    grid.appendChild(tile);
  });
}
function selectHD(hd){
  if(selHD===hd){selHD=null;selAD=null;selAM=null;hideAD();hideAM();}
  else{selHD=hd;selAD=null;selAM=null;renderADTiles(hd);hideAM();}
  renderHDTiles(); updateTopStats(); renderCharts(); renderGrid();

    updateSelectionBadge();
}
function hideAD(){el('adSection').style.display='none';selAD=null;}
function hideAM(){el('amSection').style.display='none';selAM=null;}

// ══════════════════════════════════════════════════════════════════
//  AD TILES (= LM tiles style)
// ══════════════════════════════════════════════════════════════════
function renderADTiles(hd){
  el('adSection').style.display='block';
  set('adContext','← '+hd);
  const pfTest=PF_FAMILIES[selPF];
  const isMobile=selPF===MOBILE_PF;
const hdBids=FILTERED.filter(b=>pfTest(b.productFamily)&&b.headDirector===hd&&(!selStatusTile||b.status===selStatusTile));
let ads=[...new Set(hdBids.map(b=>b.accountDirector).filter(v=>v&&v!=='—'))].sort();
if(USER.role==='Account Director'){
  const myAD=findMyAD();
  if(myAD) ads=ads.filter(a=>a===myAD);
}  set('adBadge',ads.length);
  const grid=el('adGrid'); grid.innerHTML='';
  if(!ads.length){grid.innerHTML='<div style="color:var(--t3);font-size:.84rem;padding:20px;">No account directors found.</div>';return;}
  ads.forEach(function(ad){
    const adBids=hdBids.filter(b=>b.accountDirector===ad);
    const s=buildTileStats(adBids,hdBids);
    const verticals=[...new Set(adBids.map(b=>b.vertical).filter(v=>v&&v!=='—'))].join(', ');
    const billed=adBids.filter(b=>b.status==='Billed');
    const won=adBids.filter(b=>b.status==='Won');
    const lost=adBids.filter(b=>STATUS_LOST.includes(b.status));
    const ip=adBids.filter(b=>STATUS_IP.includes(b.status));
    const mainLabel=isMobile?'GA Points':'MRC';
    const mainVal=isMobile?fmtGA(s.ga):fmt(adBids.reduce((sum,b)=>sum+b.mrc,0));
    const tile=document.createElement('div');
    tile.className='lm-tile'+(selAD===ad?' selected':'');
    tile.innerHTML=`
      <div class="lm-header" style="flex-direction:row;justify-content:space-between;align-items:flex-start">
        <div><h3>${ad}</h3><div class="lm-meta">Account Director</div></div>
        <div style="font-size:.65rem;font-weight:700;color:var(--acc);background:var(--nab);border:1px solid var(--nab2);padding:2px 7px;border-radius:20px;white-space:nowrap;max-width:100px;overflow:hidden;text-overflow:ellipsis;text-align:right">${verticals||'—'}</div>
      </div>
      <div class="lm-stats-grid">
        <div class="lm-stat-box"><div class="lm-stat-label">Opportunities</div><div class="lm-stat-value">${s.total}</div></div>
        <div class="lm-stat-box"><div class="lm-stat-label">TCV</div><div class="lm-stat-value">${fmt(s.allTCV)}</div></div>
      </div>
      <div class="lm-revenue">
        <div class="lm-revenue-label">Billed / Won / Lost / In Progress</div>
        <div class="lm-revenue-count">${billed.length} / ${won.length} / ${lost.length} / ${ip.length}</div>
        <div class="lm-revenue-breakdown">
          <div class="lm-revenue-item"><div class="lm-revenue-item-label">${mainLabel}</div><div class="lm-revenue-item-value">${mainVal}</div></div>
          <div class="lm-revenue-item"><div class="lm-revenue-item-label">OTC</div><div class="lm-revenue-item-value">${fmt(adBids.reduce((sum,b)=>sum+b.otc,0))}</div></div>
          <div class="lm-revenue-item"><div class="lm-revenue-item-label">Catelog MRC</div><div class="lm-revenue-item-value">${fmt(adBids.reduce((sum,b)=>sum+b.pcv,0))}</div></div>
        </div>
      </div>
      <div class="lm-progress-section">
        <div class="lm-progress-row"><span class="lm-progress-label">Billed Ratio</span><span class="lm-progress-value">${s.total?(billed.length/s.total*100).toFixed(1):0}%</span></div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.total?(billed.length/s.total*100).toFixed(1):0}%"></div></div>
        <div class="lm-progress-row"><span class="lm-progress-label">Opportunity Contribution</span><span class="lm-progress-value">${s.contribPct}%</span></div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.contribPct}%"></div></div>
        <div class="lm-progress-row"><span class="lm-progress-label">TCV Contribution</span><span class="lm-progress-value">${s.tcvPct}%</span></div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.tcvPct}%"></div></div>
      </div>`;
    tile.onclick=function(){ selectAD(ad); };
    grid.appendChild(tile);
  });
}function selectAD(ad){
  if(selAD===ad){selAD=null;selAM=null;hideAM();}
  else{selAD=ad;selAM=null;renderAMRows(ad);}
  renderADTiles(selHD); updateTopStats(); renderCharts(); renderGrid();
  updateSelectionBadge();
}

// ══════════════════════════════════════════════════════════════════
//  AM ROWS (= SM rows style)
// ══════════════════════════════════════════════════════════════════
function renderAMRows(ad){
  el('amSection').style.display='block';
  set('amContext','← '+ad);
  const pfTest=PF_FAMILIES[selPF];
  const isMobile=selPF===MOBILE_PF;
const adBids=FILTERED.filter(b=>pfTest(b.productFamily)&&b.headDirector===selHD&&b.accountDirector===ad&&(!selStatusTile||b.status===selStatusTile));  const amMap={};
  adBids.forEach(function(b){
    const key=b.amEmail||b.amName||'Unknown';
    if(!amMap[key]) amMap[key]={name:b.amName,email:b.amEmail,bids:[]};
    amMap[key].bids.push(b);
  });
  const ams=Object.values(amMap).filter(a=>a.name&&a.name!=='—').sort((a,b)=>b.bids.reduce((s,x)=>s+x.tcv,0)-a.bids.reduce((s,x)=>s+x.tcv,0));
  set('amBadge',ams.length);
  const list=el('amList'); list.innerHTML='';
  if(!ams.length){list.innerHTML='<div style="color:var(--t3);font-size:.84rem;padding:20px;">No account managers found.</div>';return;}
  ams.forEach(function(am,i){
    const s=buildTileStats(am.bids,adBids);
    const key=am.email||am.name;
    const rankClass=i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-other';
    const verticals=[...new Set(am.bids.map(b=>b.vertical).filter(v=>v&&v!=='—'))].join(', ');
    const billed=am.bids.filter(b=>b.status==='Billed');
    const won=am.bids.filter(b=>b.status==='Won');
    const lost=am.bids.filter(b=>STATUS_LOST.includes(b.status));
    const ip=am.bids.filter(b=>STATUS_IP.includes(b.status));
    const mainLabel=isMobile?'GA':'MRC';
    const mainVal=isMobile?fmtGA(s.ga):fmt(am.bids.reduce((sum,b)=>sum+b.mrc,0));
    const row=document.createElement('div');
    row.className='manager-row'+(selAM===key?' selected':'');
    row.innerHTML=`
      <div class="rank-badge ${rankClass}">${i+1}</div>
      <div class="manager-name-col">
        <div class="manager-name">${am.name}</div>
        <div class="manager-tag" style="font-size:.62rem">${verticals||'—'}</div>
      </div>
      <div class="stat-col"><div class="stat-label">Opps</div><div class="stat-value">${s.total}</div></div>
      <div class="stat-col"><div class="stat-label">Billed</div><div class="stat-value" style="color:#16a34a">${billed.length}</div></div>
      <div class="stat-col"><div class="stat-label">Won</div><div class="stat-value" style="color:#16a34a">${won.length}</div></div>
      <div class="stat-col"><div class="stat-label">Lost</div><div class="stat-value" style="color:#dc2626">${lost.length}</div></div>
      <div class="stat-col"><div class="stat-label">TCV</div><div class="stat-value">${fmt(s.allTCV)}</div></div>
      <div class="stat-col"><div class="stat-label">${mainLabel}</div><div class="stat-value">${mainVal}</div></div>
      <div class="stat-col"><div class="stat-label">OTC</div><div class="stat-value">${fmt(am.bids.reduce((sum,b)=>sum+b.otc,0))}</div></div>
      <div class="stat-col"><div class="stat-label">Catelog MRC</div><div class="stat-value">${fmt(am.bids.reduce((sum,b)=>sum+b.pcv,0))}</div></div>
      <div class="progress-bar-col">
        <div class="progress-label">Billed Ratio: ${s.total?(billed.length/s.total*100).toFixed(1):0}%</div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.total?(billed.length/s.total*100).toFixed(1):0}%"></div></div>
      </div>
      <div class="progress-bar-col">
        <div class="progress-label">TCV Contribution: ${s.tcvPct}%</div>
        <div class="progress-bar"><div class="progress-fill" style="width:${s.tcvPct}%"></div></div>
      </div>`;
    row.onclick=function(){ selectAM(key); };
    list.appendChild(row);
  });
}function selectAM(key){
  if(selAM===key) selAM=null; else selAM=key;
  renderAMRows(selAD); updateTopStats(); renderCharts(); renderGrid();
  updateSelectionBadge();
}

// ══════════════════════════════════════════════════════════════════
//  CHARTS
// ══════════════════════════════════════════════════════════════════
function toggleCharts(){
  chartsVisible=!chartsVisible;
  el('chartsSection').style.display=chartsVisible?'block':'none';
  el('chartsToggleText').textContent=chartsVisible?'Hide Analytics Charts':'Show Analytics Charts';
  if(chartsVisible) setTimeout(()=>renderCharts(),80);
}
function getChartColors(){
  const t=document.body.getAttribute('data-theme')||'';
  const isDark=t==='dark'||t==='duralux-dark';
  const isDural=t==='duralux'||t==='duralux-dark';
  return {
    text:isDark?'rgba(255,255,255,0.6)':'rgba(0,0,0,0.5)',
    grid:isDark?'rgba(255,255,255,0.07)':'rgba(0,0,0,0.06)',
p1:isDural?'#4c6fff':'#a855f7',
    p2:isDural?'#818cf8':'#c724b1',
    p1a:isDural?'rgba(76,111,255,':'rgba(168,85,247,',
    p2a:isDural?'rgba(129,140,248,':'rgba(199,36,177,',

  };
}
function destroyChart(k){ if(CHARTS[k]){ CHARTS[k].destroy(); CHARTS[k]=null; } }
const dataLabelPlugin={id:'dlp',afterDatasetsDraw(chart){
  const ctx=chart.ctx;
  chart.data.datasets.forEach((ds,di)=>{
    const meta=chart.getDatasetMeta(di);
    if(meta.hidden)return;
    meta.data.forEach((el,i)=>{
      const v=ds.data[i]; if(!v&&v!==0)return;
      const isH=chart.options.indexAxis==='y';
      ctx.save();
      ctx.font='bold 11px Inter,sans-serif';
      ctx.fillStyle=chart.options.scales[isH?'x':'y'].ticks.color||'#666';
      const lbl=v>=1e6?(v/1e6).toFixed(1)+'M':v>=1e3?(v/1e3).toFixed(0)+'K':Number.isInteger(v)?String(v):v.toFixed(1);
      if(isH){ctx.textAlign='left';ctx.textBaseline='middle';const p=el.tooltipPosition();ctx.fillText(lbl,p.x+6,p.y);}
      else{ctx.textAlign='center';ctx.textBaseline='bottom';const p=el.tooltipPosition();ctx.fillText(lbl,p.x,p.y-4);}
      ctx.restore();
    });
  });
}};
function renderCharts(){
  if(!chartsVisible) return;
  const bids=getViewBids(); const c=getChartColors();
  renderWinLoss(bids,c);
  renderTrend(bids,c);
  renderProbTCV(bids,c);
  renderLeaderboard(bids,c);
  renderVertical(bids,c);
  renderTopChart(bids,c);
  renderGA(bids,c);
}

function renderWinLoss(bids,c){
  destroyChart('wl');
  let groups={};
  if(selAM) groups[selAM]=bids;
  else if(selAD) bids.forEach(b=>{const k=b.amName||'?';if(!groups[k])groups[k]=[];groups[k].push(b);});
  else if(selHD) bids.forEach(b=>{const k=b.accountDirector||'?';if(!groups[k])groups[k]=[];groups[k].push(b);});
  else bids.forEach(b=>{const k=b.headDirector||'?';if(!groups[k])groups[k]=[];groups[k].push(b);});
  const sorted=Object.entries(groups)
    .map(([k,v])=>({k,billed:v.filter(b=>b.status==='Billed').length,ip:v.filter(b=>STATUS_IP.includes(b.status)).length,lost:v.filter(b=>STATUS_LOST.includes(b.status)).length}))
    .sort((a,b)=>(b.billed+b.ip+b.lost)-(a.billed+a.ip+a.lost))
    .slice(0,8);
  const labels=sorted.map(s=>s.k);
  CHARTS.wl=new Chart(el('chartWinLoss'),{type:'bar',
    data:{labels,datasets:[
      {label:'Billed',data:sorted.map(s=>s.billed),backgroundColor:'#10b981',borderRadius:6,borderSkipped:false,barPercentage:.55,categoryPercentage:.7},
      {label:'Pipeline',data:sorted.map(s=>s.ip),backgroundColor:c.p1,borderRadius:6,borderSkipped:false,barPercentage:.55,categoryPercentage:.7},
      {label:'Lost',data:sorted.map(s=>s.lost),backgroundColor:'#ef4444',borderRadius:6,borderSkipped:false,barPercentage:.55,categoryPercentage:.7},
    ]},
    options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{position:'top',labels:{color:c.text,font:{size:12,weight:'600'},usePointStyle:true,pointStyleWidth:10,padding:20}},
        tooltip:{backgroundColor:'rgba(0,0,0,.75)',padding:12,cornerRadius:10,bodyFont:{size:12}}
      },
      scales:{
        x:{ticks:{color:c.text,font:{size:11}},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true},
        y:{ticks:{color:c.text,font:{size:12,weight:'600'},padding:8},grid:{display:false}}
      }}});
}
let trendMetric='tcv';
function renderTrend(bids,c){
  destroyChart('trend');
  const isMobile=selPF===MOBILE_PF;
  const metrics=isMobile?
    [{k:'tcv',l:'TCV'},{k:'ga',l:'GA Points'},{k:'otc',l:'OTC'},{k:'pcv',l:'Catelog MRC'}]:
    [{k:'tcv',l:'TCV'},{k:'mrc',l:'MRC'},{k:'otc',l:'OTC'},{k:'pcv',l:'Catelog MRC'}];
  const now=new Date();
  let labels=[];
  const getVal=(b,k)=>k==='tcv'?b.tcv:k==='mrc'?b.mrc:k==='otc'?b.otc:k==='pcv'?b.pcv:b.gaPoints;
  const periods=trendPeriod==='W'?12:trendPeriod==='M'?12:trendPeriod==='Q'?8:5;
  const getBucket=(rd)=>{
    const d=new Date(rd);
    if(trendPeriod==='W') return d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
    if(trendPeriod==='M') return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
    if(trendPeriod==='Q') return d.getFullYear()+'-Q'+Math.ceil((d.getMonth()+1)/3);
    return String(d.getFullYear());
  };
  const buckets=[];
  for(let i=periods-1;i>=0;i--){
    let label,bucket;
    if(trendPeriod==='W'){
      const d=new Date(now);d.setDate(d.getDate()-i*7);
      bucket=d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
      label='W'+getWeekOfYear(d);
    } else if(trendPeriod==='M'){
      const d=new Date(now.getFullYear(),now.getMonth()-i,1);
      bucket=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
      label=d.toLocaleDateString('en-US',{month:'short',year:'2-digit'});
    } else if(trendPeriod==='Q'){
      const totalQ=now.getFullYear()*4+Math.ceil((now.getMonth()+1)/3)-1-i;
      const yr=Math.floor(totalQ/4);
      const q=(totalQ%4)+1;
      bucket=yr+'-Q'+q;
      label='Q'+q+' '+String(yr).slice(2);
    } else {
      const yr=now.getFullYear()-i;
      bucket=String(yr);label=String(yr);
    }
    labels.push(label);buckets.push(bucket);
  }
  const billedD=[],wonD=[],pipeD=[];
  buckets.forEach(bkt=>{
    const mb=bids.filter(b=>{const rd=getRelevantDate(b);if(!rd)return false;return getBucket(rd)===bkt;});
    billedD.push(+(mb.filter(b=>b.status==='Billed').reduce((s,b)=>s+getVal(b,trendMetric),0)/1e6).toFixed(2));
    wonD.push(+(mb.filter(b=>b.status==='Won').reduce((s,b)=>s+getVal(b,trendMetric),0)/1e6).toFixed(2));
    pipeD.push(+(mb.filter(b=>STATUS_IP.includes(b.status)).reduce((s,b)=>s+getVal(b,trendMetric),0)/1e6).toFixed(2));
  });
  const ctx=el('chartTrend').getContext('2d');
  const mkGrad=(r,g,b2)=>{const g2=ctx.createLinearGradient(0,0,0,280);g2.addColorStop(0,`rgba(${r},${g},${b2},.35)`);g2.addColorStop(1,`rgba(${r},${g},${b2},.02)`);return g2;};
  CHARTS.trend=new Chart(el('chartTrend'),{type:'line',
    data:{labels,datasets:[
     {label:'Billed',data:billedD,borderColor:'#10b981',backgroundColor:'rgba(16,185,129,.25)',fill:true,tension:.35,pointRadius:4,pointHoverRadius:7,pointBackgroundColor:'#10b981',pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:2.5,stack:'revenue'},
      {label:'Won',data:wonD,borderColor:'#6366f1',backgroundColor:'rgba(99,102,241,.25)',fill:true,tension:.35,pointRadius:4,pointHoverRadius:7,pointBackgroundColor:'#6366f1',pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:2.5,stack:'revenue'},
      {label:'Pipeline',data:pipeD,borderColor:c.p1,backgroundColor:'rgba(168,85,247,.25)',fill:true,tension:.35,pointRadius:4,pointHoverRadius:7,pointBackgroundColor:c.p1,pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:2.5,stack:'revenue'},
    ]},
options:{responsive:true,maintainAspectRatio:false,
      interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{position:'top',labels:{color:c.text,font:{size:12,weight:'600'},usePointStyle:true,pointStyleWidth:10,padding:20}},
        tooltip:{
          backgroundColor:'rgba(15,10,30,.85)',padding:14,cornerRadius:12,
          titleFont:{size:13,weight:'700'},bodyFont:{size:12},
          bodySpacing:6,
          callbacks:{
            label:ctx=>'  '+ctx.dataset.label+':  '+ctx.parsed.y.toFixed(2)+'M'
          }
        }
      },
      scales:{
        x:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{color:c.grid},border:{dash:[4,4]}},
        y:{stacked:true,ticks:{color:c.text,font:{size:11},callback:v=>v+'M'},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true}
      }}});

  // render metric + period toggle buttons below chart
  const wrap=el('trendControlsWrap');
  if(wrap){
    wrap.innerHTML=`
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:.65rem;flex-wrap:wrap;gap:.5rem;">
        <div style="display:flex;gap:.35rem;">
          ${metrics.map(m=>`<button type="button" onclick="trendMetric='${m.k}';renderTrend(getViewBids(),getChartColors())" style="padding:.25rem .7rem;border-radius:6px;font-size:.72rem;font-weight:700;border:1px solid var(--border);cursor:pointer;transition:all .15s;background:${trendMetric===m.k?'var(--grad)':'var(--bg-secondary)'};color:${trendMetric===m.k?'#fff':'var(--t3)'}">${m.l}</button>`).join('')}
        </div>
        <div style="display:flex;gap:.35rem;">
          ${['W','M','Q','Y'].map(p=>`<button type="button" onclick="trendPeriod='${p}';renderTrend(getViewBids(),getChartColors())" style="padding:.25rem .7rem;border-radius:6px;font-size:.72rem;font-weight:700;border:1px solid var(--border);cursor:pointer;transition:all .15s;background:${trendPeriod===p?'var(--grad)':'var(--bg-secondary)'};color:${trendPeriod===p?'#fff':'var(--t3)'}">${p==='W'?'Week':p==='M'?'Month':p==='Q'?'Quarter':'Year'}</button>`).join('')}
        </div>
      </div>`;
  }
}
function renderProbTCV(bids,c){
  destroyChart('ptcv');
  const tcvs=PROB_ORDER.map(p=>+(bids.filter(b=>b.closureProb===p).reduce((s,b)=>s+b.tcv,0)/1e6).toFixed(2));
  const counts=PROB_ORDER.map(p=>bids.filter(b=>b.closureProb===p).length);
  const palette=['#ef4444','#f97316','#eab308','#10b981','#6366f1'];
  const totalTCV=tcvs.reduce((a,b)=>a+b,0);
  const centerPlugin={id:'probCenter',beforeDraw(chart){
    const{ctx,chartArea:{width,height,left,top}}=chart;
    ctx.save();
    ctx.font='bold 22px Inter';
    ctx.fillStyle=document.body.getAttribute('data-theme')||''?'rgba(255,255,255,0.9)':'rgba(30,17,51,0.9)';
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(totalTCV.toFixed(1)+'M',left+width/2,top+height/2-12);
    ctx.font='600 11px Inter';
    ctx.fillStyle=c.text;
    ctx.fillText('Total TCV',left+width/2,top+height/2+10);
    ctx.restore();
  }};
  CHARTS.ptcv=new Chart(el('chartProbTCV'),{type:'doughnut',plugins:[centerPlugin],
    data:{
      labels:PROB_ORDER.map((p,i)=>p+' — '+counts[i]+' bids — '+tcvs[i]+'M'),
      datasets:[{
        data:tcvs,
        backgroundColor:palette,
        borderWidth:4,
        borderColor:'var(--bg-card)',
        hoverOffset:14,
        hoverBorderWidth:2,
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,cutout:'58%',
      plugins:{
        legend:{
          position:'right',
          labels:{color:c.text,font:{size:11,weight:'600'},padding:12,usePointStyle:true,pointStyleWidth:10,
            generateLabels:chart=>{
              return chart.data.labels.map((lbl,i)=>({
                text:lbl,fillStyle:palette[i],strokeStyle:palette[i],
                fontColor:c.text,hidden:false,index:i,
              }));
            }
          }
        },
        tooltip:{
          backgroundColor:'rgba(0,0,0,.8)',padding:14,cornerRadius:10,
          callbacks:{
            label:ctx=>{
              const pct=totalTCV>0?(ctx.parsed/totalTCV*100).toFixed(1):'0';
              return ['  TCV: '+ctx.parsed.toFixed(2)+'M','  Share: '+pct+'%','  Bids: '+counts[ctx.dataIndex]];
            }
          }
        }
      }
    }
  });
}
let lbMode='hd';
let lbMetric='tcv';
let vertMetric='tcv';
function renderLeaderboard(bids,c){
  destroyChart('lb');
  const role=USER.role;

  // Determine available modes based on role
  let modes=[];
if(role==='Admin'||role==='CEO'||role==='Admin (Dev)'||role==='admin'||role==='ADMIN'){    modes=[
      {k:'hd',l:'Head Directors'},
      {k:'ad',l:'Account Directors'},
      {k:'am',l:'Account Managers'}
    ];
  } else if(role==='Head Director'){
    modes=[
      {k:'ad',l:'Account Directors'},
      {k:'am',l:'Account Managers'}
    ];
    if(lbMode==='hd') lbMode='ad';
  } else if(role==='Account Director'){
    modes=[{k:'am',l:'Account Managers'}];
    lbMode='am';
  } else {
    // Account Manager — hide leaderboard entirely
    const card=el('chartLeaderboard')?.closest('.chart-card');
    if(card) card.style.display='none';
    return;
  }

  // Build HD/AD/AM toggle buttons
  const wrap=el('lbControlsWrap');
  if(wrap){
    wrap.innerHTML=`<div style="display:flex;gap:.5rem;margin-bottom:.75rem;flex-wrap:wrap;">
      ${modes.map(m=>`<button type="button"
        onclick="lbMode='${m.k}';renderLeaderboard(getViewBids(),getChartColors())"
        style="padding:.35rem 1rem;border-radius:8px;font-size:.78rem;font-weight:700;
        border:2px solid ${lbMode===m.k?'transparent':'var(--border)'};cursor:pointer;
        background:${lbMode===m.k?'var(--grad)':'var(--bg-secondary)'};
        color:${lbMode===m.k?'#fff':'var(--t3)'};transition:all .18s;">
        ${m.l}</button>`).join('')}
    </div>`;
  }

  // Build metric toggle buttons
  const metricWrap=el('lbMetricToggle');
  if(metricWrap){
    const isMobile=selPF==='Mobile';
    const metrics=isMobile?
      [{k:'tcv',l:'TCV'},{k:'mrc',l:'GA Pts'},{k:'otc',l:'OTC'},{k:'pcv',l:'Catelog MRC'}]:
      [{k:'tcv',l:'TCV'},{k:'mrc',l:'MRC'},{k:'otc',l:'OTC'},{k:'pcv',l:'Catelog MRC'}];
    metricWrap.innerHTML=metrics.map(m=>`<button type="button"
      onclick="lbMetric='${m.k}';renderLeaderboard(getViewBids(),getChartColors())"
      style="padding:.25rem .75rem;border-radius:6px;font-size:.72rem;font-weight:700;
      border:1px solid ${lbMetric===m.k?'transparent':'var(--border)'};cursor:pointer;
      background:${lbMetric===m.k?'var(--grad)':'var(--bg-secondary)'};
      color:${lbMetric===m.k?'#fff':'var(--t3)'};transition:all .15s;">
      ${m.l}</button>`).join('');
  }

  // Build data entries scoped correctly per role + mode
  const map={};

  if(lbMode==='hd'){
    // Admin only — all HDs
    bids.forEach(b=>{
      const k=b.headDirector||'?';
      if(!k||k==='—') return;
      if(!map[k]) map[k]={won:0,total:0,wonTCV:0,mrc:0,otc:0,pcv:0,ga:0};
      if(STATUS_WON.includes(b.status)){map[k].won++;map[k].wonTCV+=b.tcv;}
      map[k].mrc+=b.mrc;map[k].otc+=b.otc;map[k].pcv+=b.pcv;map[k].ga+=b.gaPoints;map[k].total++;
    });

  } else if(lbMode==='ad'){
    // Admin → all ADs | HD → only ADs under this HD
    let scope=bids;
    if(role==='Head Director'){
      const myHD=findMyHD();
      scope=bids.filter(b=>b.headDirector===myHD);
    }
    scope.forEach(b=>{
      const k=b.accountDirector||'?';
      if(!k||k==='—') return;
      if(!map[k]) map[k]={won:0,total:0,wonTCV:0,mrc:0,otc:0,pcv:0,ga:0};
      if(STATUS_WON.includes(b.status)){map[k].won++;map[k].wonTCV+=b.tcv;}
      map[k].mrc+=b.mrc;map[k].otc+=b.otc;map[k].pcv+=b.pcv;map[k].ga+=b.gaPoints;map[k].total++;
    });

  } else {
    // Admin → all AMs | HD → AMs under his ADs | AD → only his AMs
    let scope=bids;
    if(role==='Head Director'){
      const myHD=findMyHD();
      scope=bids.filter(b=>b.headDirector===myHD);
    } else if(role==='Account Director'){
      const myAD=findMyAD();
      scope=bids.filter(b=>b.accountDirector===myAD);
    }
    scope.forEach(b=>{
      const k=b.amName||'?';
      if(!k||k==='—') return;
      if(!map[k]) map[k]={won:0,total:0,wonTCV:0,mrc:0,otc:0,pcv:0,ga:0};
      if(STATUS_WON.includes(b.status)){map[k].won++;map[k].wonTCV+=b.tcv;}
      map[k].mrc+=b.mrc;map[k].otc+=b.otc;map[k].pcv+=b.pcv;map[k].ga+=b.gaPoints;map[k].total++;
    });
  }

  const getMetricVal=(v)=>{
    if(lbMetric==='tcv') return +(v.wonTCV/1e6).toFixed(2);
    if(lbMetric==='mrc') return +(v.mrc/1e6).toFixed(2);
    if(lbMetric==='otc') return +(v.otc/1e6).toFixed(2);
    if(lbMetric==='pcv') return +(v.pcv/1e6).toFixed(2);
    return 0;
  };
  const metricLabel={'tcv':'TCV','mrc':selPF==='Mobile'?'GA Pts':'MRC','otc':'OTC','pcv':'Catelog MRC'}[lbMetric];

  const entries=Object.entries(map);
  const sorted=entries.sort((a,b)=>getMetricVal(b[1])-getMetricVal(a[1])).slice(0,12);

  if(!sorted.length){
    el('chartLeaderboard').parentElement.innerHTML+='<div style="padding:20px;color:var(--t3);text-align:center;font-size:.85rem;">No data available</div>';
    return;
  }

  // Color bars: green=high win rate, accent=mid, red=low
  const barColors=sorted.map(([,v])=>{
    const wr=v.total?v.won/v.total:0;
    return wr>=.55?'#10b981':wr>=.30?c.p1:'#ef4444';
  });

  // Dynamic height based on number of entries
  const chartHeight=Math.max(320, sorted.length*52);
  const canvasWrap=el('chartLeaderboard').parentElement;
  canvasWrap.style.height=chartHeight+'px';

  CHARTS.lb=new Chart(el('chartLeaderboard'),{
    type:'bar',
    data:{
      labels:sorted.map(([k])=>k),
      datasets:[{
        label:metricLabel+' (M)',
        data:sorted.map(([,v])=>getMetricVal(v)),
        backgroundColor:barColors,
        borderRadius:8,
        borderSkipped:false,
        barThickness:28,
      }]
    },
    options:{
      indexAxis:'y',
      responsive:true,
      maintainAspectRatio:false,
      layout:{padding:{right:60}},
      plugins:{
        legend:{display:false},
        tooltip:{
          backgroundColor:'rgba(0,0,0,.82)',
          padding:14,
          cornerRadius:10,
          titleFont:{size:13,weight:'700'},
          bodyFont:{size:12},
          bodySpacing:5,
          callbacks:{
            label:ctx=>'  '+metricLabel+': '+ctx.parsed.x.toFixed(2)+'M',
            afterLabel:ctx=>{
              const d=sorted[ctx.dataIndex][1];
              const wr=d.total?(d.won/d.total*100).toFixed(1):0;
              return [
                '  Total Bids: '+d.total,
                '  Won: '+d.won,
                '  Win Rate: '+wr+'%',
                '  MRC: '+fmt(d.mrc),
                '  OTC: '+fmt(d.otc),
              ];
            }
          }
        }
      },
      scales:{
        x:{
          ticks:{color:c.text,font:{size:11},callback:v=>v+'M'},
          grid:{color:c.grid},
          border:{dash:[4,4]},
          beginAtZero:true
        },
        y:{
          ticks:{
            color:c.text,
            font:{size:12,weight:'700'},
            padding:12,
          },
          grid:{display:false}
        }
      }
    },
    plugins:[{
      id:'lbValueLabels',
      afterDatasetsDraw(chart){
        const ctx=chart.ctx;
        chart.data.datasets[0].data.forEach((val,i)=>{
          const meta=chart.getDatasetMeta(0);
          const bar=meta.data[i];
          const pos=bar.tooltipPosition();
          ctx.save();
          ctx.font='bold 11px Inter,sans-serif';
          ctx.fillStyle=c.text;
          ctx.textAlign='left';
          ctx.textBaseline='middle';
          ctx.fillText(val.toFixed(2)+'M', pos.x+8, pos.y);
          ctx.restore();
        });
      }
    }]
  });
}
function renderVertical(bids,c){
  destroyChart('vert');
  const vm={};
  bids.forEach(b=>{const v=b.vertical||'Other';if(!vm[v])vm[v]={count:0,tcv:0};vm[v].count++;vm[v].tcv+=b.tcv;});
  const sorted=Object.entries(vm).sort((a,b)=>b[1][vertMetric]-a[1][vertMetric]).slice(0,10);
  const palette=['rgba(168,85,247,.85)','rgba(99,102,241,.85)','rgba(59,130,246,.85)','rgba(6,182,212,.85)','rgba(16,185,129,.85)','rgba(251,146,60,.85)','rgba(236,72,153,.85)','rgba(239,68,68,.85)','rgba(234,179,8,.85)','rgba(20,184,166,.85)'];
  const isValue=vertMetric==='tcv';
  CHARTS.vert=new Chart(el('chartVertical'),{type:'bar',plugins:[dataLabelPlugin],
    data:{labels:sorted.map(([k])=>k),datasets:[{
      data:sorted.map(([,v])=>isValue?+(v.tcv/1e6).toFixed(2):v.count),
      backgroundColor:palette.slice(0,sorted.length),
      borderRadius:8,borderSkipped:false}]},
options:{responsive:true,maintainAspectRatio:false,      plugins:{
        legend:{display:false},
        tooltip:{backgroundColor:'rgba(0,0,0,.75)',padding:12,cornerRadius:10,
          callbacks:{label:ctx=>isValue?ctx.parsed.x.toFixed(2)+'M':ctx.parsed.x+' bids'}}
      },
     scales:{
        x:{ticks:{color:c.text,font:{size:10,weight:'600'}},grid:{display:false}},
        y:{ticks:{color:c.text,callback:v=>isValue?v+'M':v},grid:{color:c.grid},beginAtZero:true}
      }}});
}

function setVertMetric(m){
  vertMetric=m;
  el('vertBtnTCV').style.background=m==='tcv'?'var(--grad)':'var(--bg-secondary)';
  el('vertBtnTCV').style.color=m==='tcv'?'#fff':'var(--t3)';
  el('vertBtnCount').style.background=m==='count'?'var(--grad)':'var(--bg-secondary)';
  el('vertBtnCount').style.color=m==='count'?'#fff':'var(--t3)';
  renderVertical(getViewBids(),getChartColors());
}
function renderServices(bids,c){
  destroyChart('svc');
  const sm={};
  bids.forEach(b=>{const s=b.services||'Unknown';if(s==='—'||!s)return;if(!sm[s])sm[s]=0;sm[s]++;});
  const sorted=Object.entries(sm).sort((a,b)=>b[1]-a[1]).slice(0,7);
  const total=sorted.reduce((s,[,v])=>s+v,0);
  const palette=['rgba(168,85,247,.88)','rgba(59,130,246,.88)','rgba(6,182,212,.88)','rgba(16,185,129,.88)','rgba(251,146,60,.88)','rgba(236,72,153,.88)','rgba(239,68,68,.88)'];
  const centerPlugin={id:'svcCenter',beforeDraw(chart){
    const{ctx,chartArea:{width,height,left,top}}=chart;
    ctx.save();
    ctx.font='bold 26px Inter';
    ctx.fillStyle=c.text==='rgba(255,255,255,0.6)'?'rgba(255,255,255,0.9)':'rgba(0,0,0,0.8)';
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(total,left+width/2,top+height/2-10);
    ctx.font='600 11px Inter';ctx.fillStyle=c.text;
    ctx.fillText('Total Bids',left+width/2,top+height/2+14);
    ctx.restore();
  }};
  CHARTS.svc=new Chart(el('chartServices'),{type:'doughnut',plugins:[centerPlugin],
    data:{labels:sorted.map(([k])=>k),datasets:[{data:sorted.map(([,v])=>v),
      backgroundColor:palette.slice(0,sorted.length),borderWidth:3,borderColor:'var(--bg-card)',hoverOffset:10}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'62%',
      plugins:{legend:{position:'right',labels:{color:c.text,font:{size:10},padding:10,usePointStyle:true,pointStyleWidth:8}}}}});
}

let topChartMode='customers';
let svcMetric='tcv';

function setTopChart(mode){
  topChartMode=mode;
  const custBtn=el('topChartBtnCust'),svcBtn=el('topChartBtnSvc'),subToggle=el('svcSubToggle');
  const titleEl=el('topChartTitle');
  if(mode==='customers'){
    custBtn.style.background='var(--grad)';custBtn.style.color='#fff';
    svcBtn.style.background='var(--bg-secondary)';svcBtn.style.color='var(--t3)';
    if(subToggle){subToggle.style.display='none';}
    if(titleEl) titleEl.innerHTML=`<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> Top 10 Customers by TCV`;
  } else {
    svcBtn.style.background='var(--grad)';svcBtn.style.color='#fff';
    custBtn.style.background='var(--bg-secondary)';custBtn.style.color='var(--t3)';
    if(subToggle){subToggle.style.display='flex';}
    if(titleEl) titleEl.innerHTML=`<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg> Top Services by ${svcMetric==='tcv'?'TCV':'Bid Count'}`;
  }
  renderTopChart(getViewBids(),getChartColors());
}

function setSvcMetric(m){
  svcMetric=m;
  el('svcBtnTCV').style.background=m==='tcv'?'var(--grad)':'var(--bg-secondary)';
  el('svcBtnTCV').style.color=m==='tcv'?'#fff':'var(--t3)';
  el('svcBtnBids').style.background=m==='bids'?'var(--grad)':'var(--bg-secondary)';
  el('svcBtnBids').style.color=m==='bids'?'#fff':'var(--t3)';
  const titleEl=el('topChartTitle');
  if(titleEl) titleEl.innerHTML=`<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg> Top Services by ${m==='tcv'?'TCV':'Bid Count'}`;
  renderTopChart(getViewBids(),getChartColors());
}

function renderTopChart(bids,c){
  destroyChart('topCust');
  let labels=[],data=[],colors=[];
  const palette=['#6366f1','#8b5cf6','#a855f7','#c084fc','#06b6d4','#10b981','#f59e0b','#ef4444','#ec4899','#14b8a6'];

  if(topChartMode==='customers'){
    const cm={};
    bids.forEach(b=>{if(!b.customerName||b.customerName==='—')return;if(!cm[b.customerName])cm[b.customerName]=0;cm[b.customerName]+=b.tcv;});
    const sorted=Object.entries(cm).sort((a,b)=>b[1]-a[1]).slice(0,10);
    labels=sorted.map(([k])=>k);
    data=sorted.map(([,v])=>+(v/1e6).toFixed(2));
    colors=palette.slice(0,labels.length);
  } else {
    const sm={};
    bids.forEach(b=>{if(!b.services||b.services==='—')return;if(!sm[b.services])sm[b.services]={tcv:0,bids:0};sm[b.services].tcv+=b.tcv;sm[b.services].bids++;});
    const sorted=Object.entries(sm).sort((a,b)=>b[1][svcMetric]-a[1][svcMetric]).slice(0,10);
    labels=sorted.map(([k])=>k);
    data=svcMetric==='tcv'?sorted.map(([,v])=>+(v.tcv/1e6).toFixed(2)):sorted.map(([,v])=>v.bids);
    colors=palette.slice(0,labels.length);
  }

  CHARTS.topCust=new Chart(el('chartTopCustomers'),{type:'bar',plugins:[dataLabelPlugin],
    data:{labels,datasets:[{
      data,backgroundColor:colors,borderRadius:8,borderSkipped:false,
      barThickness:22,
    }]},
    options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{backgroundColor:'rgba(0,0,0,.75)',padding:12,cornerRadius:10,
          callbacks:{label:ctx=>topChartMode==='customers'||svcMetric==='tcv'?ctx.parsed.x.toFixed(2)+'M':ctx.parsed.x+' bids'}}
      },
      scales:{
        x:{ticks:{color:c.text,font:{size:11},callback:v=>topChartMode==='customers'||svcMetric==='tcv'?v+'M':v},grid:{color:c.grid},border:{dash:[4,4]}},
        y:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{display:false}}
      }}});
}
let gaTrendMetric='auto';
function renderGA(bids,c){
destroyChart('ga');
  const isMobile=selPF===MOBILE_PF;
  const useGA=isMobile;
  const titleEl=el('gaTrendTitle'); if(titleEl) titleEl.textContent=useGA?'GA Points Trend':'MRC Trend';
  const metricKey=useGA?'gaPoints':'mrc';
  const metricLabel=useGA?'GA Points':'MRC';
  const now=new Date();
  let labels=[],vals=[];
  const getBucket=(rd)=>{
    const d=new Date(rd);
    if(gaPeriod==='W') return d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
    if(gaPeriod==='M') return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
    if(gaPeriod==='Q') return d.getFullYear()+'-Q'+Math.ceil((d.getMonth()+1)/3);
    return String(d.getFullYear());
  };
  const periods=gaPeriod==='W'?12:gaPeriod==='M'?12:gaPeriod==='Q'?8:5;
  const buckets=[];
  for(let i=periods-1;i>=0;i--){
    let label,bucket;
    if(gaPeriod==='W'){
      const d=new Date(now);d.setDate(d.getDate()-i*7);
      bucket=d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
      label='W'+getWeekOfYear(d);
    } else if(gaPeriod==='M'){
      const d=new Date(now.getFullYear(),now.getMonth()-i,1);
      bucket=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
      label=d.toLocaleDateString('en-US',{month:'short',year:'2-digit'});
    } else if(gaPeriod==='Q'){
      const totalQ=now.getFullYear()*4+Math.ceil((now.getMonth()+1)/3)-1-i;
      const yr=Math.floor(totalQ/4);const q=(totalQ%4)+1;
      bucket=yr+'-Q'+q;label='Q'+q+' '+String(yr).slice(2);
    } else {
      const yr=now.getFullYear()-i;bucket=String(yr);label=String(yr);
    }
    labels.push(label);buckets.push(bucket);
    vals.push(bids.filter(b=>{const rd=getRelevantDate(b);if(!rd)return false;return getBucket(rd)===bucket;}).reduce((s,b)=>s+b[metricKey],0));
  }
  const ctx=el('chartGA').getContext('2d');
  const gaGrad=ctx.createLinearGradient(0,0,0,260);
  gaGrad.addColorStop(0,c.p2a+'0.4)');gaGrad.addColorStop(1,c.p2a+'0.02)');
  CHARTS.ga=new Chart(el('chartGA'),{type:'line',
    data:{labels,datasets:[{label:metricLabel,data:vals,borderColor:c.p2,backgroundColor:gaGrad,fill:true,tension:.42,pointRadius:5,pointHoverRadius:8,pointBackgroundColor:c.p2,pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:2.5}]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{backgroundColor:'rgba(0,0,0,.75)',padding:12,cornerRadius:10,titleFont:{size:13,weight:'700'},bodyFont:{size:12}}
      },
      scales:{x:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{color:c.grid},border:{dash:[4,4]}},y:{ticks:{color:c.text},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true}}}});

  const wrap=el('gaControlsWrap');
  if(wrap){
    wrap.innerHTML=`
      <div style="display:flex;justify-content:flex-end;margin-top:.65rem;gap:.35rem;">
        ${['W','M','Q','Y'].map(p=>`<button type="button" onclick="gaPeriod='${p}';renderGA(getViewBids(),getChartColors())" style="padding:.25rem .7rem;border-radius:6px;font-size:.72rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:${gaPeriod===p?'var(--grad)':'var(--bg-secondary)'};color:${gaPeriod===p?'#fff':'var(--t3)'}">${p==='W'?'Week':p==='M'?'Month':p==='Q'?'Quarter':'Year'}</button>`).join('')}
      </div>`;
  }
}

// ══════════════════════════════════════════════════════════════════
//  AG GRID
// ══════════════════════════════════════════════════════════════════
function renderGrid(){
  if(typeof agGrid==='undefined'){ el('myGrid').innerHTML='<div style="padding:20px;color:var(--t3);">AG Grid not loaded.</div>'; return; }
  const data=getViewBids();
  const cols=[
    {field:'headDirector',headerName:'Head Director',width:155,pinned:'left'},
    {field:'accountDirector',headerName:'Account Director',width:155,pinned:'left'},
    {field:'amName',headerName:'Account Manager',width:145},
    {field:'customerName',headerName:'Customer',width:180},
    {field:'typeOfRequest',headerName:'Type of Request',width:140},
    {field:'typeOfContract',headerName:'Type of Contract',width:140},
    {field:'vertical',headerName:'Vertical',width:120},
    {field:'productFamily',headerName:'Product Family',width:130},
    {field:'productCategory',headerName:'Product Category',width:145},
    {field:'services',headerName:'Services',width:155},
    {field:'gaPoints',headerName:'GA Points',width:100,type:'numericColumn'},
    {field:'mrc',headerName:'MRC',width:110,valueFormatter:p=>fmt(p.value),type:'numericColumn'},
    {field:'otc',headerName:'OTC',width:110,valueFormatter:p=>fmt(p.value),type:'numericColumn'},
    {field:'tcv',headerName:'TCV',width:120,valueFormatter:p=>fmt(p.value),type:'numericColumn',cellStyle:{fontWeight:'700'}},
    {
      headerName:'Year Impact ⓘ',
      width:155,
      sortable:true,
      resizable:true,
      type:'numericColumn',
      headerTooltip:'Year Impact = MRC × months remaining in current year from Expected Activation date (inclusive). Only current-year activation dates are calculated. Past year = skipped. Next year = shown with note. Excludes Lost / Cancelled / No Bid.',
      valueGetter: p => { const r = calcYearImpact(p.data); return r.val; },
      cellRenderer: p => {
        const r = calcYearImpact(p.data);
        if (r.val === null && r.note) return `<span style="color:var(--t3);font-size:.76rem;font-style:italic">— <span title="${r.note}" style="cursor:help;border-bottom:1px dashed var(--t3);">ⓘ</span></span>`;
        if (r.val === null) return `<span style="color:var(--t3);">—</span>`;
        return `<span style="font-weight:700;color:var(--sc);">${fmtYearImpact(r.val)}</span>`;
      },
      cellStyle:{ display:'flex', alignItems:'center' }
    },
    {field:'pcv',headerName:'Cat. Value',width:110,valueFormatter:p=>fmt(p.value),type:'numericColumn'},
    {field:'status',headerName:'Status',width:115,cellRenderer:p=>{
      const s=p.value||'—'; const cl=STATUS_WON.includes(s)?'badge-success':STATUS_LOST.includes(s)?'badge-danger':'badge-warning';
      return `<span class="status-badge ${cl}">${s}</span>`;
    }},
    {field:'closureProb',headerName:'Closure Prob.',width:120,cellRenderer:p=>{
      const v=p.value||'—'; const col=v==='100%'?'#16a34a':v==='75%'?'rgba(22,163,74,.8)':v==='50%'?'#b45309':'#dc2626';
      return `<span style="font-weight:700;color:${col}">${v}</span>`;
    }},
    {field:'complexity',headerName:'Complexity',width:110},
    {field:'proposedDate',headerName:'Proposed Date',width:130,valueFormatter:p=>fmtDate(p.value)},
    {field:'expectedActivation',headerName:'Expected Activation',width:150,valueFormatter:p=>fmtDate(p.value)},
    {field:'contractSigned',headerName:'Contract Signed',width:140,valueFormatter:p=>fmtDate(p.value)},
    {field:'billedDate',headerName:'Billed Date',width:120,valueFormatter:p=>fmtDate(p.value)},
    {field:'lostDate',headerName:'Lost Date',width:120,valueFormatter:p=>fmtDate(p.value)},
    {field:'lostReason',headerName:'Lost Reason',width:160},
    {field:'duration',headerName:'Duration',width:100},
    {field:'customerCode',headerName:'Customer Code',width:130},
    {field:'bidManager',headerName:'Bid Manager',width:140},
    {field:'projectManager',headerName:'Project Manager',width:140},
    {field:'prepaidPostpaid',headerName:'Pre/Postpaid',width:115},
  ];
  const opts={
    columnDefs:cols,rowData:data,
    defaultColDef:{sortable:true,filter:true,resizable:true},
    pagination:true,paginationPageSize:50,paginationPageSizeSelector:[25,50,100,250],
    rowHeight:44,headerHeight:48,animateRows:true,enableCellTextSelection:true,
    onGridReady:p=>{GRID_API=p.api;}
  };
  if(GRID_API){try{GRID_API.destroy();}catch(e){} GRID_API=null;}
  el('myGrid').innerHTML='';
  agGrid.createGrid(el('myGrid'),opts);
}
function gridSearch(v){ if(GRID_API) GRID_API.setGridOption('quickFilterText',v); }

// ══════════════════════════════════════════════════════════════════
//  EXPORT
// ══════════════════════════════════════════════════════════════════
function exportExcel(){
  const data=getViewBids();
  const cols=['headDirector','accountDirector','amName','customerName','typeOfRequest','typeOfContract','vertical','productFamily','productCategory','services','gaPoints','mrc','otc','tcv','pcv','status','closureProb','complexity','proposedDate','expectedActivation','contractSigned','billedDate','lostDate','lostReason','duration','customerCode','bidManager','projectManager','prepaidPostpaid'];
  const headers=['Head Director','Account Director','Account Manager','Customer','Type of Request','Type of Contract','Vertical','Product Family','Product Category','Services','GA Points','MRC','OTC','TCV','Cat. Value','Status','Closure Prob.','Complexity','Proposed Date','Expected Activation','Contract Signed','Billed Date','Lost Date','Lost Reason','Duration','Customer Code','Bid Manager','Project Manager','Pre/Postpaid'];
  let html='<html><head><meta charset="utf-8"></head><body><table border="1" cellpadding="4" cellspacing="0">';
  html+='<tr>'+headers.map(h=>'<th style="background:#a855f7;color:white;font-weight:bold;padding:10px;">'+h+'</th>').join('')+'</tr>';
  data.forEach((row,i)=>{
    const bg=i%2===0?'#f9f0ff':'#ffffff';
    html+='<tr>'+cols.map(c=>{let v=row[c]||'—';if(['proposedDate','expectedActivation','contractSigned','billedDate','lostDate'].includes(c))v=fmtDate(v);if(['mrc','otc','tcv','pcv'].includes(c))v=fmt(num(v));return '<td style="background:'+bg+';padding:8px;">'+v+'</td>';}).join('')+'</tr>';
  });
  html+='</table></body></html>';
  const blob=new Blob([html],{type:'application/vnd.ms-excel'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
  a.download='GLK_Pipeline_'+new Date().toISOString().split('T')[0]+'.xls'; a.click();
}

// ══════════════════════════════════════════════════════════════════
//  RESET
// ══════════════════════════════════════════════════════════════════
function resetAll(){
  selHD=null;selAD=null;selAM=null;selStatusTile=null; hideAD(); hideAM();
  document.querySelectorAll('.ms-dropdown input:not([disabled])').forEach(cb=>cb.checked=false);
  FILTER_DEFS.forEach(fd=>updateMsText(fd.key));
  applyAll();
  updateSelectionBadge();
}

// ══════════════════════════════════════════════════════════════════
//  SIDEBAR / THEME / SECTION SWITCHING
// ══════════════════════════════════════════════════════════════════
function toggleSidebar(){
  const sb=el('sidebar'); sb.classList.toggle('collapsed');
  const collapsed=sb.classList.contains('collapsed');
  el('sidebarToggleIcon').innerHTML=collapsed?
    '<polyline points="9 18 15 12 9 6"/><polyline points="15 18 21 12 15 6"/>':
    '<polyline points="15 18 9 12 15 6"/><polyline points="9 18 3 12 9 6"/>';
}
function switchSection(id){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const target=document.getElementById(id);
  if(target) target.scrollIntoView({behavior:'smooth',block:'start'});
  event.currentTarget.classList.add('active');
}
function applyTheme(base,dark){
  if(base==='duralux') document.body.setAttribute('data-theme',dark?'duralux-dark':'duralux');
  else { if(dark) document.body.setAttribute('data-theme','dark'); else document.body.removeAttribute('data-theme'); }
  const icon=el('themeIcon');
  if(icon) icon.innerHTML=dark?
    '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>':
    '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
}
function glkShowAnalytics() {
    document.getElementById('dashboard-view').style.display = 'none';
    document.getElementById('table-nav').style.display = 'none';
    document.getElementById('analytics-nav').style.display = 'block';
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    document.getElementById('navAnalytics').classList.add('active');
    glkLoadAnalytics();
}
function changeTheme(event){
  const base=event.target.value;
  const cur=document.body.getAttribute('data-theme')||'';
  const isDark=cur==='dark'||cur==='duralux-dark';
  applyTheme(base,isDark);
  try{localStorage.setItem('glk_base_theme',base);}catch(e){}
  setTimeout(()=>renderCharts(),100);
}
function toggleTheme(){
  const cur=document.body.getAttribute('data-theme')||'';
  const isDark=cur==='dark'||cur==='duralux-dark';
  const isDural=cur==='duralux'||cur==='duralux-dark';
  applyTheme(isDural?'duralux':'magenta',!isDark);
  try{localStorage.setItem('glk_dark_mode',String(!isDark));}catch(e){}
  setTimeout(()=>renderCharts(),100);
}
function updateSelectionBadge(){
  const b=el('selectionBadge'); if(!b) return;
  const parts=[];
  if(selHD) parts.push('HD: '+selHD);
  if(selAD) parts.push('AD: '+selAD);
  if(selAM) parts.push('AM: '+selAM);
  if(selStatusTile) parts.push('Status: '+selStatusTile);
  if(parts.length){ b.textContent=parts.join(' › '); b.style.display='flex'; }
  else { b.textContent=''; b.style.display='none'; }
}

// ══════════════════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════════════════
window.addEventListener('load',function(){
  el('landingPage').style.display='flex';
  try{
    const bt=localStorage.getItem('glk_base_theme')||'magenta';
    const dm=localStorage.getItem('glk_dark_mode')==='true';
    const sel=el('colorSchemeSelector'); if(sel) sel.value=bt;
    applyTheme(bt,dm);
  }catch(e){}
  initAccess();
});
</script>
<script src="/sites/GKA/SiteAssets/glk-analytics.js"></script></body>
</html>
